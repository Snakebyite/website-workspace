---
// ProblemVisual.astro — "Fragmented Marketplace" flow diagram
// Same style as StrategieVisual/OrganicVisual: pills, connection lines, dots, hub
// Shows: scattered channels feeding into an overwhelmed center with no clear output
---

<div class="problem-visual w-full max-w-[440px]" aria-hidden="true">
  <svg
    class="w-full h-auto"
    viewBox="0 0 440 400"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <filter id="pv-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="4" />
      </filter>
    </defs>

    <!-- ═══ INPUT PILLS (left — scattered channels) ═══ -->
    <g class="pv-pill" style="opacity:0;">
      <rect x="10" y="45" width="120" height="36" rx="18" fill="rgba(239,68,68,0.05)" stroke="rgba(239,68,68,0.15)" stroke-width="1" />
      <text x="70" y="68" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Amazon</text>
    </g>

    <g class="pv-pill" style="opacity:0;">
      <rect x="10" y="115" width="120" height="36" rx="18" fill="rgba(239,68,68,0.05)" stroke="rgba(239,68,68,0.15)" stroke-width="1" />
      <text x="70" y="138" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Otto</text>
    </g>

    <g class="pv-pill" style="opacity:0;">
      <rect x="10" y="185" width="120" height="36" rx="18" fill="rgba(239,68,68,0.05)" stroke="rgba(239,68,68,0.15)" stroke-width="1" />
      <text x="70" y="208" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Support</text>
    </g>

    <g class="pv-pill" style="opacity:0;">
      <rect x="10" y="255" width="120" height="36" rx="18" fill="rgba(239,68,68,0.05)" stroke="rgba(239,68,68,0.15)" stroke-width="1" />
      <text x="70" y="278" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">eBay</text>
    </g>

    <!-- ═══ CONNECTION LINES (fragmented, dashed — chaos feel) ═══ -->
    <path class="pv-line" d="M 130 63 L 175 63 L 200 155" stroke="rgba(239,68,68,0.15)" stroke-width="1.5" stroke-dasharray="4 4" fill="none" style="opacity:0;" />
    <path class="pv-line" d="M 130 133 L 170 133 L 200 165" stroke="rgba(239,68,68,0.15)" stroke-width="1.5" stroke-dasharray="4 4" fill="none" style="opacity:0;" />
    <path class="pv-line" d="M 130 203 L 170 203 L 200 185" stroke="rgba(239,68,68,0.15)" stroke-width="1.5" stroke-dasharray="4 4" fill="none" style="opacity:0;" />
    <path class="pv-line" d="M 130 273 L 175 273 L 200 195" stroke="rgba(239,68,68,0.15)" stroke-width="1.5" stroke-dasharray="4 4" fill="none" style="opacity:0;" />

    <!-- Junction dots (scattered, not aligned — chaos) -->
    <circle class="pv-dot" cx="175" cy="63" r="3" fill="rgba(239,68,68,0.3)" style="opacity:0;" />
    <circle class="pv-dot" cx="170" cy="133" r="3" fill="rgba(239,68,68,0.3)" style="opacity:0;" />
    <circle class="pv-dot" cx="170" cy="203" r="3" fill="rgba(239,68,68,0.3)" style="opacity:0;" />
    <circle class="pv-dot" cx="175" cy="273" r="3" fill="rgba(239,68,68,0.3)" style="opacity:0;" />

    <!-- ═══ CENTER HUB — overwhelmed / "?" ═══ -->
    <g class="pv-hub" style="opacity:0;">
      <!-- Warning glow -->
      <circle cx="240" cy="175" r="55" fill="rgba(239,68,68,0.03)" filter="url(#pv-glow)" />
      <!-- Outer ring -->
      <rect x="198" y="133" width="84" height="84" rx="20" fill="rgba(239,68,68,0.04)" stroke="rgba(239,68,68,0.15)" stroke-width="1.2" />
      <!-- Inner ring -->
      <rect x="210" y="145" width="60" height="60" rx="15" fill="rgba(239,68,68,0.06)" stroke="rgba(239,68,68,0.2)" stroke-width="1" />
      <!-- "?" symbol -->
      <text x="240" y="184" text-anchor="middle" fill="rgba(239,68,68,0.5)" font-family="var(--font-body)" font-size="28" font-weight="700">?</text>
      <!-- Pins (top) -->
      <line x1="218" y1="126" x2="218" y2="133" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
      <line x1="232" y1="126" x2="232" y2="133" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
      <line x1="246" y1="126" x2="246" y2="133" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
      <line x1="260" y1="126" x2="260" y2="133" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
      <!-- Pins (bottom) -->
      <line x1="218" y1="217" x2="218" y2="224" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
      <line x1="232" y1="217" x2="232" y2="224" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
      <line x1="246" y1="217" x2="246" y2="224" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
      <line x1="260" y1="217" x2="260" y2="224" stroke="rgba(239,68,68,0.12)" stroke-width="1" />
    </g>

    <!-- ═══ OUTPUT — broken / no result ═══ -->
    <!-- Line from hub going right — but dashed, fading out -->
    <line class="pv-line" x1="282" y1="175" x2="340" y2="175" stroke="rgba(239,68,68,0.1)" stroke-width="1.5" stroke-dasharray="4 6" style="opacity:0;" />
    <circle class="pv-dot" cx="310" cy="175" r="3" fill="rgba(239,68,68,0.2)" style="opacity:0;" />

    <!-- Empty output pill — the result is missing -->
    <g class="pv-pill" style="opacity:0;">
      <rect x="345" y="157" width="85" height="36" rx="18" fill="rgba(255,255,255,0.015)" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="3 3" />
      <text x="387" y="180" text-anchor="middle" fill="rgba(255,255,255,0.2)" font-family="var(--font-body)" font-size="11" font-weight="500">Kein Plan</text>
    </g>

    <!-- ═══ BOTTOM LABELS — pain summary ═══ -->
    <g class="pv-label" style="opacity:0;">
      <rect x="60" y="330" width="135" height="30" rx="15" fill="rgba(239,68,68,0.05)" stroke="rgba(239,68,68,0.12)" stroke-width="0.8" />
      <text x="127" y="350" text-anchor="middle" fill="rgba(239,68,68,0.5)" font-family="var(--font-body)" font-size="10" font-weight="600">Marge schrumpft</text>
    </g>

    <g class="pv-label" style="opacity:0;">
      <rect x="215" y="330" width="135" height="30" rx="15" fill="rgba(251,191,36,0.05)" stroke="rgba(251,191,36,0.12)" stroke-width="0.8" />
      <text x="282" y="350" text-anchor="middle" fill="rgba(251,191,36,0.5)" font-family="var(--font-body)" font-size="10" font-weight="600">Keine Zeit</text>
    </g>
  </svg>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initProblemVisual(): void {
    const visual = document.querySelector<HTMLElement>(".problem-visual");
    if (!visual) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      visual.querySelectorAll("[style*='opacity:0']").forEach(el => {
        (el as HTMLElement).style.opacity = "1";
      });
      return;
    }

    const ctx = gsap.context(() => {
      const pills = visual.querySelectorAll(".pv-pill");
      const lines = visual.querySelectorAll(".pv-line");
      const dots = visual.querySelectorAll(".pv-dot");
      const hub = visual.querySelector(".pv-hub");
      const labels = visual.querySelectorAll(".pv-label");

      const tl = gsap.timeline({
        defaults: { ease: "power2.out" },
        scrollTrigger: {
          trigger: visual,
          start: "top 80%",
          once: true,
        },
      });

      // Input pills stagger in from left
      tl.to([pills[0], pills[1], pills[2], pills[3]], {
        opacity: 1,
        duration: 0.4,
        stagger: 0.1,
        ease: "back.out(1.2)",
      });

      // Connection lines fade in
      tl.to(lines, { opacity: 1, duration: 0.4, stagger: 0.06 }, "-=0.2");

      // Junction dots pop
      tl.to(dots, { opacity: 1, duration: 0.3, stagger: 0.05, ease: "back.out(2)" }, "-=0.2");

      // Hub appears with slight shake
      tl.to(hub, { opacity: 1, duration: 0.5 }, "-=0.1");

      // Output pill (empty/broken)
      tl.to(pills[4], { opacity: 1, duration: 0.4 }, "-=0.1");

      // Bottom labels
      tl.to(labels, { opacity: 1, duration: 0.4, stagger: 0.12 }, "-=0.1");

      // Continuous subtle pulse on the "?" hub — feels unstable
      gsap.to(hub, {
        scale: 1.02,
        duration: 2,
        yoyo: true,
        repeat: -1,
        ease: "sine.inOut",
        transformOrigin: "240px 175px",
        delay: 2,
      });

      // Dots pulse
      dots.forEach((dot, i) => {
        gsap.to(dot, {
          opacity: 0.1,
          duration: 1.5 + i * 0.3,
          yoyo: true,
          repeat: -1,
          ease: "sine.inOut",
          delay: 2.5 + i * 0.4,
        });
      });

    }, visual);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initProblemVisual();
  document.addEventListener("astro:after-swap", initProblemVisual);
</script>
