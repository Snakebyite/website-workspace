---
import { Menu, X } from "@lucide/astro";

const navLinks = [
  { label: "Leistungen", href: "/leistungen" },
  { label: "Über uns", href: "/ueber-uns" },
  { label: "Referenzen", href: "/#referenzen" },
];

const bookingUrl = "https://calendly.com/kflconsulting/kennenlernen";

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 w-full z-50 bg-[rgba(10,10,10,0.9)]">
  <nav class="mx-auto max-w-7xl px-4 md:px-8" aria-label="Hauptnavigation">
    <div class="relative flex items-center justify-between h-18 md:h-24">
      <!-- Logo -->
      <a href="/" class="block shrink-0">
        <img src="/kfl-logo-white.png" alt="KFL Consulting" class="h-9 md:h-11 w-auto" />
      </a>

      <!-- Desktop Nav — true center via absolute positioning -->
      <div class="hidden md:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-bold transition-colors duration-200 py-2",
              currentPath === link.href
                ? "text-text-primary"
                : "text-text-secondary hover:text-text-primary",
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Desktop CTA — isolated right -->
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-block bg-accent hover:bg-accent-hover text-background font-medium text-sm px-6 py-3 rounded-button transition-colors duration-200"
      >
        Termin buchen
      </a>

      <!-- Mobile Menu Toggle -->
      <button
        class="md:hidden text-text-primary p-3 -mr-3"
        aria-label="Menü öffnen"
        aria-expanded="false"
        data-menu-toggle
      >
        <Menu class="size-6" data-menu-icon />
        <X class="size-6 hidden" data-close-icon />
      </button>
    </div>

    <!-- Mobile Menu -->
    <div
      class="md:hidden overflow-hidden transition-[grid-template-rows] duration-300 ease-out grid"
      style="grid-template-rows: 0fr;"
      data-mobile-menu
    >
      <div class="min-h-0">
        <div class="flex flex-col gap-1 pt-4 pb-6">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "text-base font-medium py-3 transition-colors duration-200",
                currentPath === link.href
                  ? "text-text-primary"
                  : "text-text-secondary hover:text-text-primary",
              ]}
            >
              {link.label}
            </a>
          ))}
          <a
            href={bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-accent hover:bg-accent-hover text-background font-medium text-base px-6 py-3 rounded-button transition-colors duration-200 text-center mt-4"
          >
            Termin buchen
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector(
    "[data-menu-toggle]"
  ) as HTMLButtonElement;
  const menu = document.querySelector("[data-mobile-menu]") as HTMLElement;
  const menuIcon = document.querySelector("[data-menu-icon]") as HTMLElement;
  const closeIcon = document.querySelector("[data-close-icon]") as HTMLElement;

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    const opening = !expanded;

    toggle.setAttribute("aria-expanded", String(opening));
    menu.style.gridTemplateRows = opening ? "1fr" : "0fr";
    menuIcon.classList.toggle("hidden", opening);
    closeIcon.classList.toggle("hidden", !opening);
    toggle.setAttribute(
      "aria-label",
      opening ? "Menü schließen" : "Menü öffnen"
    );
  });
</script>
