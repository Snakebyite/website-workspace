---
const navLinks = [
  { label: "Leistungen", href: "/leistungen" },
  { label: "Über uns", href: "/ueber-uns" },
  { label: "Referenzen", href: "/#referenzen" },
];

const bookingUrl = "https://calendly.com/kflconsulting/kennenlernen";

const legalLinks = [
  { label: "Impressum", href: "/impressum" },
  { label: "Datenschutz", href: "/datenschutz" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-surface border-t border-white/5">
  <div class="mx-auto max-w-7xl px-4 md:px-8 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <!-- Brand -->
      <div class="md:col-span-6">
        <a href="/" class="block">
          <img src="/kfl-logo-white.png" alt="KFL Consulting" class="h-8 w-auto" />
        </a>
        <p class="mt-4 text-text-secondary text-sm leading-relaxed max-w-sm">
          Dein Best Interest Advisor für digitale Marktplätze.
          Gründergeführt, strategisch, hands-on.
        </p>
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-block bg-accent hover:bg-accent-hover text-background font-medium text-sm px-6 py-3 rounded-button transition-colors duration-200"
        >
          Termin buchen
        </a>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-3">
        <p class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">
          Navigation
        </p>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-text-secondary hover:text-text-primary focus-visible:outline-1 focus-visible:outline-accent-text transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div class="md:col-span-3">
        <p class="text-xs font-medium text-text-muted uppercase tracking-wider mb-4">
          Rechtliches
        </p>
        <ul class="flex flex-col gap-3">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-text-secondary hover:text-text-primary focus-visible:outline-1 focus-visible:outline-accent-text transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <button
              type="button"
              onclick="if(window.Cookiebot){Cookiebot.renew();}"
              class="text-sm text-text-secondary hover:text-text-primary focus-visible:outline-1 focus-visible:outline-accent-text transition-colors duration-200 bg-transparent border-0 p-0 cursor-pointer text-left font-[inherit]"
            >
              Cookie-Einstellungen
            </button>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom -->
    <div class="mt-16 pt-8 border-t border-white/5">
      <p class="text-text-muted text-xs">
        &copy; {currentYear} KFL Consulting. Alle Rechte vorbehalten.
      </p>
    </div>
  </div>
</footer>
