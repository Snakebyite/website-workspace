---
// StrategieClarityVisual — Hochformat, Analyse-Pool oben → Priorisierte Hebel unten.
// Chaos-Chips in obere Hälfte (y 5-55%), 3 Winner-Slots vertikal unten (y 68/80/92%).
// Loop wechselt die ausgewählten 3 über 3 kuratierte Sets.

const chips = [
  { id: "amazon-seo",     text: "Amazon SEO",               pos: { x: 16, y: 8,  rot: -3 } },
  { id: "dsp",            text: "Amazon DSP",               pos: { x: 44, y: 5,  rot: 2 } },
  { id: "otto",           text: "Otto anbinden",            pos: { x: 74, y: 10, rot: 4 } },
  { id: "brandstore",     text: "Brand-Store",              pos: { x: 92, y: 6,  rot: -4 } },
  { id: "stammdaten",     text: "Stammdaten harmonisieren", pos: { x: 14, y: 22, rot: 3 } },
  { id: "vine",           text: "Amazon Vine",              pos: { x: 40, y: 19, rot: 3 } },
  { id: "kaufland",       text: "Kaufland launchen",        pos: { x: 62, y: 24, rot: -2 } },
  { id: "ppc",            text: "PPC rebalancieren",        pos: { x: 86, y: 22, rot: -5 } },
  { id: "pricing",        text: "Pricing-Tests",            pos: { x: 20, y: 36, rot: 4 } },
  { id: "reviews",        text: "Reviews strategisch",      pos: { x: 48, y: 38, rot: 2 } },
  { id: "prozesse",       text: "Prozess-Automatisierung",  pos: { x: 76, y: 36, rot: 4 } },
  { id: "content",        text: "Content-Velocity",         pos: { x: 10, y: 48, rot: -3 } },
  { id: "sortiment",      text: "Sortiment bereinigen",     pos: { x: 36, y: 52, rot: -4 } },
  { id: "en-rollout",     text: "EN-Rollout",               pos: { x: 58, y: 52, rot: 5 } },
  { id: "zalando",        text: "Zalando Partner",          pos: { x: 82, y: 50, rot: -3 } },
  { id: "tiktok",         text: "TikTok Shop",              pos: { x: 30, y: 14, rot: -2 } },
] as const;

type Prio = "hoch" | "mittel" | "niedrig";

const sets: { ids: string[]; prios: Prio[] }[] = [
  { ids: ["amazon-seo", "otto", "ppc"],          prios: ["hoch", "hoch", "mittel"] },
  { ids: ["stammdaten", "kaufland", "prozesse"], prios: ["hoch", "mittel", "mittel"] },
  { ids: ["sortiment", "reviews", "en-rollout"], prios: ["hoch", "mittel", "niedrig"] },
];
---

<div class="clarity-wrap" data-clarity-wrap>
  <div class="clarity-canvas" data-clarity-canvas>
    {/* Horizontaler Divider zwischen Pool (oben) und Hebel-Zone (unten) */}
    <div class="clarity-divider" aria-hidden="true"></div>

    {/* Leere Slot-Marker unten — zeigen wo Hebel landen, auch im Chaos-State */}
    <div class="slot-marker" data-slot-marker="0" aria-hidden="true"></div>
    <div class="slot-marker" data-slot-marker="1" aria-hidden="true"></div>
    <div class="slot-marker" data-slot-marker="2" aria-hidden="true"></div>

    {chips.map((chip) => (
      <div
        class="chip"
        data-chip-id={chip.id}
        style={`--x: ${chip.pos.x}%; --y: ${chip.pos.y}%; --rot: ${chip.pos.rot}deg;`}
      >
        <span class="chip-text">{chip.text}</span>
        <span class="chip-prio" data-prio aria-hidden="true"></span>
      </div>
    ))}

    {/* Radial Glow hinter der Hebel-Zone unten */}
    <div class="clarity-glow" data-clarity-glow aria-hidden="true"></div>
  </div>

  <script type="application/json" data-clarity-sets set:html={JSON.stringify(sets)}></script>
</div>

<style>
  .clarity-wrap {
    width: 100%;
  }

  .clarity-canvas {
    position: relative;
    width: 100%;
    height: 640px;
    border-radius: 1rem;
    overflow: hidden;
  }

  .clarity-divider {
    position: absolute;
    left: 10%;
    right: 10%;
    top: 60%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(255, 255, 255, 0.06) 25%,
      rgba(255, 255, 255, 0.06) 75%,
      transparent 100%
    );
    pointer-events: none;
  }

  .clarity-glow {
    position: absolute;
    left: 50%;
    top: 80%;
    width: 480px;
    height: 300px;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse at center, rgba(107, 175, 150, 0.1) 0%, transparent 70%);
    opacity: 0.4;
    pointer-events: none;
  }

  .slot-marker {
    position: absolute;
    left: 50%;
    width: 240px;
    height: 36px;
    border-radius: 9999px;
    border: 1px dashed rgba(255, 255, 255, 0.08);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .slot-marker[data-slot-marker="0"] { top: 68%; }
  .slot-marker[data-slot-marker="1"] { top: 80%; }
  .slot-marker[data-slot-marker="2"] { top: 92%; }

  .chip {
    position: absolute;
    left: var(--x);
    top: var(--y);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    color: #efefef;
    font-size: 0.875rem;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
    will-change: transform, opacity;
    transition: border-color 0.4s ease, background-color 0.4s ease;
    transform: translate(-50%, -50%) rotate(var(--rot));
  }

  .chip.is-winner {
    border-color: rgba(107, 175, 150, 0.45);
    background: rgba(107, 175, 150, 0.08);
  }

  .chip-prio {
    display: none;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    line-height: 1;
  }

  .chip.is-winner .chip-prio {
    display: inline-flex;
    align-items: center;
  }

  .chip-prio[data-prio="hoch"] {
    background: rgba(107, 175, 150, 0.18);
    color: #6baf96;
  }

  .chip-prio[data-prio="mittel"] {
    background: rgba(255, 255, 255, 0.08);
    color: #efefef;
  }

  .chip-prio[data-prio="niedrig"] {
    background: rgba(255, 255, 255, 0.04);
    color: #999999;
  }

  @media (max-width: 1024px) {
    .clarity-canvas {
      height: 560px;
    }
    .clarity-glow {
      width: 380px;
      height: 260px;
    }
    .slot-marker {
      width: 200px;
    }
  }

  @media (max-width: 640px) {
    .clarity-canvas {
      height: 500px;
    }
    .chip {
      font-size: 0.75rem;
      padding: 0.4375rem 0.75rem;
    }
    .slot-marker {
      width: 170px;
    }
    .clarity-glow {
      width: 300px;
      height: 220px;
    }
  }

  @media (max-width: 420px) {
    .clarity-canvas {
      height: 460px;
    }
    .chip {
      font-size: 0.6875rem;
      padding: 0.375rem 0.625rem;
    }
    .slot-marker {
      width: 150px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chip {
      transition: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  type Prio = "hoch" | "mittel" | "niedrig";

  function initClarity(): void {
    const wrap = document.querySelector<HTMLElement>("[data-clarity-wrap]");
    if (!wrap) return;

    const canvas = wrap.querySelector<HTMLElement>("[data-clarity-canvas]");
    const setsScript = wrap.querySelector<HTMLScriptElement>("[data-clarity-sets]");
    const glow = wrap.querySelector<HTMLElement>("[data-clarity-glow]");
    if (!canvas || !setsScript) return;

    const sets: { ids: string[]; prios: Prio[] }[] = JSON.parse(setsScript.textContent || "[]");
    if (!sets.length) return;

    const chips = Array.from(canvas.querySelectorAll<HTMLElement>(".chip"));
    const chipsById = new Map<string, HTMLElement>();
    chips.forEach((c) => {
      const id = c.dataset.chipId;
      if (id) chipsById.set(id, c);
    });

    const baselines = new Map<HTMLElement, { rot: number }>();
    chips.forEach((c) => {
      const rot = parseFloat(c.style.getPropertyValue("--rot")) || 0;
      baselines.set(c, { rot });
      gsap.set(c, { xPercent: -50, yPercent: -50, rotation: rot, scale: 1, opacity: 0.65 });
    });

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function getSlotPositions(): { x: number; y: number }[] {
      const rect = canvas!.getBoundingClientRect();
      const sx = rect.width * 0.5;
      return [
        { x: sx, y: rect.height * 0.68 },
        { x: sx, y: rect.height * 0.8 },
        { x: sx, y: rect.height * 0.92 },
      ];
    }

    function getChaosCoords(chip: HTMLElement): { x: number; y: number } {
      const rect = canvas!.getBoundingClientRect();
      const xPct = parseFloat(chip.style.getPropertyValue("--x")) || 50;
      const yPct = parseFloat(chip.style.getPropertyValue("--y")) || 50;
      return { x: (xPct / 100) * rect.width, y: (yPct / 100) * rect.height };
    }

    function applyClarityStatic(set: { ids: string[]; prios: Prio[] }): void {
      const slots = getSlotPositions();
      chips.forEach((c) => {
        c.classList.remove("is-winner");
        const prioEl = c.querySelector<HTMLElement>("[data-prio]");
        if (prioEl) {
          prioEl.removeAttribute("data-prio");
          prioEl.textContent = "";
        }
      });
      set.ids.forEach((id, i) => {
        const chip = chipsById.get(id);
        if (!chip) return;
        chip.classList.add("is-winner");
        const prioEl = chip.querySelector<HTMLElement>("[data-prio]");
        if (prioEl) {
          prioEl.setAttribute("data-prio", set.prios[i]);
          prioEl.textContent = set.prios[i];
        }
        const slot = slots[i];
        const chaos = getChaosCoords(chip);
        gsap.set(chip, {
          x: slot.x - chaos.x,
          y: slot.y - chaos.y,
          rotation: 0,
          scale: 1.05,
          opacity: 1,
        });
      });
      chips.forEach((c) => {
        if (!c.classList.contains("is-winner")) {
          gsap.set(c, { opacity: 0.18 });
        }
      });
      if (glow) gsap.set(glow, { opacity: 1 });
    }

    if (reduced) {
      applyClarityStatic(sets[0]);
      return;
    }

    let tl: gsap.core.Timeline | null = null;
    let isPlaying = false;

    function buildTimeline(): void {
      if (tl) { tl.kill(); tl = null; }

      const master = gsap.timeline({ repeat: -1, repeatDelay: 0 });

      sets.forEach((set) => {
        const slots = getSlotPositions();
        const winnerIds = new Set(set.ids);

        // Phase 1: Reset zum Chaos-Zustand
        master.add(() => {
          chips.forEach((c) => {
            const prioEl = c.querySelector<HTMLElement>("[data-prio]");
            if (prioEl) {
              prioEl.removeAttribute("data-prio");
              prioEl.textContent = "";
            }
            c.classList.remove("is-winner");
          });
        });

        chips.forEach((c) => {
          const base = baselines.get(c)!;
          master.to(c, {
            x: 0,
            y: 0,
            rotation: base.rot,
            scale: 1,
            opacity: 0.65,
            duration: 0.7,
            ease: "power2.inOut",
          }, "<");
        });
        if (glow) master.to(glow, { opacity: 0.35, duration: 0.7, ease: "power2.inOut" }, "<");

        // Phase 2: Chaos-Hold
        master.to({}, { duration: 1.4 });

        // Phase 3: Kristallisation — Winner fliegen nach unten in Slots
        master.add(() => {
          set.ids.forEach((id, i) => {
            const chip = chipsById.get(id);
            if (!chip) return;
            chip.classList.add("is-winner");
            const prioEl = chip.querySelector<HTMLElement>("[data-prio]");
            if (prioEl) {
              prioEl.setAttribute("data-prio", set.prios[i]);
              prioEl.textContent = set.prios[i];
            }
          });
        });

        chips.forEach((c) => {
          if (winnerIds.has(c.dataset.chipId || "")) {
            const idx = set.ids.indexOf(c.dataset.chipId || "");
            const slot = slots[idx];
            const chaos = getChaosCoords(c);
            master.to(c, {
              x: slot.x - chaos.x,
              y: slot.y - chaos.y,
              rotation: 0,
              scale: 1.05,
              opacity: 1,
              duration: 1.1,
              ease: "power3.inOut",
            }, "<");
          } else {
            master.to(c, {
              opacity: 0.15,
              scale: 0.92,
              duration: 0.9,
              ease: "power2.inOut",
            }, "<");
          }
        });
        if (glow) master.to(glow, { opacity: 1, duration: 1.1, ease: "power2.inOut" }, "<");

        // Phase 4: Clarity-Hold
        master.to({}, { duration: 3.2 });
      });

      tl = master;
      tl.pause();
    }

    function play(): void {
      if (!tl) buildTimeline();
      if (tl && !isPlaying) {
        tl.play();
        isPlaying = true;
      }
    }

    function pause(): void {
      if (tl && isPlaying) {
        tl.pause();
        isPlaying = false;
      }
    }

    ScrollTrigger.create({
      trigger: canvas,
      start: "top 90%",
      end: "bottom 10%",
      onEnter: play,
      onEnterBack: play,
      onLeave: pause,
      onLeaveBack: pause,
    });

    let resizeTimer: number | null = null;
    window.addEventListener("resize", () => {
      if (resizeTimer) window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        const wasPlaying = isPlaying;
        buildTimeline();
        if (wasPlaying) play();
      }, 200);
    });

    buildTimeline();
  }

  initClarity();
  document.addEventListener("astro:after-swap", initClarity);
</script>
