---
// HeroVisual.astro — "Rank Rise"
// Foto im Vordergrund. Im Hintergrund: ein zentriertes Marktplatz-Ranking-Panel mit
// Suchleiste (inkl. Store-Icon als Plattform-Kontext) — Suche tippt sich ein,
// ein Listing rutscht durch Rewrite auf Platz 1. Rechts daneben ein kleines
// Hochkant-Datencockpit (3 Tiles: Sparkline, Gauge, Bars), rot im schlechten
// Zustand, shiftet mit dem Aufstieg zu grün.
import { Image } from 'astro:assets';
import heroPhoto from '../assets/kevin-luca-hero.webp';
import { Search, Store } from '@lucide/astro';

const ROWS = 5;
const HERO_INDEX = 3; // "unser Kunde" — startet auf Platz 4, klettert auf Platz 1
---

<div class="hero-visual hidden lg:block" aria-hidden="true">
  <div class="visual-scene relative">

    <!-- ═══ HINTERGRUND (z-[5]) ═══ -->

    <!-- Ranking-Panel mit Suchleiste -->
    <div class="rank-panel absolute z-[5]" style="opacity:0;">
      <div class="rank-search">
        <Search size={16} strokeWidth={2} class="search-icon" />
        <div class="search-query"></div>
        <div class="search-separator"></div>
        <Store size={16} strokeWidth={1.6} class="search-platform-icon" />
      </div>
      <div class="rank-stack">
        {Array.from({ length: ROWS }).map((_, i) => (
          <div class={`rank-row ${i === HERO_INDEX ? 'is-hero' : ''}`} data-row-index={i}>
            <div class="rank-thumb"></div>
            <div class="rank-bars">
              <div class="rank-bar rank-bar-title"></div>
              <div class="rank-bar rank-bar-meta"></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Data-Cockpit (hochkant, rechts vom Panel) -->
    <div class="data-cockpit absolute z-[5]" style="opacity:0;">
      <!-- Tile 1: Trend-Arrow (rotiert 180° bei Zustandswechsel) -->
      <div class="cockpit-tile">
        <svg class="cockpit-arrow" viewBox="0 0 32 32" preserveAspectRatio="xMidYMid meet">
          <path class="arrow-path" d="M 6 20 L 16 10 L 26 20"
                stroke="currentColor" stroke-width="2.8" fill="none"
                stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>

      <!-- Tile 2: Gauge -->
      <div class="cockpit-tile">
        <svg class="cockpit-gauge" viewBox="0 0 60 38" preserveAspectRatio="xMidYMid meet">
          <path d="M 8 34 A 22 22 0 0 1 52 34"
                stroke="rgba(255,255,255,0.08)" stroke-width="4" fill="none" stroke-linecap="round" />
          <path class="gauge-fill" d="M 8 34 A 22 22 0 0 1 52 34"
                stroke="#E05252" stroke-width="4" fill="none" stroke-linecap="round"
                pathLength="100" stroke-dasharray="100" stroke-dashoffset="75" />
        </svg>
      </div>

      <!-- Tile 3: Bars -->
      <div class="cockpit-tile">
        <div class="cockpit-bars">
          <div class="cockpit-bar"></div>
          <div class="cockpit-bar"></div>
          <div class="cockpit-bar"></div>
          <div class="cockpit-bar"></div>
          <div class="cockpit-bar"></div>
        </div>
      </div>
    </div>

    <!-- ═══ VORDERGRUND: Foto (z-10) ═══ -->
    <div class="relative z-10">
      <Image
        src={heroPhoto}
        alt="Kevin und Luca, Gründer von KFL Consulting"
        widths={[400, 600, 800]}
        sizes="(min-width: 1024px) 38vw, 0"
        class="hero-photo w-full h-auto select-none"
        loading="eager"
        decoding="async"
      />
    </div>

  </div>
</div>

<style>
  .hero-photo {
    display: block;
    width: 118%;
    margin-left: -9%;
    mask-image: linear-gradient(to bottom, black 95%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 95%, transparent 100%);
  }

  /* ── Ranking-Panel ───────────────────────────────────────── */
  .rank-panel {
    bottom: 0%;
    left: 50%;
    margin-left: -210px; /* zentriert das 420px breite Panel zwischen Kevin & Luca */
    width: 420px;
    padding: 14px;
    background: rgba(14, 14, 14, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    box-shadow:
      0 20px 48px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  /* Suchleiste */
  .rank-search {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 40px;
    padding: 0 14px;
    margin-bottom: 10px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
  }
  .search-icon {
    color: rgba(255, 255, 255, 0.45);
    flex-shrink: 0;
  }
  .search-query {
    flex: 1;
    height: 5px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.24);
    max-width: 70%;
    transform-origin: left center;
    transform: scaleX(0);
  }
  .search-separator {
    width: 1px;
    height: 18px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
    margin-left: auto;
  }
  .search-platform-icon {
    color: rgba(239, 239, 239, 0.55);
    flex-shrink: 0;
  }

  /* Listing-Stack */
  .rank-stack {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .rank-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    height: 52px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    will-change: transform;
  }
  .rank-row.is-hero {
    background: rgba(76, 175, 130, 0.08);
    border-color: rgba(76, 175, 130, 0.22);
  }

  .rank-thumb {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
    flex-shrink: 0;
  }
  .rank-row.is-hero .rank-thumb {
    background: linear-gradient(135deg, rgba(76,175,130,0.35), rgba(76,175,130,0.1));
  }

  .rank-bars {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .rank-bar {
    height: 5px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.12);
    transform-origin: left center;
  }
  .rank-bar-title { width: 85%; }
  .rank-bar-meta  { width: 55%; background: rgba(255, 255, 255, 0.07); }
  .rank-row.is-hero .rank-bar-title { background: rgba(76, 175, 130, 0.6); }
  .rank-row.is-hero .rank-bar-meta  { background: rgba(76, 175, 130, 0.3); }

  /* ── Data-Cockpit ────────────────────────────────────────── */
  .data-cockpit {
    bottom: 0%;
    left: 50%;
    margin-left: 220px; /* 10px rechts vom Panel-Rand */
    width: 88px;
    /* Höhe matcht das Panel: padding (28) + search (40) + margin (10) + stack (5×52 + 4×4 = 276) + border (2) */
    height: 356px;
    padding: 10px 8px;
    background: rgba(14, 14, 14, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    box-shadow:
      0 20px 48px rgba(0, 0, 0, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cockpit-tile {
    flex: 1;
    padding: 10px 8px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .cockpit-arrow {
    width: 100%;
    height: 100%;
    max-height: 44px;
    color: #E05252;
    transform-origin: center center;
    will-change: transform;
  }

  .cockpit-gauge {
    width: 100%;
    height: 100%;
    max-height: 52px;
  }

  .gauge-fill {
    transition: none;
  }

  .cockpit-bars {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 3px;
  }

  .cockpit-bar {
    flex: 1;
    height: 100%;
    background: #E05252;
    border-radius: 2px 2px 0 0;
    transform-origin: bottom center;
    will-change: transform;
  }
</style>

<script>
  import { gsap } from "gsap";

  function initHeroVisual(): void {
    const visual = document.querySelector<HTMLElement>(".hero-visual");
    if (!visual) return;

    const ctx = gsap.context(() => {
      const panel = visual.querySelector<HTMLElement>(".rank-panel");
      const rows = visual.querySelectorAll<HTMLElement>(".rank-row");
      const heroRow = visual.querySelector<HTMLElement>(".rank-row.is-hero");
      if (!panel || !rows.length || !heroRow) return;

      const heroIndex = parseInt(heroRow.dataset.rowIndex || "0", 10);
      const rowsAboveHero = Array.from(rows).filter((_, i) => i < heroIndex);
      const titleBar = heroRow.querySelector<HTMLElement>(".rank-bar-title");
      const thumb = heroRow.querySelector<HTMLElement>(".rank-thumb");
      const searchQuery = visual.querySelector<HTMLElement>(".search-query");

      // Cockpit
      const cockpit = visual.querySelector<HTMLElement>(".data-cockpit");
      const arrow = visual.querySelector<SVGSVGElement>(".cockpit-arrow");
      const gaugeFill = visual.querySelector<SVGPathElement>(".gauge-fill");
      const cockpitBars = visual.querySelectorAll<HTMLElement>(".cockpit-bar");

      const BAD_COLOR = "#E05252";
      const GOOD_COLOR = "#4CAF82";
      const BAR_BAD_SCALES  = [0.92, 0.80, 0.66, 0.50, 0.34];
      const BAR_GOOD_SCALES = [0.30, 0.48, 0.64, 0.80, 0.95];

      // Row-Step = Höhe (52) + Gap (4)
      const STEP = 56;

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // ── ENTRANCE ──────────────────────────────────────────────
      const entrance = gsap.timeline({ defaults: { ease: "power2.out" }, delay: 0.2 });
      entrance.fromTo(
        ".hero-photo",
        { opacity: 0, y: 15 },
        { opacity: 1, y: 0, duration: 0.9 },
      );
      entrance.fromTo(
        panel,
        { opacity: 0, y: 20, scale: 0.98 },
        { opacity: 1, y: 0, scale: 1, duration: 0.8, ease: "power3.out" },
        0.4,
      );

      // Cockpit-Ausgangszustand (rot, schlecht) + Entrance
      if (arrow) gsap.set(arrow, { rotation: 180, color: BAD_COLOR });
      if (gaugeFill) gsap.set(gaugeFill, { strokeDashoffset: 75, stroke: BAD_COLOR });
      cockpitBars.forEach((bar, i) => {
        gsap.set(bar, { scaleY: BAR_BAD_SCALES[i] ?? 0.5, backgroundColor: BAD_COLOR });
      });
      if (cockpit) {
        entrance.fromTo(
          cockpit,
          { opacity: 0, x: 16, scale: 0.96 },
          { opacity: 1, x: 0, scale: 1, duration: 0.8, ease: "power3.out" },
          0.55,
        );
      }

      if (reduced) {
        if (searchQuery) gsap.set(searchQuery, { scaleX: 0.65 });
        return;
      }

      // ── LOOP: SEARCH → RANK RISE ──────────────────────────────
      const loop = gsap.timeline({
        repeat: -1,
        delay: 2.0,
        defaults: { ease: "power2.inOut" },
      });

      // 1. Suche "tippt sich ein" (0 → 0.9)
      if (searchQuery) {
        loop.to(searchQuery, { scaleX: 1, duration: 0.9, ease: "steps(14)" }, 0);
      }

      // 2. Hero-Row Highlight-Puls (1.2 → 1.7)
      loop.to(heroRow, {
        scale: 1.03,
        backgroundColor: "rgba(76, 175, 130, 0.14)",
        borderColor: "rgba(76, 175, 130, 0.5)",
        duration: 0.5,
        ease: "power2.out",
      }, 1.2);

      // 3. Rewrite (1.5 → 2.6)
      if (titleBar) {
        loop.to(titleBar, { scaleX: 0, duration: 0.35, ease: "power1.in" }, 1.5);
        loop.to(titleBar, { scaleX: 1, duration: 0.7, ease: "power2.out" }, 1.85);
      }
      if (thumb) {
        loop.to(thumb, { opacity: 0.5, duration: 0.25 }, 1.5);
        loop.to(thumb, { opacity: 1, duration: 0.35 }, 1.85);
      }

      // 4. Aufstieg auf #1 (2.8 → 3.7) + Cockpit verbessert sich
      loop.to(heroRow, {
        y: -STEP * heroIndex,
        scale: 1.05,
        boxShadow: "0 10px 28px rgba(76, 175, 130, 0.18), 0 0 0 1px rgba(76, 175, 130, 0.4)",
        duration: 0.9,
        ease: "back.out(1.2)",
      }, 2.8);
      rowsAboveHero.forEach((row) => {
        loop.to(row, { y: STEP, duration: 0.9, ease: "power2.inOut" }, 2.8);
      });

      // Cockpit: rot → grün, Werte steigen
      if (arrow) loop.to(arrow, {
        rotation: 0,
        color: GOOD_COLOR,
        duration: 0.9,
        ease: "power3.out",
      }, 2.8);
      if (gaugeFill) loop.to(gaugeFill, {
        strokeDashoffset: 12,
        stroke: GOOD_COLOR,
        duration: 0.9,
        ease: "power2.out",
      }, 2.8);
      cockpitBars.forEach((bar, i) => {
        loop.to(bar, {
          scaleY: BAR_GOOD_SCALES[i] ?? 0.7,
          backgroundColor: GOOD_COLOR,
          duration: 0.9,
          ease: "power2.out",
        }, 2.8);
      });

      // 5. Halten mit Atmen (3.9 → 5.9)
      loop.to(heroRow, {
        scale: 1.03,
        duration: 1.0,
        ease: "sine.inOut",
        yoyo: true,
        repeat: 1,
      }, 3.9);

      // 6. Reset (6.8 → 7.8)
      if (searchQuery) {
        loop.to(searchQuery, { scaleX: 0, duration: 0.4, ease: "power1.in" }, 6.8);
      }
      loop.to(heroRow, {
        y: 0,
        scale: 1,
        backgroundColor: "rgba(76, 175, 130, 0.08)",
        borderColor: "rgba(76, 175, 130, 0.22)",
        boxShadow: "0 0 0 rgba(0,0,0,0)",
        duration: 1.0,
      }, 6.8);
      rowsAboveHero.forEach((row) => {
        loop.to(row, { y: 0, duration: 1.0 }, 6.8);
      });

      // Cockpit: zurück auf rot / schlechte Werte
      if (arrow) loop.to(arrow, {
        rotation: 180,
        color: BAD_COLOR,
        duration: 0.9,
        ease: "power2.inOut",
      }, 6.8);
      if (gaugeFill) loop.to(gaugeFill, {
        strokeDashoffset: 75,
        stroke: BAD_COLOR,
        duration: 0.9,
      }, 6.8);
      cockpitBars.forEach((bar, i) => {
        loop.to(bar, {
          scaleY: BAR_BAD_SCALES[i] ?? 0.5,
          backgroundColor: BAD_COLOR,
          duration: 0.9,
        }, 6.8);
      });

      // 7. Pause (7.8 → 10.5)
      loop.to({}, { duration: 2.7 }, 7.8);
    }, visual);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initHeroVisual();
  document.addEventListener("astro:after-swap", initHeroVisual);
</script>
