---
const GA_MEASUREMENT_ID = "G-SLVB4EXG5C";
const META_PIXEL_ID = "1267793908896085";
---

<!-- Cookiebot — must be first script in <head> -->
<script
  id="Cookiebot"
  src="https://consent.cookiebot.com/uc.js"
  data-cbid="1d803fba-7ce8-44b4-a0a1-cd93eb5261fa"
  data-blockingmode="manual"
  type="text/javascript"
></script>

<!-- Google Analytics 4 — loaded only after statistics consent -->
<script
  type="text/plain"
  data-cookieconsent="statistics"
  src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
  async
></script>
<script type="text/plain" data-cookieconsent="statistics" define:vars={{ GA_MEASUREMENT_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("js", new Date());
  gtag("config", GA_MEASUREMENT_ID);
</script>

<!-- Meta Pixel — loaded only after marketing consent -->
<script type="text/plain" data-cookieconsent="marketing" define:vars={{ META_PIXEL_ID }}>
  !(function (f, b, e, v, n, t, s) {
    if (f.fbq) return;
    n = f.fbq = function () {
      n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
    };
    if (!f._fbq) f._fbq = n;
    n.push = n;
    n.loaded = !0;
    n.version = "2.0";
    n.queue = [];
    t = b.createElement(e);
    t.async = !0;
    t.src = v;
    s = b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t, s);
  })(
    window,
    document,
    "script",
    "https://connect.facebook.net/en_US/fbevents.js"
  );
  fbq("init", META_PIXEL_ID);
  fbq("track", "PageView");
</script>

<!-- Calendly-Click → Meta Pixel Lead-Event (self-gated: fbq exists only after marketing consent) -->
<script>
  document.addEventListener(
    "click",
    (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const link = target.closest('a[href*="calendly.com"]');
      if (link && window.fbq) {
        window.fbq("track", "Lead");
      }
    },
    { passive: true }
  );
</script>
