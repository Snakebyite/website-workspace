---
// StrategieVisual.astro — Produktdaten + API Hub
// Flow: Shop-Systeme (links) → Produktdaten + API (Mitte) → Marktplätze (rechts)
// Stil: Dark Mode CI, zentrierte Texte, animierte Data-Dots
---

<div class="strategie-visual w-full" aria-hidden="true">
  <svg
    class="w-full h-auto"
    viewBox="0 0 900 420"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <filter id="sv-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="4" />
      </filter>
      <filter id="dot-glow" x="-100%" y="-100%" width="300%" height="300%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="3" />
      </filter>
    </defs>

    <!-- ═══ LEFT: SHOP-SYSTEME ═══ -->
    <g class="sv-shop" style="opacity:0;">
      <rect x="0" y="60" width="160" height="44" rx="12" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.18)" stroke-width="1" />
      <text x="80" y="87" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-family="var(--font-body)" font-size="14" font-weight="500">Shopify</text>
    </g>
    <g class="sv-shop" style="opacity:0;">
      <rect x="0" y="168" width="160" height="44" rx="12" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.18)" stroke-width="1" />
      <text x="80" y="195" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-family="var(--font-body)" font-size="14" font-weight="500">Shopware</text>
    </g>
    <g class="sv-shop" style="opacity:0;">
      <rect x="0" y="276" width="160" height="44" rx="12" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.18)" stroke-width="1" />
      <text x="80" y="303" text-anchor="middle" fill="rgba(255,255,255,0.6)" font-family="var(--font-body)" font-size="14" font-weight="500">WooCommerce</text>
    </g>

    <!-- ═══ CONNECTIONS LEFT → HUB ═══ -->
    <line class="sv-line-l" x1="160" y1="82" x2="320" y2="175" stroke="rgba(76,175,130,0.2)" stroke-width="1.5" style="opacity:0;" />
    <line class="sv-line-l" x1="160" y1="190" x2="320" y2="195" stroke="rgba(76,175,130,0.2)" stroke-width="1.5" style="opacity:0;" />
    <line class="sv-line-l" x1="160" y1="298" x2="320" y2="215" stroke="rgba(76,175,130,0.2)" stroke-width="1.5" style="opacity:0;" />

    <!-- Animated dots left → hub -->
    <circle class="sv-dot-l" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-l" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-l" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />

    <!-- ═══ CENTER HUB ═══ -->
    <g class="sv-hub" style="opacity:0;">
      <!-- Outer glow -->
      <rect x="310" y="130" width="260" height="140" rx="20" fill="rgba(76,175,130,0.03)" filter="url(#sv-glow)" />
      <!-- Card -->
      <rect x="320" y="140" width="240" height="120" rx="18" fill="rgba(76,175,130,0.06)" stroke="rgba(76,175,130,0.2)" stroke-width="1.2" />
      <!-- Inner card -->
      <rect x="336" y="155" width="208" height="90" rx="14" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.06)" stroke-width="0.8" />

      <!-- Icon — centered at x=440 -->
      <g transform="translate(426, 165)">
        <rect x="0" y="0" width="28" height="22" rx="5" fill="none" stroke="rgba(76,175,130,0.5)" stroke-width="1.3" />
        <line x1="5" y1="8" x2="23" y2="8" stroke="rgba(76,175,130,0.3)" stroke-width="0.8" />
        <line x1="5" y1="13" x2="18" y2="13" stroke="rgba(76,175,130,0.3)" stroke-width="0.8" />
        <line x1="5" y1="18" x2="14" y2="18" stroke="rgba(76,175,130,0.2)" stroke-width="0.8" />
      </g>

      <!-- Labels -->
      <text x="440" y="208" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="var(--font-body)" font-size="14" font-weight="600">Produktdaten + API</text>
      <text x="440" y="226" text-anchor="middle" fill="rgba(76,175,130,0.7)" font-family="var(--font-body)" font-size="12" font-weight="500">AI Data Enrichment</text>

    </g>

    <!-- ═══ CONNECTIONS HUB → RIGHT ═══ -->
    <line class="sv-line-r" x1="560" y1="165" x2="650" y2="52" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />
    <line class="sv-line-r" x1="560" y1="175" x2="650" y2="100" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />
    <line class="sv-line-r" x1="560" y1="185" x2="650" y2="148" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />
    <line class="sv-line-r" x1="560" y1="195" x2="650" y2="196" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />
    <line class="sv-line-r" x1="560" y1="205" x2="650" y2="244" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />
    <line class="sv-line-r" x1="560" y1="215" x2="650" y2="292" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />
    <line class="sv-line-r" x1="560" y1="225" x2="650" y2="340" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />
    <line class="sv-line-r" x1="560" y1="235" x2="650" y2="388" stroke="rgba(76,175,130,0.18)" stroke-width="1.3" style="opacity:0;" />

    <!-- Animated dots hub → right -->
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />
    <circle class="sv-dot-r" r="3" fill="rgba(76,175,130,0.8)" filter="url(#dot-glow)" style="opacity:0;" />

    <!-- ═══ RIGHT: MARKTPLÄTZE ═══ -->
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="32" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="56" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Decathlon</text>
    </g>
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="80" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="104" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Amazon</text>
    </g>
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="128" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="152" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Hornbach</text>
    </g>
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="176" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="200" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Zalando</text>
    </g>
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="224" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="248" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Otto</text>
    </g>
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="272" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="296" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">eBay</text>
    </g>
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="320" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="344" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">TikTok Shop</text>
    </g>
    <g class="sv-mp" style="opacity:0;">
      <rect x="652" y="368" width="140" height="38" rx="10" fill="rgba(76,175,130,0.05)" stroke="rgba(76,175,130,0.16)" stroke-width="1" />
      <text x="722" y="392" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="12" font-weight="500">Kaufland</text>
    </g>
  </svg>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  interface DotLine {
    x1: number;
    y1: number;
    x2: number;
    y2: number;
  }

  function initStrategieVisual(): void {
    const visual = document.querySelector<HTMLElement>(".strategie-visual");
    if (!visual) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      visual.querySelectorAll("[style*='opacity:0']").forEach(el => {
        (el as HTMLElement).style.opacity = "1";
      });
      return;
    }

    const ctx = gsap.context(() => {
      const shops = visual.querySelectorAll(".sv-shop");
      const linesL = visual.querySelectorAll(".sv-line-l");
      const hub = visual.querySelector(".sv-hub");
      const linesR = visual.querySelectorAll(".sv-line-r");
      const mps = visual.querySelectorAll(".sv-mp");
      const dotsL = visual.querySelectorAll(".sv-dot-l");
      const dotsR = visual.querySelectorAll(".sv-dot-r");

      const tl = gsap.timeline({
        defaults: { ease: "power2.out" },
        scrollTrigger: {
          trigger: visual,
          start: "top 80%",
          once: true,
        },
      });

      // 1) Shop pills stagger in from left
      tl.to(shops, { opacity: 1, duration: 0.4, stagger: 0.1 });

      // 2) Left connections
      tl.to(linesL, { opacity: 1, duration: 0.3, stagger: 0.05 }, "-=0.15");

      // 3) Hub appears
      tl.fromTo(hub, { opacity: 0, scale: 0.95 }, { opacity: 1, scale: 1, duration: 0.6, ease: "back.out(1.2)" }, "-=0.1");

      // 4) Right connections fan out
      tl.to(linesR, { opacity: 1, duration: 0.25, stagger: 0.04 }, "-=0.2");

      // 5) Marketplace pills stagger in
      tl.to(mps, { opacity: 1, duration: 0.3, stagger: 0.06 }, "-=0.15");

      // Subtle float on hub
      gsap.to(hub, { y: 3, duration: 3.5, yoyo: true, repeat: -1, ease: "sine.inOut", delay: 2 });

      // ═══ ANIMATED DATA DOTS ═══

      // Left lines: shop → hub
      const leftLines: DotLine[] = [
        { x1: 160, y1: 82, x2: 320, y2: 175 },
        { x1: 160, y1: 190, x2: 320, y2: 195 },
        { x1: 160, y1: 298, x2: 320, y2: 215 },
      ];

      // Right lines: hub → marketplace
      const rightLines: DotLine[] = [
        { x1: 560, y1: 165, x2: 650, y2: 52 },
        { x1: 560, y1: 175, x2: 650, y2: 100 },
        { x1: 560, y1: 185, x2: 650, y2: 148 },
        { x1: 560, y1: 195, x2: 650, y2: 196 },
        { x1: 560, y1: 205, x2: 650, y2: 244 },
        { x1: 560, y1: 215, x2: 650, y2: 292 },
        { x1: 560, y1: 225, x2: 650, y2: 340 },
        { x1: 560, y1: 235, x2: 650, y2: 388 },
      ];

      function animateDot(dot: Element, line: DotLine, delay: number, duration: number): void {
        gsap.set(dot, { attr: { cx: line.x1, cy: line.y1 }, opacity: 0 });
        gsap.timeline({ repeat: -1, delay })
          .to(dot, { opacity: 0.9, duration: 0.2 })
          .to(dot, {
            attr: { cx: line.x2, cy: line.y2 },
            duration,
            ease: "power1.inOut",
          }, "<")
          .to(dot, { opacity: 0, duration: 0.2 }, `-=${0.2}`);
      }

      // Start dot animations after entrance completes
      tl.call(() => {
        dotsL.forEach((dot, i) => {
          animateDot(dot, leftLines[i], i * 0.8, 1.8);
        });

        dotsR.forEach((dot, i) => {
          animateDot(dot, rightLines[i], i * 0.4, 1.5);
        });
      });

    }, visual);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initStrategieVisual();
  document.addEventListener("astro:after-swap", initStrategieVisual);
</script>
