---
// OrganicVisual.astro — "Ranklift Organic" dashboard visual
// Flow: Shop → solid connection → Dashboard card → solid connection → Marktplätze
// Connections: thick solid lines with draw-in animation, no dots
---

<div class="organic-visual w-full" aria-hidden="true">
  <svg
    class="w-full h-auto"
    viewBox="0 0 820 340"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <filter id="line-glow" x="-20%" y="-200%" width="140%" height="500%">
        <feGaussianBlur in="SourceGraphic" stdDeviation="3" />
      </filter>
      <linearGradient id="conn-grad-l" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(76,175,130,0.15)" />
        <stop offset="100%" stop-color="rgba(76,175,130,0.4)" />
      </linearGradient>
      <linearGradient id="conn-grad-r" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="rgba(76,175,130,0.4)" />
        <stop offset="100%" stop-color="rgba(76,175,130,0.15)" />
      </linearGradient>
    </defs>

    <!-- ═══ LEFT: DEIN SHOP ═══ -->
    <g class="ov-shop" style="opacity:0;">
      <!-- Outer glow -->
      <rect x="0" y="95" width="100" height="100" rx="22" fill="rgba(76,175,130,0.04)" />
      <!-- Container -->
      <rect x="6" y="101" width="88" height="88" rx="20" fill="rgba(76,175,130,0.07)" stroke="rgba(76,175,130,0.25)" stroke-width="1.5" />
      <!-- Shop icon — zentriert in inner rect (center: 50, 145) -->
      <g transform="translate(31, 127)" stroke="rgba(255,255,255,0.7)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 14l5-12h24l5 12" />
        <path d="M2 14h34v20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V14z" />
        <path d="M14 34V22h10v12" />
      </g>
      <!-- Label -->
      <text x="50" y="222" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="14" font-weight="600" letter-spacing="0.06em">
        DEIN SHOP
      </text>
    </g>

    <!-- ═══ CONNECTION LEFT — von Kante Shop-Rect (x=94) ins Dashboard (x=160) ═══ -->
    <!-- Glow behind -->
    <line x1="94" y1="145" x2="160" y2="145" stroke="rgba(76,175,130,0.1)" stroke-width="14" filter="url(#line-glow)" class="ov-conn-l" style="opacity:0;" />
    <!-- Main solid line -->
    <line class="ov-conn-l-main" x1="94" y1="145" x2="160" y2="145" stroke="url(#conn-grad-l)" stroke-width="3.5" stroke-linecap="round" style="opacity:0;" />
    <!-- Animated pulse line (overlays the main line) -->
    <line class="ov-pulse-l" x1="94" y1="145" x2="160" y2="145" stroke="rgba(76,175,130,0.6)" stroke-width="3.5" stroke-linecap="round" style="opacity:0;" />

    <!-- ═══ CENTER: DASHBOARD CARD ═══ -->
    <g class="ov-card" style="opacity:0;">
      <!-- Card bg -->
      <rect x="160" y="20" width="480" height="270" rx="16" fill="rgba(255,255,255,0.025)" stroke="rgba(255,255,255,0.07)" stroke-width="1" />

      <!-- Header -->
      <rect x="160" y="20" width="480" height="48" rx="16" fill="rgba(255,255,255,0.025)" />
      <rect x="160" y="52" width="480" height="16" fill="rgba(255,255,255,0.025)" />

      <!-- R badge -->
      <rect x="178" y="32" width="28" height="28" rx="8" fill="rgba(76,175,130,0.15)" />
      <text x="192" y="51" text-anchor="middle" fill="rgba(76,175,130,0.8)" font-family="var(--font-body)" font-size="13" font-weight="700">R</text>

      <!-- Title -->
      <text x="218" y="51" fill="rgba(255,255,255,0.7)" font-family="var(--font-body)" font-size="15" font-weight="600">Ranklift Organic</text>

      <!-- KI badge -->
      <rect x="510" y="34" width="110" height="24" rx="12" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.08)" stroke-width="0.8" />
      <circle cx="528" cy="46" r="3" fill="rgba(76,175,130,0.5)" />
      <text x="572" y="50" text-anchor="middle" fill="rgba(255,255,255,0.45)" font-family="var(--font-body)" font-size="12" font-weight="600">KI-gestützt</text>

      <!-- Divider below header -->
      <line x1="160" y1="68" x2="640" y2="68" stroke="rgba(255,255,255,0.04)" stroke-width="1" />

      <!-- ── DATENANALYSE ── -->
      <text x="185" y="95" fill="rgba(255,255,255,0.3)" font-family="var(--font-body)" font-size="11" font-weight="600" letter-spacing="0.08em">DATENANALYSE</text>

      <!-- Metric: CTR -->
      <text class="ov-metric" x="185" y="132" fill="rgba(255,255,255,0.8)" font-family="var(--font-body)" font-size="28" font-weight="700" style="opacity:0;">4.2</text>
      <text x="185" y="150" fill="rgba(255,255,255,0.3)" font-family="var(--font-body)" font-size="11" font-weight="500">% CTR</text>

      <!-- Metric: Conv Rate -->
      <text class="ov-metric" x="265" y="132" fill="rgba(255,255,255,0.8)" font-family="var(--font-body)" font-size="28" font-weight="700" style="opacity:0;">12.8</text>
      <text x="265" y="150" fill="rgba(255,255,255,0.3)" font-family="var(--font-body)" font-size="11" font-weight="500">% CONV. RATE</text>

      <!-- Metric: Suchvolumen -->
      <text class="ov-metric" x="345" y="132" fill="rgba(255,255,255,0.8)" font-family="var(--font-body)" font-size="28" font-weight="700" style="opacity:0;">8.400</text>
      <text x="345" y="150" fill="rgba(255,255,255,0.3)" font-family="var(--font-body)" font-size="11" font-weight="500">SUCHVOLUMEN</text>

      <!-- Bar chart — baseline at y=265 -->
      <rect class="ov-bar" x="185" y="225" width="16" height="40" rx="3" fill="rgba(76,175,130,0.2)" data-h="40" data-y="225" />
      <rect class="ov-bar" x="206" y="215" width="16" height="50" rx="3" fill="rgba(76,175,130,0.25)" data-h="50" data-y="215" />
      <rect class="ov-bar" x="227" y="208" width="16" height="57" rx="3" fill="rgba(76,175,130,0.3)" data-h="57" data-y="208" />
      <rect class="ov-bar" x="248" y="200" width="16" height="65" rx="3" fill="rgba(76,175,130,0.35)" data-h="65" data-y="200" />
      <rect class="ov-bar" x="269" y="205" width="16" height="60" rx="3" fill="rgba(76,175,130,0.3)" data-h="60" data-y="205" />
      <rect class="ov-bar" x="290" y="195" width="16" height="70" rx="3" fill="rgba(76,175,130,0.4)" data-h="70" data-y="195" />
      <rect class="ov-bar" x="311" y="183" width="16" height="82" rx="3" fill="rgba(76,175,130,0.45)" data-h="82" data-y="183" />
      <rect class="ov-bar" x="332" y="173" width="16" height="92" rx="3" fill="rgba(76,175,130,0.55)" data-h="92" data-y="173" />

      <!-- Vertical divider -->
      <line x1="410" y1="82" x2="410" y2="270" stroke="rgba(255,255,255,0.04)" stroke-width="1" />

      <!-- ── OPTIMIERUNG ── -->
      <text x="430" y="95" fill="rgba(255,255,255,0.3)" font-family="var(--font-body)" font-size="11" font-weight="600" letter-spacing="0.08em">OPTIMIERUNG</text>

      <!-- Checklist -->
      <g class="ov-check" style="opacity:0;">
        <circle cx="440" cy="125" r="6" fill="rgba(76,175,130,0.5)" />
        <text x="457" y="130" fill="rgba(255,255,255,0.6)" font-family="var(--font-body)" font-size="14" font-weight="400">Keywords analysiert</text>
      </g>
      <g class="ov-check" style="opacity:0;">
        <circle cx="440" cy="158" r="6" fill="rgba(76,175,130,0.5)" />
        <text x="457" y="163" fill="rgba(255,255,255,0.6)" font-family="var(--font-body)" font-size="14" font-weight="400">Titel optimiert</text>
      </g>
      <g class="ov-check" style="opacity:0;">
        <circle cx="440" cy="191" r="6" fill="rgba(76,175,130,0.5)" />
        <text x="457" y="196" fill="rgba(255,255,255,0.6)" font-family="var(--font-body)" font-size="14" font-weight="400">Content generiert</text>
      </g>
      <g class="ov-check" style="opacity:0;">
        <circle cx="440" cy="224" r="6" fill="none" stroke="rgba(76,175,130,0.3)" stroke-width="1.2" />
        <text x="457" y="229" fill="rgba(255,255,255,0.35)" font-family="var(--font-body)" font-size="14" font-weight="400">A+ Content erstellt</text>
      </g>
    </g>

    <!-- ═══ CONNECTION RIGHT — vom Dashboard (x=640) zur Kante Marktplätze-Rect (x=716) ═══ -->
    <line x1="640" y1="145" x2="716" y2="145" stroke="rgba(76,175,130,0.1)" stroke-width="14" filter="url(#line-glow)" class="ov-conn-r" style="opacity:0;" />
    <line class="ov-conn-r-main" x1="640" y1="145" x2="716" y2="145" stroke="url(#conn-grad-r)" stroke-width="3.5" stroke-linecap="round" style="opacity:0;" />
    <line class="ov-pulse-r" x1="640" y1="145" x2="716" y2="145" stroke="rgba(76,175,130,0.6)" stroke-width="3.5" stroke-linecap="round" style="opacity:0;" />

    <!-- ═══ RIGHT: MARKTPLÄTZE ═══ -->
    <g class="ov-market" style="opacity:0;">
      <rect x="710" y="95" width="100" height="100" rx="22" fill="rgba(76,175,130,0.04)" />
      <rect x="716" y="101" width="88" height="88" rx="20" fill="rgba(76,175,130,0.07)" stroke="rgba(76,175,130,0.25)" stroke-width="1.5" />
      <!-- Monitor icon — zentriert in inner rect (center: 760, 145) -->
      <g transform="translate(740, 127)" stroke="rgba(255,255,255,0.7)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <rect x="0" y="0" width="40" height="30" rx="4" />
        <line x1="14" y1="35" x2="26" y2="35" />
        <line x1="20" y1="30" x2="20" y2="35" />
      </g>
      <text x="760" y="222" text-anchor="middle" fill="rgba(255,255,255,0.55)" font-family="var(--font-body)" font-size="14" font-weight="600" letter-spacing="0.06em">
        MARKTPLÄTZE
      </text>
    </g>
  </svg>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initOrganicVisual(): void {
    const visual = document.querySelector<HTMLElement>(".organic-visual");
    if (!visual) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      visual.querySelectorAll("[style*='opacity:0']").forEach(el => {
        (el as HTMLElement).style.opacity = "1";
      });
      return;
    }

    const ctx = gsap.context(() => {
      const shop = visual.querySelector(".ov-shop");
      const connL = visual.querySelectorAll(".ov-conn-l, .ov-conn-l-main");
      const pulseL = visual.querySelector(".ov-pulse-l") as SVGLineElement | null;
      const card = visual.querySelector(".ov-card");
      const metrics = visual.querySelectorAll(".ov-metric");
      const bars = visual.querySelectorAll<SVGRectElement>(".ov-bar");
      const checks = visual.querySelectorAll(".ov-check");
      const connR = visual.querySelectorAll(".ov-conn-r, .ov-conn-r-main");
      const pulseR = visual.querySelector(".ov-pulse-r") as SVGLineElement | null;
      const market = visual.querySelector(".ov-market");

      // Prepare bars — start at zero height
      bars.forEach((bar) => {
        const h = parseFloat(bar.dataset.h || "0");
        const y = parseFloat(bar.dataset.y || "0");
        gsap.set(bar, { attr: { height: 0, y: y + h } });
      });

      // Prepare connection lines for draw-in effect
      [pulseL, pulseR].forEach((line) => {
        if (!line) return;
        const length = 76; // line length (160-94=66 or 716-640=76)
        gsap.set(line, {
          strokeDasharray: length,
          strokeDashoffset: length,
          opacity: 1,
        });
      });

      const tl = gsap.timeline({
        defaults: { ease: "power2.out" },
        scrollTrigger: {
          trigger: visual,
          start: "top 80%",
          once: true,
        },
      });

      // 1) Shop icon pops in
      tl.to(shop, { opacity: 1, duration: 0.4, ease: "back.out(1.4)" });

      // 2) Left connection — solid lines fade in + pulse draws through
      tl.to(connL, { opacity: 1, duration: 0.3 }, "-=0.1");
      if (pulseL) {
        tl.to(pulseL, { strokeDashoffset: 0, duration: 0.5, ease: "power2.inOut" }, "-=0.2");
      }

      // 3) Card fades in with slight scale
      tl.fromTo(card, { opacity: 0, scale: 0.97 }, { opacity: 1, scale: 1, duration: 0.6 }, "-=0.1");

      // 4) Metrics pop in
      tl.to(metrics, { opacity: 1, duration: 0.4, stagger: 0.12 }, "-=0.2");

      // 5) Bars grow up
      bars.forEach((bar, i) => {
        const h = parseFloat(bar.dataset.h || "0");
        const y = parseFloat(bar.dataset.y || "0");
        tl.to(bar, {
          attr: { height: h, y: y },
          duration: 0.4,
          ease: "power2.out",
        }, 0.9 + i * 0.05);
      });

      // 6) Checklist items appear
      tl.to(checks, { opacity: 1, duration: 0.3, stagger: 0.15, ease: "power2.out" }, 1.0);

      // 7) Right connection — solid lines + pulse draws through
      tl.to(connR, { opacity: 1, duration: 0.3 }, "-=0.3");
      if (pulseR) {
        tl.to(pulseR, { strokeDashoffset: 0, duration: 0.5, ease: "power2.inOut" }, "-=0.2");
      }

      // 8) Marketplace icon pops in
      tl.to(market, { opacity: 1, duration: 0.4, ease: "back.out(1.4)" }, "-=0.1");

      // Subtle float animation on shop + market icons
      gsap.to(shop, { y: 3, duration: 3, yoyo: true, repeat: -1, ease: "sine.inOut", delay: 1 });
      gsap.to(market, { y: -3, duration: 3.5, yoyo: true, repeat: -1, ease: "sine.inOut", delay: 1.5 });

      // Continuous data-flow pulse on connections (repeating draw-through)
      [pulseL, pulseR].forEach((line) => {
        if (!line) return;
        gsap.to(line, {
          opacity: 0.3,
          duration: 2,
          yoyo: true,
          repeat: -1,
          ease: "sine.inOut",
          delay: 2.5,
        });
      });

    }, visual);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initOrganicVisual();
  document.addEventListener("astro:after-swap", initOrganicVisual);
</script>
