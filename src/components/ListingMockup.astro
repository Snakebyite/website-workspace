---
// ListingMockup — stylisiertes Amazon-Listing als SVG/HTML-Komponente.
// Zeigt Amazon-typische Struktur (Breadcrumb-Strip, Bild, Titel, Sterne, Preis, Buybox)
// ohne echte Marke oder Produktdaten. Rechtlich clean, responsive, wiederverwendbar.
interface Props {
  variant: "before" | "after";
  class?: string;
}

const { variant, class: className = "" } = Astro.props;

const config =
  variant === "before"
    ? {
        title: "Bart Balsam Wachs",
        rating: 3.2,
        reviews: "24",
        price: "14,90",
      }
    : {
        title:
          "Premium Bartbalsam | Handgefertigt | Natürliche Pflege für volles Wachstum | 55g",
        rating: 4.7,
        reviews: "842",
        price: "22,90",
      };

const fullStars = Math.floor(config.rating);
const hasHalfStar = config.rating - fullStars >= 0.5;
---

<article
  class:list={[
    "listing-mockup relative overflow-hidden rounded-xl bg-white shadow-[0_14px_40px_rgba(0,0,0,0.4)]",
    className,
  ]}
  data-listing-variant={variant}
>
  <!-- Breadcrumb strip -->
  <div
    class="flex items-center gap-2 border-b border-gray-100 bg-gray-50 px-4 py-2"
  >
    <span class="h-[6px] w-16 rounded-sm bg-gray-200"></span>
    <span class="text-[10px] leading-none text-gray-300">›</span>
    <span class="h-[6px] w-20 rounded-sm bg-gray-200"></span>
    <span class="text-[10px] leading-none text-gray-300">›</span>
    <span class="h-[6px] w-14 rounded-sm bg-gray-200"></span>
  </div>

  <div class="flex gap-3 p-4">
    <!-- Product image placeholder -->
    <div
      class="flex h-20 w-20 shrink-0 items-center justify-center rounded-md bg-gray-100 md:h-[88px] md:w-[88px]"
    >
      <svg
        class="h-9 w-9 text-gray-300"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.25"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
        <circle cx="8.5" cy="8.5" r="1.5"></circle>
        <path d="m21 15-4.5-4.5L7 21"></path>
      </svg>
    </div>

    <!-- Info column -->
    <div class="flex min-w-0 flex-1 flex-col gap-1.5">
      <p
        class="line-clamp-2 text-[12.5px] font-medium leading-snug text-gray-900"
      >
        {config.title}
      </p>

      <!-- Rating row -->
      <div class="flex items-center gap-1.5">
        <div class="flex items-center gap-[1px]">
          {
            Array.from({ length: 5 }).map((_, i) => {
              const filled = i < fullStars;
              const half = i === fullStars && hasHalfStar;
              return (
                <svg
                  class="h-3 w-3"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <defs>
                    <linearGradient id={`half-${variant}-${i}`}>
                      <stop offset="50%" stop-color="#FFA41C" />
                      <stop offset="50%" stop-color="#E7E7E7" />
                    </linearGradient>
                  </defs>
                  <path
                    d="M10 1l2.753 5.585 6.164.897-4.459 4.342 1.053 6.136L10 15.072l-5.511 2.888 1.053-6.136L1.083 7.482l6.164-.897L10 1z"
                    fill={
                      filled
                        ? "#FFA41C"
                        : half
                          ? `url(#half-${variant}-${i})`
                          : "#E7E7E7"
                    }
                  />
                </svg>
              );
            })
          }
        </div>
        <span class="text-[10.5px] text-[#007185]">({config.reviews})</span>
      </div>

      <!-- Price -->
      <div class="flex items-baseline gap-0.5 mt-auto">
        <span class="text-[11px] font-medium text-gray-900">€</span>
        <span class="text-[18px] font-medium leading-none text-gray-900"
          >{config.price}</span
        >
      </div>
    </div>

    <!-- Buybox column -->
    <div class="flex shrink-0 flex-col justify-center gap-1.5">
      <span
        class="rounded-full bg-[#FFD814] px-3 py-[5px] text-center text-[10px] font-medium text-gray-900 whitespace-nowrap"
      >
        In den Einkaufswagen
      </span>
      <span
        class="rounded-full bg-[#FFA41C] px-3 py-[5px] text-center text-[10px] font-medium text-gray-900 whitespace-nowrap"
      >
        Jetzt kaufen
      </span>
    </div>
  </div>
</article>
