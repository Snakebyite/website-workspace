---
// ListingMockup — stylisiertes Amazon-Listing als HTML-Mockup.
// Zeigt Detail-Page-Struktur: Breadcrumb, Bild-Galerie, Titel, Rating, Preis, Buybox, Bullets.
// Before-Variante: minimal (nur Hauptbild, keine Thumbnails, keine Bullets).
// After-Variante: voll ausgestattet (Thumbnails, Prime, Choice-Badge, Feature-Bullets).
interface Props {
  variant: "before" | "after";
  class?: string;
}

const { variant, class: className = "" } = Astro.props;

const config =
  variant === "before"
    ? {
        title: "Edelstahl Flasche 750ml",
        rating: 3.1,
        reviews: "18",
        price: "12,90",
        prime: false,
        choice: false,
        thumbnails: 0,
        bullets: [] as string[],
      }
    : {
        title:
          "Premium Edelstahl Trinkflasche 750ml | 24h Kalt, 12h Warm | BPA-frei | Auslaufsicher | Sport & Büro",
        rating: 4.8,
        reviews: "2.341",
        price: "19,90",
        prime: true,
        choice: true,
        thumbnails: 4,
        bullets: [
          "Doppelwandige Vakuum-Isolierung: 24h eiskalt, 12h heiß",
          "Hochwertiger 18/8 Edelstahl, geschmacksneutral, BPA-frei",
          "Auslaufsicher mit Schraubverschluss und Silikon-Dichtung",
          "Passt in Auto-Halter, Rucksäcke und Sporttaschen",
        ] as string[],
      };

const fullStars = Math.floor(config.rating);
const hasHalfStar = config.rating - fullStars >= 0.5;
---

<article
  class:list={[
    "listing-mockup relative overflow-hidden rounded-xl bg-white shadow-[0_14px_40px_rgba(0,0,0,0.4)]",
    className,
  ]}
  data-listing-variant={variant}
>
  <!-- Breadcrumb strip -->
  <div class="flex items-center gap-1.5 border-b border-gray-100 bg-gray-50 px-3.5 py-2">
    <span class="h-[5px] w-10 rounded-sm bg-gray-200"></span>
    <span class="text-[9px] leading-none text-gray-300">›</span>
    <span class="h-[5px] w-14 rounded-sm bg-gray-200"></span>
    <span class="text-[9px] leading-none text-gray-300">›</span>
    <span class="h-[5px] w-10 rounded-sm bg-gray-200"></span>
  </div>

  <!-- Main content: image + info -->
  <div class="grid grid-cols-[40%_1fr] gap-3.5 p-3.5">
    <!-- Left: Image gallery column -->
    <div class="flex flex-col gap-2">
      <!-- Main image -->
      <div class="flex aspect-square w-full items-center justify-center rounded-md bg-gradient-to-br from-gray-50 to-gray-100 border border-gray-100">
        <svg
          class="h-10 w-10 text-gray-300"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <path d="m21 15-4.5-4.5L7 21"></path>
        </svg>
      </div>

      <!-- Thumbnails (only when > 0) -->
      {config.thumbnails > 0 && (
        <div class="grid grid-cols-4 gap-1">
          {Array.from({ length: config.thumbnails }).map(() => (
            <div class="aspect-square rounded-sm bg-gradient-to-br from-gray-50 to-gray-100 border border-gray-100"></div>
          ))}
        </div>
      )}
    </div>

    <!-- Right: Info column -->
    <div class="flex min-w-0 flex-col gap-1.5">
      <!-- Title -->
      <p class="line-clamp-3 text-[12.5px] font-medium leading-snug text-gray-900">
        {config.title}
      </p>

      <!-- Rating row -->
      <div class="flex items-center gap-1.5 flex-wrap">
        <div class="flex items-center gap-[1px]">
          {
            Array.from({ length: 5 }).map((_, i) => {
              const filled = i < fullStars;
              const half = i === fullStars && hasHalfStar;
              return (
                <svg
                  class="h-[11px] w-[11px]"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <defs>
                    <linearGradient id={`half-${variant}-${i}`}>
                      <stop offset="50%" stop-color="#FFA41C" />
                      <stop offset="50%" stop-color="#E7E7E7" />
                    </linearGradient>
                  </defs>
                  <path
                    d="M10 1l2.753 5.585 6.164.897-4.459 4.342 1.053 6.136L10 15.072l-5.511 2.888 1.053-6.136L1.083 7.482l6.164-.897L10 1z"
                    fill={
                      filled
                        ? "#FFA41C"
                        : half
                          ? `url(#half-${variant}-${i})`
                          : "#E7E7E7"
                    }
                  />
                </svg>
              );
            })
          }
        </div>
        <span class="text-[10px] text-[#007185]">({config.reviews})</span>
        {config.prime && (
          <span class="inline-flex items-center text-[9.5px] font-bold text-[#00A8E1] tracking-tight">
            <svg class="h-2.5 w-2.5 mr-[2px]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M10 0C4.5 0 0 4.5 0 10s4.5 10 10 10 10-4.5 10-10S15.5 0 10 0zm4.2 8.5l-5 5c-.2.2-.5.3-.7.3s-.5-.1-.7-.3l-2.5-2.5c-.4-.4-.4-1 0-1.4s1-.4 1.4 0L8.5 11.4l4.3-4.3c.4-.4 1-.4 1.4 0s.4 1 0 1.4z"/>
            </svg>
            prime
          </span>
        )}
      </div>

      <!-- Amazon's Choice badge -->
      {config.choice && (
        <span class="inline-flex w-fit items-center rounded-sm bg-[#232f3e] pl-1.5 pr-2 py-0.5 text-[8.5px] font-bold uppercase tracking-wide text-white">
          <span class="text-[#ff9900] mr-[3px]">Amazon's</span>Choice
        </span>
      )}

      <!-- Price -->
      <div class="flex items-baseline gap-0.5 mt-0.5">
        <span class="text-[10px] font-medium text-gray-900">€</span>
        <span class="text-[17px] font-medium leading-none text-gray-900">{config.price}</span>
      </div>

      <!-- Buybox (compact) -->
      <div class="flex flex-col gap-1 mt-1">
        <span class="rounded-full bg-[#FFD814] px-2 py-[3px] text-center text-[9px] font-medium text-gray-900 whitespace-nowrap">
          In den Einkaufswagen
        </span>
        <span class="rounded-full bg-[#FFA41C] px-2 py-[3px] text-center text-[9px] font-medium text-gray-900 whitespace-nowrap">
          Jetzt kaufen
        </span>
      </div>
    </div>
  </div>

  <!-- Bullets ("Über diesen Artikel") — only when present -->
  {config.bullets.length > 0 && (
    <div class="border-t border-gray-100 bg-gray-50/60 px-3.5 py-3">
      <p class="text-[10px] font-bold text-gray-900 mb-1.5">Über diesen Artikel</p>
      <ul class="space-y-1">
        {config.bullets.map((bullet) => (
          <li class="flex items-start gap-1.5 text-[10px] text-gray-700 leading-snug">
            <span class="text-gray-400 mt-[4px] flex-shrink-0 text-[8px]">●</span>
            <span class="line-clamp-2">{bullet}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</article>
