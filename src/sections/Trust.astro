---
// Trust Section — Homepage
// Job: Luca & Kevin zeigen. Persönlichkeit, Expertise, Haltung. "People game."
// Komposition: Asymmetrischer Split — Foto links (5/12), Content rechts (7/12).
// Content-Stack rechts: H2, Origin-Story, CTA, Stats + Badge.
// Background: #0A0A0A (default)
import { Image } from 'astro:assets';
import duoPhoto from '../assets/kevin-luca-bar.png';
import StaatlichBadge from '../components/StaatlichBadge.astro';
---

<section class="py-20 md:py-32" data-trust>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start lg:items-stretch">

      <!-- Left: Foto — auf Desktop ausgerichtet zwischen Body-Text-Top und Stats-Bottom -->
      <div class="lg:col-span-5 lg:flex lg:flex-col lg:min-h-0">
        <!-- Spacer (Desktop): spiegelt H2-Höhe + Spacing der rechten Spalte, damit das Bild bei der Body-Text-Oberkante startet -->
        <h2 aria-hidden="true" class="hidden lg:block invisible whitespace-nowrap mb-8 md:mb-10">Warum es uns gibt.</h2>
        <h2 class="lg:hidden mb-6">Warum es uns gibt.</h2>
        <div class="rounded-2xl overflow-hidden lg:flex-1 lg:min-h-0 lg:relative" data-trust-photo>
          <Image
            src={duoPhoto}
            alt="Luca und Kevin, Gründer von KFL Consulting"
            widths={[480, 720, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 42vw"
            class="w-full h-auto object-cover object-top aspect-square lg:absolute lg:inset-0 lg:h-full lg:w-full lg:aspect-auto lg:object-center"
          />
        </div>
      </div>

      <!-- Right: Content-Stack -->
      <div class="lg:col-span-7">

        <h2 class="hidden lg:block max-w-2xl">Warum es uns gibt.</h2>

        <div class="mt-0 lg:mt-10 space-y-5">
          <p class="text-base md:text-xl text-text-secondary leading-relaxed" data-trust-p>
            Wir sind Luca und Kevin, Gründer von KFL Consulting. Kennengelernt haben wir uns im Master Innovationsmanagement. Luca kommt aus der Industrie, von Mercedes, Allianz und Porsche. Seit dem Master ist er tief in KI und Automatisierung und baut die Systeme, mit denen wir Arbeit auf Marktplätzen skalieren, die sonst manuell liegen bleibt. Kevin beschäftigt sich seit über sieben Jahren mit digitalen Marktplätzen und hat Bachelor- und Masterarbeit zum Amazon-Algorithmus geschrieben.
          </p>
          <p class="text-base md:text-xl text-text-secondary leading-relaxed" data-trust-p>
            Wir haben zu viele Brands gesehen, die auf Marktplätzen Potenzial liegen lassen. Nicht, weil die Produkte schlecht sind, sondern weil Full-Service-Agenturen nach Schema X abarbeiten, statt den eigentlichen Hebel anzusetzen. Wir arbeiten als <span class="text-accent-text">Best Interest Advisor</span>: reindenken, Engpässe identifizieren und dort ansetzen, wo der größte Hebel liegt.
          </p>
        </div>

        <a
          href="/ueber-uns"
          class="inline-block text-accent-text hover:underline text-base font-medium mt-6 transition-colors duration-200"
        >
          Mehr über uns erfahren &rarr;
        </a>

        <!-- Stats + Badge — kompakte Zeile -->
        <div class="mt-10 md:mt-12 grid grid-cols-3 gap-y-6 items-center md:flex md:flex-wrap md:gap-x-10 md:gap-y-6" data-trust-stats>
          <div class="text-center md:text-left">
            <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">80+</span>
            <span class="font-body block text-sm text-text-muted mt-1">Marken</span>
          </div>
          <div class="text-center md:text-left">
            <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">5.000+</span>
            <span class="font-body block text-sm text-text-muted mt-1">Listings</span>
          </div>
          <div class="text-center md:text-left">
            <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">140+</span>
            <span class="font-body block text-sm text-text-muted mt-1">Marktplatz-Setups</span>
          </div>
          <div class="col-span-3 flex justify-center md:block">
            <StaatlichBadge />
          </div>
        </div>

      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-trust]");
  if (section) {
    const h2s = section.querySelectorAll("h2:not([aria-hidden])");
    const photo = section.querySelector("[data-trust-photo]");
    const paragraphs = section.querySelectorAll("[data-trust-p]");
    const ctaLink = section.querySelector('a[href="/ueber-uns"]');
    const statsRow = section.querySelector("[data-trust-stats]");
    const statItems = statsRow?.children;

    // Photo reveal — clip from left
    if (photo) {
      gsap.set(photo, { clipPath: "inset(0 100% 0 0)" });
      gsap.to(photo, {
        clipPath: "inset(0 0% 0 0)",
        duration: 1,
        ease: "power2.inOut",
        scrollTrigger: {
          trigger: photo,
          start: "top 80%",
          once: true,
        },
      });
    }

    // H2 SplitText reveal — nur auf den sichtbaren H2 (Mobile vs Desktop) anwenden
    h2s.forEach((h2) => {
      if (!(h2 as HTMLElement).offsetParent) return;
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: h2,
          start: "top 80%",
          once: true,
        },
      });
    });

    // Paragraphs fade-in
    paragraphs.forEach((p, i) => {
      gsap.set(p, { opacity: 0, y: 20 });
      gsap.to(p, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        delay: 0.1 * i,
        ease: "power2.out",
        scrollTrigger: {
          trigger: p,
          start: "top 85%",
          once: true,
        },
      });
    });

    // CTA-Link fade-in
    if (ctaLink) {
      gsap.set(ctaLink, { opacity: 0, y: 15 });
      gsap.to(ctaLink, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ctaLink,
          start: "top 90%",
          once: true,
        },
      });
    }

    // Stats + Badge stagger
    if (statItems && statItems.length) {
      gsap.set(statItems, { opacity: 0, y: 20 });
      gsap.to(statItems, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: statsRow,
          start: "top 85%",
          once: true,
        },
      });
    }
  }
</script>
