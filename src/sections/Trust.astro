---
// Trust Section — Homepage
// Job: Luca & Kevin zeigen. Persönlichkeit, Expertise, Haltung. "People game."
// Komposition: Foto-dominant, Magazine-Style. Breites Foto als Hero-Element,
// kurzer Haltungssatz darunter, Stats + Badge als kompakte Zeile.
// Background: #0A0A0A (default)
import { Image } from 'astro:assets';
import duoPhoto from '../assets/luca-kevin-triptychon-v2.jpg';
import StaatlichBadge from '../components/StaatlichBadge.astro';
---

<section class="py-20 md:py-32" data-trust>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Headline -->
    <h2 class="max-w-3xl">Warum es uns gibt.</h2>

    <!-- Foto — breit, cinematisch, das Hero-Element dieser Section -->
    <div class="mt-10 md:mt-14">
      <div class="rounded-2xl overflow-hidden" data-trust-photo>
        <Image
          src={duoPhoto}
          alt="Luca und Kevin, Gründer von KFL Consulting, im Workshop und auf Reise"
          widths={[600, 900, 1200, 1800]}
          sizes="(max-width: 768px) 100vw, (max-width: 1280px) 90vw, 1200px"
          class="w-full h-auto object-cover aspect-[16/9] object-center"
        />
      </div>
    </div>

    <!-- Kennenlernstory + Haltung -->
    <div class="mt-8 md:mt-10 space-y-5">
      <p class="text-lg md:text-xl text-text-secondary leading-relaxed">
        Kennengelernt haben wir uns im Master <em>Innovation für den Mittelstand</em>. Im ersten Semester, November 2022, kam ChatGPT heraus. Zufall oder Schicksal? Der Moment hat uns nicht mehr losgelassen. Seitdem verfolgen wir jede relevante Entwicklung in diesem Bereich intensiv und lassen uns immer wieder neu davon begeistern.
      </p>
      <p class="text-lg md:text-xl text-text-secondary leading-relaxed">
        In seiner Masterarbeit hat Kevin zu Amazons A10 Algorithmus und KI auf Marktplätzen geforscht. Zwischen dieser Forschung, Projekten mit echten Unternehmen und unseren eigenen Experimenten wurde uns beiden dasselbe klar: Die besten Antworten entstehen, wenn Forschung, Praxis und KI am selben Tisch sitzen statt in getrennten Welten. An dieser Schnittstelle bauen wir seitdem Systeme, in denen am Ende jede Seite gewinnt. Den Rest der Geschichte findest du hier.
      </p>
    </div>
    <a
      href="/ueber-uns"
      class="inline-block text-accent-text hover:underline text-base font-medium mt-4 transition-colors duration-200"
    >
      Mehr über uns erfahren &rarr;
    </a>

    <!-- Stats + Badge — eine kompakte Zeile -->
    <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-x-8 gap-y-4 md:gap-x-12 md:gap-y-6">
      <div>
        <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">80+</span>
        <span class="font-body block text-sm text-text-muted mt-1">Marken</span>
      </div>
      <div>
        <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">5.000+</span>
        <span class="font-body block text-sm text-text-muted mt-1">Listings</span>
      </div>
      <div>
        <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">140+</span>
        <span class="font-body block text-sm text-text-muted mt-1">Marktplatz-Setups</span>
      </div>
      <StaatlichBadge />
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-trust]");
  if (section) {
    const h2 = section.querySelector("h2");
    const photo = section.querySelector("[data-trust-photo]");
    const stories = section.querySelectorAll("p.text-lg");
    const statItems = section.querySelectorAll(".flex.flex-wrap > div");
    const badge = section.querySelector(".inline-flex");

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // Photo reveal — clip from left
    if (photo) {
      gsap.set(photo, { clipPath: "inset(0 100% 0 0)" });

      gsap.to(photo, {
        clipPath: "inset(0 0% 0 0)",
        duration: 1,
        ease: "power2.inOut",
        scrollTrigger: {
          trigger: photo,
          start: "top 80%",
          once: true,
        },
      });
    }

    // Origin story fade-in (staggered für mehrere Absätze)
    if (stories.length) {
      gsap.set(stories, { opacity: 0, y: 20 });

      gsap.to(stories, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.12,
        ease: "power2.out",
        scrollTrigger: {
          trigger: stories[0],
          start: "top 85%",
          once: true,
        },
      });
    }

    // Stats stagger + badge
    const statsAndBadge = [...Array.from(statItems), badge].filter(Boolean) as Element[];
    if (statsAndBadge.length) {
      gsap.set(statsAndBadge, { opacity: 0, y: 20 });

      gsap.to(statsAndBadge, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: statItems[0] || badge,
          start: "top 85%",
          once: true,
        },
      });
    }
  }
</script>
