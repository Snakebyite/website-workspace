---
// Trust Section — Homepage
// Job: Luca & Kevin zeigen. Persönlichkeit, Expertise, Haltung. "People game."
// Komposition: Foto-dominant, Magazine-Style. Breites Foto als Hero-Element,
// kurzer Haltungssatz darunter, Stats + Badge als kompakte Zeile.
// Background: #0A0A0A (default)
import { ShieldCheck } from '@lucide/astro';
---

<section class="py-24 md:py-section">
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Headline -->
    <h2 class="max-w-3xl">Warum es uns gibt.</h2>

    <!-- Foto — breit, cinematisch, das Hero-Element dieser Section -->
    <div class="mt-12 md:mt-16">
      <div class="bg-surface rounded-2xl aspect-[21/9] overflow-hidden">
        <!-- Replace with real candid photo of Luca & Kevin -->
      </div>
    </div>

    <!-- Origin Story — persönlich, authentisch -->
    <p class="text-lg md:text-xl text-text-secondary leading-relaxed mt-10 md:mt-14 max-w-2xl">
      Wir haben zu viele Brands gesehen, die bei Agenturen nur eine Nummer waren. Deshalb gibt es Telos. Nicht als nächste Full Service Agentur, sondern als der Partner, den wir selbst gerne gehabt hätten.
    </p>

    <!-- Stats + Badge — eine kompakte Zeile -->
    <div class="mt-12 md:mt-16 flex flex-wrap items-center gap-x-12 gap-y-6">
      <div>
        <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">75+</span>
        <span class="font-body block text-sm text-text-muted mt-1">Marken</span>
      </div>
      <div>
        <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">5.000+</span>
        <span class="font-body block text-sm text-text-muted mt-1">Listings</span>
      </div>
      <div>
        <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">140+</span>
        <span class="font-body block text-sm text-text-muted mt-1">Marktplatz-Setups</span>
      </div>
      <span class="inline-flex items-center gap-2 bg-accent-subtle text-accent-text text-sm font-medium px-4 py-2 rounded-badge">
        <ShieldCheck class="w-4 h-4" />
        Staatlich akkreditierte Berater
      </span>
    </div>

  </div>
</section>
