---
// Leistungen Section — Homepage
// Job: Direkte Antwort auf Problem-Section. 3 Services als Teaser.
// Komposition: Bento Grid — Marktplatz-Strategie full-width oben (größte Kachel),
// Organische Sichtbarkeit (7col) + KI & Prozesse (5col, kleinste) unten.
// Kacheln: border-only (white/5), angedeutet statt gefüllt. Resend-Style.
// Hierarchie: "Was wir tun." als einziges Serif-Element (H2).
// Service-Namen in Satoshi medium, Sublines + Body in text-secondary.
import OrganicVisual from "../components/OrganicVisual.astro";
import KIProzesseVisual from "../components/KIProzesseVisual.astro";

// Tool logos — all white on dark background
import toolMake from "../assets/tools/make.png";
import toolAirtable from "../assets/tools/airtable.png";
import toolChannable from "../assets/tools/channable.png";
import toolDatadive from "../assets/tools/datadive.png";
import toolClaude from "../assets/tools/claude-code.png";
import toolMirakl from "../assets/tools/mirakl.png";

// Marketplace logos
import mpAmazon from "../assets/marketplaces/amazon.png";
import mpOtto from "../assets/marketplaces/otto.png";
import mpKaufland from "../assets/marketplaces/kaufland.png";
import mpZalando from "../assets/marketplaces/zalando.png";
import mpEbay from "../assets/marketplaces/ebay.png";
import mpDecathlon from "../assets/marketplaces/decathlon.png";
import mpHornbach from "../assets/marketplaces/hornbach.png";
import mpObi from "../assets/marketplaces/obi.png";
import mpHome24 from "../assets/marketplaces/home24.png";
import mpGalaxus from "../assets/marketplaces/galaxus.png";
import mpBolcom from "../assets/marketplaces/bolcom.png";
import mpAllegro from "../assets/marketplaces/allegro.png";

const tools = [
  { src: toolMake, name: "Make" },
  { src: toolClaude, name: "Claude Code" },
  { src: toolChannable, name: "Channable" },
  { src: toolDatadive, name: "DataDive" },
  { src: toolAirtable, name: "Airtable" },
  { src: toolMirakl, name: "Mirakl" },
];

const marketplaces = [
  { src: mpAmazon, name: "Amazon" },
  { src: mpOtto, name: "Otto Market" },
  { src: mpKaufland, name: "Kaufland" },
  { src: mpZalando, name: "Zalando" },
  { src: mpEbay, name: "eBay" },
  { src: mpDecathlon, name: "Decathlon" },
  { src: mpHornbach, name: "Hornbach" },
  { src: mpObi, name: "OBI" },
  { src: mpHome24, name: "home24" },
  { src: mpGalaxus, name: "Galaxus" },
  { src: mpBolcom, name: "bol.com" },
  { src: mpAllegro, name: "Allegro" },
];
---

<section id="leistungen" class="py-20 md:py-32" data-leistungen>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Section Headline — Instrument Serif, einziges Serif-Element -->
    <h2 class="max-w-2xl">Was wir tun.</h2>

    <!-- Bento Grid -->
    <div class="mt-12 md:mt-16 grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-5">

      <!-- Kachel 1: Marktplatz-Strategie — full-width, größte Kachel -->
      <div class="bento-card lg:col-span-12 border border-white/5 rounded-2xl p-8 md:p-10">
        <h3 class="font-body text-2xl md:text-[2rem] font-medium tracking-[-0.01em]">Marktplatz-Strategie</h3>
        <p class="font-body text-lg md:text-xl text-text-secondary leading-relaxed mt-3 max-w-2xl">
          Marktplatz-Wachstum, das auf Daten steht.
        </p>
        <p class="font-body text-lg text-text-secondary leading-relaxed mt-3 max-w-2xl">
          Wir machen den Einstieg und die Skalierung auf digitalen Marktplätzen <span class="text-accent-text font-medium">planbar.</span> Keine Bauchentscheidungen, sondern Strategie, die auf Daten basiert.
        </p>
      </div>

      <!-- Kachel 2: Organische Sichtbarkeit — 7col -->
      <div class="bento-card lg:col-span-7 border border-white/5 rounded-2xl p-8 md:p-10">
        <h3 class="font-body text-2xl md:text-[2rem] font-medium tracking-[-0.01em]">Organische Sichtbarkeit</h3>
        <p class="font-body text-lg md:text-xl text-text-secondary leading-relaxed mt-3">
          SEO ist kein Kanal, es ist das Fundament. Ohne organische Relevanz verbrennst du Budget.
        </p>
        <p class="font-body text-lg text-text-secondary leading-relaxed mt-3">
          Wir optimieren <span class="text-accent-text font-medium">Listings, Keywords und Content</span> so, dass deine Produkte gefunden werden, bevor du für Klicks zahlst.
        </p>
        <!-- Ranklift Organic Dashboard Visual — direkt nach Text, volle Breite -->
        <div class="mt-10 md:mt-12 -mx-4 md:-mx-6">
          <OrganicVisual />
        </div>
      </div>

      <!-- Kachel 3: KI & Prozesse — 5col, kleinste Kachel -->
      <div class="bento-card lg:col-span-5 border border-white/5 rounded-2xl p-8 md:p-10 flex flex-col justify-between">
        <div>
          <h3 class="font-body text-2xl md:text-[2rem] font-medium tracking-[-0.01em]">KI & Prozesse</h3>
          <p class="font-body text-lg md:text-xl text-text-secondary leading-relaxed mt-3">
            Erst der Prozess, dann die Automatisierung.
          </p>
          <p class="font-body text-lg text-text-secondary leading-relaxed mt-3">
            KI auf schlechte Prozesse kippen bringt nichts. Wir identifizieren die Hebel, <span class="text-accent-text font-medium">designen den Prozess sauber</span> und automatisieren dann mit Verstand.
          </p>
        </div>
        <!-- KI & Prozesse Flow Visual -->
        <div class="mt-6">
          <KIProzesseVisual />
        </div>
      </div>

      <!-- Kachel 4: Marktplatz-Anbindungen — full-width, Text links (5col) + Logo-Grid rechts (7col) -->
      <div class="bento-card lg:col-span-12 border border-white/5 rounded-2xl p-8 md:p-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
          <div class="lg:col-span-5">
            <h3 class="font-body text-2xl md:text-[2rem] font-medium tracking-[-0.01em]">Marktplatz-Anbindungen</h3>
            <p class="font-body text-lg md:text-xl text-text-secondary leading-relaxed mt-3">
              Dein Produkt auf dem Marktplatz. Technisch sauber, in Tagen statt Monaten.
            </p>
            <p class="font-body text-lg text-text-secondary leading-relaxed mt-3">
              Vom <span class="text-accent-text font-medium">Stammdaten-Mapping</span> bis zum Live-Gang. Wir übernehmen die komplette Anbindung, damit du dich auf dein Produkt konzentrieren kannst.
            </p>
            <p class="font-body text-lg md:text-xl text-text-primary leading-relaxed mt-6">
              Zugang zu über <span class="text-accent-text font-medium">100+ Marktplätzen</span> weltweit. Von der Anbindung bis zur laufenden Optimierung, alles aus einer Hand.
            </p>
          </div>
          <div class="lg:col-span-7 flex items-center">
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-1 w-full">
              {marketplaces.map((mp) => (
                <div class="mp-logo flex items-center justify-center rounded-lg overflow-hidden">
                  <img src={mp.src.src} alt={mp.name} loading="lazy" class="w-full h-auto object-contain opacity-80" />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Tools Section — statisches Grid, alle Tools nebeneinander lesbar -->
    <div class="mt-20 md:mt-28" data-tools-band>
      <h3 class="font-body text-xl md:text-2xl font-medium tracking-[-0.01em] text-text-secondary">
        Tools, die wir nutzen.
      </h3>
      <div class="mt-10 md:mt-14 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-1 w-full">
        {tools.map((tool) => (
          <div class="tool-item flex items-center justify-center rounded-lg overflow-hidden">
            <img src={tool.src.src} alt={tool.name} loading="lazy" class="w-full h-auto object-contain opacity-80" />
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-leistungen]");
  if (section) {
    const h2 = section.querySelector("h2");
    const cards = section.querySelectorAll(".grid > div[class*='col-span']");

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // Bento cards stagger entrance
    if (cards.length) {
      gsap.set(cards, { opacity: 0, y: 30 });

      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        stagger: 0.12,
        ease: "power2.out",
        scrollTrigger: {
          trigger: cards[0],
          start: "top 80%",
          once: true,
        },
      });
    }

    // Tools band fade-in
    const toolsBand = section.querySelector("[data-tools-band]");
    if (toolsBand) {
      gsap.set(toolsBand, { opacity: 0, y: 20 });
      gsap.to(toolsBand, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
        scrollTrigger: { trigger: toolsBand, start: "top 85%", once: true },
      });
    }

  }
</script>

<style>
  .bento-card {
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .bento-card:hover {
    border-color: rgba(76, 175, 130, 0.25);
    background-color: rgba(76, 175, 130, 0.03);
  }

  .mp-logo {
    transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    border: 1px solid transparent;
  }

  .mp-logo:hover {
    background-color: rgba(76, 175, 130, 0.06);
    border-color: rgba(76, 175, 130, 0.25);
    transform: translateY(-2px);
  }

  .mp-logo img {
    transition: opacity 0.3s ease;
  }

  .mp-logo:hover img {
    opacity: 1;
  }

  /* Tools Grid — gleiche Optik wie Marketplace-Logos */
  .tool-item {
    transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    border: 1px solid transparent;
  }

  .tool-item:hover {
    background-color: rgba(76, 175, 130, 0.06);
    border-color: rgba(76, 175, 130, 0.25);
    transform: translateY(-2px);
  }

  .tool-item img {
    transition: opacity 0.3s ease;
  }

  .tool-item:hover img {
    opacity: 1;
  }

</style>
