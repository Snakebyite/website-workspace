---
// Kevin Profil — Foto links (45%), Text rechts (55%)
// Asymmetric split per design.md Team Section Archetype
import { Image } from "astro:assets";
import kevinPhoto from "../../assets/kevin-ueber-uns.jpg";
---

<section class="py-16 md:py-24" data-profil-kevin>
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- Left: Photo -->
      <div class="lg:col-span-5" data-profil-kevin-photo>
        <div class="rounded-2xl overflow-hidden">
          <Image
            src={kevinPhoto}
            alt="Kevin Flurschütz, Gründer von KFL Consulting"
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 100vw, 40vw"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>

      <!-- Right: Text -->
      <div class="lg:col-span-7" data-profil-kevin-text>
        <h2 class="text-3xl sm:text-4xl md:text-[3rem] tracking-[-0.03em] leading-[1.15]">
          Kevin, Marktplatz-Strategie, SEO &amp; Media Buying.
        </h2>

        <div class="mt-8 space-y-5">
          <p class="text-base md:text-lg text-text-secondary leading-relaxed">
            Kevin beschäftigt sich seit über sieben Jahren intensiv mit digitalen Marktplätzen, insbesondere Amazon. Was bei den meisten als Nebenjob anfängt, wurde bei ihm zum wissenschaftlichen Fokus: In seiner Bachelor- und Masterarbeit hat er den Amazon-Algorithmus und die Mechanik hinter organischer Sichtbarkeit erforscht.
          </p>
          <p class="text-base md:text-lg text-text-secondary leading-relaxed">
            Dieses Wissen setzt er heute täglich ein. Kevin kennt die Stellschrauben, die über Sichtbarkeit, Ranking und Conversion auf Marktplätzen entscheiden. Nicht aus Blogposts, sondern aus Tausenden optimierten Listings und der ständigen Arbeit am Puls der Plattformen.
          </p>
          <p class="text-base md:text-lg text-text-secondary leading-relaxed">
            Was ihn antreibt: Die Verbindung aus neuen Technologien und den realen Herausforderungen von E-Commerce Brands. Nicht Theorie um der Theorie willen, sondern Wissen, das messbare Ergebnisse liefert.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-profil-kevin]");
  if (section) {
    const photo = section.querySelector("[data-profil-kevin-photo] .rounded-2xl");
    const textBlock = section.querySelector("[data-profil-kevin-text]");
    const h2 = textBlock?.querySelector("h2");
    const paragraphs = textBlock?.querySelectorAll("p");

    // Photo clip reveal from left
    if (photo) {
      gsap.set(photo, { clipPath: "inset(0 100% 0 0)" });

      gsap.to(photo, {
        clipPath: "inset(0 0% 0 0)",
        duration: 1,
        ease: "power2.inOut",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: h2,
          start: "top 80%",
          once: true,
        },
      });
    }

    // Paragraphs stagger
    paragraphs?.forEach((p, i) => {
      gsap.set(p, { opacity: 0, y: 20 });

      gsap.to(p, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        delay: 0.1 * i,
        ease: "power2.out",
        scrollTrigger: {
          trigger: p,
          start: "top 85%",
          once: true,
        },
      });
    });
  }
</script>
