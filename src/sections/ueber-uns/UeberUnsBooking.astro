---
// UeberUnsBooking — CTA am Ende der Über-uns-Seite.
// Zentriertes, reduziertes Layout: die Gründer-Cards drüber tragen das "people game"
// schon visuell, der CTA bleibt bewusst ruhig und fokussiert auf den Klick.
// Öffnet Calendly als Popup; ohne JS fällt der Link auf die Scheduling-URL in neuem Tab.

const calendlyUrl =
  "https://calendly.com/kflconsulting/kennenlernen?hide_event_type_details=1&hide_gdpr_banner=1&background_color=0a0a0a&text_color=efefef&primary_color=4caf82";
---

<section
  class="py-20 md:py-32"
  aria-label="Termin buchen"
  data-ueber-booking
>
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="flex flex-col items-center text-center max-w-2xl mx-auto">
      <h2>Jetzt persönlich kennenlernen.</h2>
      <p class="text-text-secondary text-lg md:text-xl leading-relaxed mt-6">
        30 Minuten per Zoom. Du erzählst, wo du stehst; wir sagen ehrlich,
        ob und wo wir einen Hebel sehen.
      </p>

      <div
        class="relative mt-10 flex flex-col items-center gap-3"
        data-booking-cta
      >
        <span class="cta-glow" aria-hidden="true"></span>

        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener"
          data-calendly-trigger
          class="relative inline-block bg-accent hover:bg-accent-hover text-background font-medium px-8 py-4 rounded-button tracking-[0.01em] leading-none transition-colors duration-200"
        >
          Termin buchen
        </a>
        <span class="relative text-text-muted text-sm">
          kostenlos & unverbindlich
        </span>
      </div>
    </div>
  </div>
</section>

<link
  is:inline
  rel="stylesheet"
  href="https://assets.calendly.com/assets/external/widget.css"
/>
<script
  is:inline
  async
  src="https://assets.calendly.com/assets/external/widget.js"></script>

<style>
  .cta-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 420px;
    height: 420px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle at center,
      rgba(76, 175, 130, 0.28) 0%,
      rgba(76, 175, 130, 0.12) 35%,
      rgba(76, 175, 130, 0) 70%
    );
    filter: blur(40px);
    opacity: 0.85;
    pointer-events: none;
    z-index: 0;
    animation: cta-glow-pulse 6s ease-in-out infinite;
    transition: opacity 400ms ease, transform 400ms ease;
  }

  [data-booking-cta]:hover .cta-glow {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.08);
  }

  @keyframes cta-glow-pulse {
    0%,
    100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
    }
  }
</style>

<script>
  interface CalendlyAPI {
    initPopupWidget: (options: { url: string }) => void;
  }
  const w = window as typeof window & { Calendly?: CalendlyAPI };

  const trigger = document.querySelector<HTMLAnchorElement>(
    "[data-calendly-trigger]",
  );
  if (trigger) {
    trigger.addEventListener("click", (e) => {
      if (!w.Calendly) return; // Fallback: Link öffnet in neuem Tab
      e.preventDefault();
      w.Calendly.initPopupWidget({ url: trigger.href });
    });
  }

  // Entrance animation — match site rhythm
  import("gsap").then(({ gsap }) => {
    Promise.all([
      import("gsap/ScrollTrigger"),
      import("gsap/SplitText"),
    ]).then(([{ ScrollTrigger }, { SplitText }]) => {
      gsap.registerPlugin(ScrollTrigger, SplitText);

      const section = document.querySelector("[data-ueber-booking]");
      if (!section) return;

      const h2 = section.querySelector("h2");
      const subtext = section.querySelector("p");
      const cta = section.querySelector("[data-booking-cta]");

      if (h2) {
        const split = new SplitText(h2, { type: "words" });
        gsap.set(split.words, { opacity: 0, y: 20 });
        gsap.to(split.words, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.08,
          ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 75%", once: true },
        });
      }

      if (subtext) {
        gsap.set(subtext, { opacity: 0, y: 20 });
        gsap.to(subtext, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out",
          scrollTrigger: { trigger: subtext, start: "top 85%", once: true },
        });
      }

      if (cta) {
        gsap.set(cta, { opacity: 0, y: 20 });
        gsap.to(cta, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: "power2.out",
          scrollTrigger: { trigger: cta, start: "top 85%", once: true },
        });
      }
    });
  });
</script>
