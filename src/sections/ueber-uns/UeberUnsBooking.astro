---
// UeberUnsBooking — Inline-Embed des Booking-Tools am Ende der Über-uns-Seite.
// Ersetzt UeberUnsCTA: der Besucher soll ohne Page-Wechsel direkt buchen können.

const bookingUrl =
  import.meta.env.PUBLIC_BOOKING_URL ??
  (import.meta.env.DEV
    ? "http://localhost:3100"
    : "https://booking.kfl-consulting.com");
---

<section
  class="py-16 md:py-24"
  aria-label="Termin buchen"
  data-ueber-booking
>
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="max-w-2xl mb-10 md:mb-14">
      <h2>Der nächste Schritt ist ein unverbindliches Gespräch.</h2>
      <p class="text-text-secondary text-lg md:text-xl leading-relaxed mt-6">
        Wir schauen uns deine größten Engpässe an und sagen dir ehrlich, wo die Hebel liegen.
      </p>
    </div>

    <div
      class="relative rounded-card overflow-hidden border border-white/5 bg-surface/30 booking-frame"
      data-booking-frame
    >
      <iframe
        src={bookingUrl}
        title="KFL Consulting — Termin buchen"
        class="w-full block border-0"
        loading="lazy"
        allow="clipboard-write"
        data-booking-iframe
      ></iframe>

      <noscript>
        <div class="p-10 text-center text-text-secondary">
          Für die Terminbuchung bitte JavaScript aktivieren oder direkt auf
          <a href={bookingUrl} class="text-accent-text underline">
            {bookingUrl}
          </a>
          buchen.
        </div>
      </noscript>
    </div>
  </div>
</section>

<style>
  /* Responsive fallback height: overridden by postMessage once iframe posts its height */
  .booking-frame iframe {
    height: 900px;
  }
  @media (max-width: 1023px) {
    .booking-frame iframe {
      height: 1600px;
    }
  }
</style>

<script>
  // Dynamic iframe height: booking-tool posts its content height, we apply it here.
  // Breakpoints fall back via CSS min-height if postMessage doesn't arrive.
  const iframe = document.querySelector<HTMLIFrameElement>("[data-booking-iframe]");

  window.addEventListener("message", (e) => {
    if (
      e.data &&
      e.data.type === "kfl-booking-height" &&
      typeof e.data.height === "number" &&
      iframe
    ) {
      // 24px buffer against rounding / scrollbar jitter
      iframe.style.height = `${e.data.height}px`;
    }
  });

  // Entrance animation for headline + subtext (match site rhythm)
  import("gsap").then(({ gsap }) => {
    Promise.all([
      import("gsap/ScrollTrigger"),
      import("gsap/SplitText"),
    ]).then(([{ ScrollTrigger }, { SplitText }]) => {
      gsap.registerPlugin(ScrollTrigger, SplitText);

      const section = document.querySelector("[data-ueber-booking]");
      if (!section) return;

      const h2 = section.querySelector("h2");
      const subtext = section.querySelector("p");
      const frame = section.querySelector("[data-booking-frame]");

      if (h2) {
        const split = new SplitText(h2, { type: "words" });
        gsap.set(split.words, { opacity: 0, y: 20 });
        gsap.to(split.words, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.08,
          ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 75%", once: true },
        });
      }

      if (subtext) {
        gsap.set(subtext, { opacity: 0, y: 20 });
        gsap.to(subtext, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out",
          scrollTrigger: { trigger: subtext, start: "top 85%", once: true },
        });
      }

      if (frame) {
        gsap.set(frame, { opacity: 0, y: 30 });
        gsap.to(frame, {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: "power2.out",
          scrollTrigger: { trigger: frame, start: "top 85%", once: true },
        });
      }
    });
  });
</script>
