---
// "Wann es passt, und wann nicht." — ICP-Filter via Polaritäts-Pairs
// Editorial Rows: Nummer als Anker links, positive Headline + Disqualifikations-Zeile rechts.
// Ersetzt das vorherige 4er-Card-Grid (Wertekatalog) durch self-selection.
const pairs = [
  {
    headline: "Es muss sich für beide lohnen.",
    detail:
      "Wenn wir nicht überzeugt sind, dass wir bei dir echten Impact liefern können, sagen wir ab. Auch wenn das Geld auf dem Tisch liegt.",
  },
  {
    headline: "Du willst jemanden, der mitdenkt.",
    detail:
      "Das heißt für uns auch: andere Wege vorschlagen und im Zweifel deine Idee challengen. Wenn du jemanden suchst, der blind ausführt und keine Rückfragen stellt, sind wir die falschen.",
  },
  {
    headline: "Wir machen eine Sache richtig: Marktplätze.",
    detail:
      "Wenn du eine Agentur suchst, die parallel auch Website, Branding und E-Mail-Marketing übernimmt, bist du bei uns an der falschen Adresse. Wir haben oft genug gesehen: Wer alles anbietet, ist in nichts wirklich Experte.",
  },
];
---

<section class="py-16 md:py-24" data-so-arbeiten>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <div class="max-w-3xl mb-14 md:mb-20">
      <h2 data-so-arbeiten-h2>Wann für uns eine Zusammenarbeit in Frage kommt.</h2>
    </div>

    <ol data-so-arbeiten-rows>
      {pairs.map((pair, i) => (
        <li
          class="group relative grid grid-cols-12 items-baseline gap-x-6 md:gap-x-10 gap-y-6 py-14 md:py-20"
          data-pair-row
        >
          <div class="col-span-12 md:col-span-3 lg:col-span-2">
            <span
              class="block text-4xl md:text-5xl lg:text-6xl leading-[0.85] text-text-muted/70 transition-colors duration-300 group-hover:text-accent-text"
              style="font-family: var(--font-heading); font-feature-settings: 'lnum';"
              aria-hidden="true"
              data-pair-num
            >
              {String(i + 1).padStart(2, "0")}
            </span>
          </div>

          <div class="col-span-12 md:col-span-9 md:col-start-4">
            <h3 class="mb-5 md:mb-6 max-w-3xl" data-pair-h3>
              {pair.headline}
            </h3>
            <p
              class="text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl transition-colors duration-300 group-hover:text-text-primary/90"
              data-pair-p
            >
              {pair.detail}
            </p>
          </div>
        </li>
      ))}
    </ol>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-so-arbeiten]");
  if (section) {
    const h2 = section.querySelector("[data-so-arbeiten-h2]");
    const rows = section.querySelectorAll("[data-pair-row]");

    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });
      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 75%", once: true },
      });
    }

    rows.forEach((row) => {
      const num = row.querySelector("[data-pair-num]");
      const h3 = row.querySelector("[data-pair-h3]");
      const p = row.querySelector("[data-pair-p]");
      const elements = [num, h3, p].filter((el): el is Element => el !== null);

      if (!elements.length) return;

      gsap.set(elements, { opacity: 0, y: 20 });
      gsap.to(elements, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: { trigger: row, start: "top 85%", once: true },
      });
    });
  }
</script>
