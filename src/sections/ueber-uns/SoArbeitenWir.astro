---
// "So arbeiten wir" — 4 Werte-Karten
// Border-only cards, accent-green hover mit Linie oben
import { Handshake, Users, Target, Zap } from "@lucide/astro";

const values = [
  {
    icon: Handshake,
    title: "Win-Win oder gar nicht.",
    text: 'Eine Zusammenarbeit kommt für uns nur in Frage, wenn wir dir ehrlich sagen können, dass es sich für <span class="text-accent-text font-medium">beide Seiten lohnt</span>. Wir lehnen Projekte ab, bei denen wir keinen echten Impact versprechen können. Auch wenn das Geld auf dem Tisch liegt.',
  },
  {
    icon: Users,
    title: "Partnerschaft auf Augenhöhe.",
    text: 'Wir sind keine Ja-Sager. Wenn wir eine bessere Idee haben, sagen wir das. Du bekommst einen <span class="text-accent-text font-medium">ehrlichen Sparringspartner</span>, der die Strategie hinterfragt, statt einfach abzunicken.',
  },
  {
    icon: Target,
    title: "Tiefe statt Breite.",
    text: 'Wir nehmen uns die Zeit, in dein Unternehmen und deine Produkte einzutauchen. Kein Quick-Fix, kein oberflächliches Drüberschauen. Wir wollen verstehen, wo <span class="text-accent-text font-medium">die größten Hebel</span> liegen.',
  },
  {
    icon: Zap,
    title: "Lean und effizient.",
    text: 'Keine aufgeblähten Teams, keine unnötigen Meetings, keine Powerpoint-Schlachten. Wir arbeiten <span class="text-accent-text font-medium">fokussiert und ergebnisorientiert</span>. Damit du mehr Ergebnisse bekommst und weniger Zeit in Abstimmungen verbrennst.',
  },
];
---

<section class="py-16 md:py-24" data-so-arbeiten>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <h2 data-so-arbeiten-h2>So arbeiten wir.</h2>

    <div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6" data-so-arbeiten-grid>
      {values.map((value) => (
        <div class="wert-card relative rounded-2xl p-7 md:p-10 border border-white/5 overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:border-accent/25 hover:shadow-[0_8px_30px_rgba(76,175,130,0.08)]">
          <div class="absolute top-0 left-6 right-6 h-px bg-accent/0 transition-all duration-300 wert-card-line"></div>
          <div class="mb-5 text-text-muted transition-colors duration-300 wert-card-icon">
            <value.icon size={24} stroke-width={1.5} />
          </div>
          <h3 class="text-xl md:text-2xl font-medium tracking-[-0.02em] leading-[1.2] mb-4">{value.title}</h3>
          <p class="text-text-secondary text-base md:text-lg leading-relaxed" set:html={value.text} />
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-so-arbeiten]");
  if (section) {
    const h2 = section.querySelector("[data-so-arbeiten-h2]");
    const cards = section.querySelectorAll("[data-so-arbeiten-grid] > div");

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // Cards stagger fade-in
    if (cards.length) {
      gsap.set(cards, { opacity: 0, y: 25 });

      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.12,
        ease: "power2.out",
        scrollTrigger: {
          trigger: cards[0],
          start: "top 85%",
          once: true,
        },
      });
    }
  }
</script>

<style>
  .wert-card:hover .wert-card-line {
    background-color: rgba(76, 175, 130, 0.5);
  }

  .wert-card:hover .wert-card-icon {
    color: var(--color-accent-text);
  }
</style>
