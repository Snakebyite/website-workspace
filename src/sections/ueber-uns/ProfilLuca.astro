---
// Luca Profil — Text links (55%), Foto rechts (45%)
// Gespiegelt zu Kevin für visuellen Rhythmus (design.md Team Archetype)
import { Image } from "astro:assets";
import lucaPhoto from "../../assets/luca-ueber-uns.jpeg";
---

<section class="py-16 md:py-24" data-profil-luca>
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <!-- Left: Text (on mobile, heading shows first naturally) -->
      <div class="lg:col-span-7 order-2 lg:order-1" data-profil-luca-text>
        <h2 class="text-3xl sm:text-4xl md:text-[3rem] tracking-[-0.03em] leading-[1.15]">
          Luca, KI, Automatisierung &amp; strategische Beratung.
        </h2>

        <div class="mt-8 space-y-5">
          <p class="text-base md:text-lg text-text-secondary leading-relaxed">
            Luca hat in der Industrie gesehen, wie große Unternehmen arbeiten. Bei Mercedes, Allianz und Porsche. Und er hat gesehen, was ihn dort gestört hat: Starre Strukturen, langsame Prozesse und zu wenig Raum für echte Veränderung.
          </p>
          <p class="text-base md:text-lg text-text-secondary leading-relaxed">
            Im Master Innovationsmanagement hat er sich intensiv mit KI beschäftigt. Nicht als Buzzword, sondern als Werkzeug, das Unternehmen konkret effizienter macht. Heute bringt er dieses Wissen in die Zusammenarbeit mit E-Commerce Brands ein: Prozesse analysieren, Engpässe identifizieren, durchdachte Automatisierungen aufsetzen und Teams befähigen, mit neuen Technologien zu arbeiten.
          </p>
          <p class="text-base md:text-lg text-text-secondary leading-relaxed">
            Was ihn antreibt: Wirklich Impact schaffen, nicht nur ein kleines Zahnrad in einer Maschinerie sein. Ideen umsetzen, die funktionieren. Und dabei kontinuierlich dazulernen.
          </p>
        </div>
      </div>

      <!-- Right: Photo -->
      <div class="lg:col-span-5 order-1 lg:order-2" data-profil-luca-photo>
        <div class="rounded-2xl overflow-hidden">
          <Image
            src={lucaPhoto}
            alt="Luca, Gründer von KFL Consulting"
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 100vw, 40vw"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-profil-luca]");
  if (section) {
    const photo = section.querySelector("[data-profil-luca-photo] .rounded-2xl");
    const textBlock = section.querySelector("[data-profil-luca-text]");
    const h2 = textBlock?.querySelector("h2");
    const paragraphs = textBlock?.querySelectorAll("p");

    // Photo clip reveal from right (mirrored from Kevin)
    if (photo) {
      gsap.set(photo, { clipPath: "inset(0 0 0 100%)" });

      gsap.to(photo, {
        clipPath: "inset(0 0 0 0%)",
        duration: 1,
        ease: "power2.inOut",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: h2,
          start: "top 80%",
          once: true,
        },
      });
    }

    // Paragraphs stagger
    paragraphs?.forEach((p, i) => {
      gsap.set(p, { opacity: 0, y: 20 });

      gsap.to(p, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        delay: 0.1 * i,
        ease: "power2.out",
        scrollTrigger: {
          trigger: p,
          start: "top 85%",
          once: true,
        },
      });
    });
  }
</script>
