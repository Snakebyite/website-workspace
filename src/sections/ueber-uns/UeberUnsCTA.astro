---
// CTA für die Über-uns-Seite
// Spezifischer als der Home-CTA: 30 Min, Setup anschauen, Engpässe identifizieren
---

<section class="py-16 md:py-24" aria-label="Termin buchen" data-ueber-cta>
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">

      <!-- Left: Headline + Context -->
      <div class="lg:col-span-7">
        <h2>Der nächste Schritt ist ein unverbindliches Gespräch.</h2>
        <p class="text-text-secondary text-lg md:text-xl leading-relaxed mt-6 max-w-xl">
          30 Minuten, in denen wir gemeinsam auf dein Marktplatz-Setup und deine größten Herausforderungen schauen. Wir sagen dir ehrlich, wo die Hebel für deine Engpässe liegen.
        </p>
      </div>

      <!-- Right: Action -->
      <div class="lg:col-span-5 flex flex-col items-start lg:items-end gap-4 md:gap-5">
        <a
          href="/kontakt"
          class="inline-block bg-accent hover:bg-accent-hover text-background font-medium px-8 py-4 rounded-button tracking-[0.01em] leading-none transition-colors duration-200"
        >
          Gespräch vereinbaren
        </a>
        <span class="text-sm text-text-muted">Unverbindlich · 30 Minuten</span>
        <a
          href="/referenzen"
          class="text-accent-text hover:underline text-sm font-medium transition-colors duration-200"
        >
          Erstmal Referenzen ansehen &rarr;
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-ueber-cta]");
  if (section) {
    const h2 = section.querySelector("h2");
    const subtext = section.querySelector("p");
    const actionArea = section.querySelector(".lg\\:col-span-5");

    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    if (subtext) {
      gsap.set(subtext, { opacity: 0, y: 20 });

      gsap.to(subtext, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
        scrollTrigger: {
          trigger: subtext,
          start: "top 85%",
          once: true,
        },
      });
    }

    if (actionArea) {
      const items = actionArea.children;
      gsap.set(items, { opacity: 0, y: 20 });

      gsap.to(items, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: actionArea,
          start: "top 85%",
          once: true,
        },
      });
    }
  }
</script>
