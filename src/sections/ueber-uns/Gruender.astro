---
// Gründer-Section — kompakte 2-Card-Ansicht von Kevin und Luca
// Kevin links, Luca rechts (Kevin-first als Erstkontakt im Sales-Call)
import { Image } from "astro:assets";
import { ArrowUpRight } from "@lucide/astro";
import kevinPhoto from "../../assets/ueber-uns/kevin-alleine-lachend-2773x4160.jpeg";
import lucaPhoto from "../../assets/ueber-uns/luca-konzentriert-1280x1920.jpeg";

const kevinLinkedIn = "https://www.linkedin.com/in/kevin-flursch%C3%BCtz/";
const lucaLinkedIn = "https://www.linkedin.com/in/luca-slangen/";
---

<section class="pt-24 md:pt-40 pb-10 md:pb-14" data-gruender>
  <div class="mx-auto max-w-5xl px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 items-stretch">

      <!-- Kevin -->
      <article class="gruender-card rounded-2xl overflow-hidden bg-surface border border-white/5 flex flex-col" data-gruender-card>
        <div class="relative h-[340px] md:h-[400px] shrink-0 overflow-hidden" data-gruender-photo>
          <Image
            src={kevinPhoto}
            alt="Kevin, Co-Founder von Telos"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 40vw"
            class="gruender-photo-img w-full h-full object-cover object-[center_25%]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/40 to-transparent pointer-events-none"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6 pointer-events-none">
            <h2 class="font-serif text-2xl md:text-3xl tracking-[-0.02em] text-text-primary">
              Kevin
            </h2>
            <p class="mt-1.5 text-[11px] font-medium tracking-[0.08em] uppercase text-text-secondary">
              Co-Founder
            </p>
          </div>
        </div>

        <div class="p-5 md:p-6 flex flex-col flex-1">
          <p class="font-serif italic text-lg md:text-xl tracking-[-0.01em] leading-snug text-text-primary">
            Spezialist für digitale Marktplätze.
          </p>
          <p class="mt-3 text-[14px] md:text-[15px] text-text-secondary leading-relaxed">
            Seit 2018 arbeite ich mit digitalen Marktplätzen, vor allem Amazon. In Bachelor- und Masterarbeit habe ich den Algorithmus und die Mechanik hinter organischer Sichtbarkeit erforscht. Dieses Wissen wende ich täglich an, aus tausenden optimierten Listings statt aus Blogposts.
          </p>
          <a
            href={kevinLinkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="gruender-link group mt-auto pt-4 inline-flex items-center gap-3 text-sm text-accent-text transition-colors self-start"
          >
            <span class="block h-4 w-[2px] shrink-0 rounded-full bg-accent-text/60 transition-colors duration-300 ease-out group-hover:bg-accent-text" aria-hidden="true"></span>
            <span>Finde mich auf LinkedIn</span>
            <ArrowUpRight class="gruender-link-arrow w-4 h-4 transition-transform duration-300 ease-out" aria-hidden="true" />
          </a>
        </div>
      </article>

      <!-- Luca -->
      <article class="gruender-card rounded-2xl overflow-hidden bg-surface border border-white/5 flex flex-col" data-gruender-card>
        <div class="relative h-[340px] md:h-[400px] shrink-0 overflow-hidden" data-gruender-photo>
          <Image
            src={lucaPhoto}
            alt="Luca, Co-Founder von Telos"
            widths={[400, 600, 800, 1000]}
            sizes="(max-width: 768px) 100vw, 40vw"
            class="gruender-photo-img w-full h-full object-cover object-[center_50%]"
            style="--base-scale: 1.2; transform-origin: right top;"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/40 to-transparent pointer-events-none"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6 pointer-events-none">
            <h2 class="font-serif text-2xl md:text-3xl tracking-[-0.02em] text-text-primary">
              Luca
            </h2>
            <p class="mt-1.5 text-[11px] font-medium tracking-[0.08em] uppercase text-text-secondary">
              Co-Founder
            </p>
          </div>
        </div>

        <div class="p-5 md:p-6 flex flex-col flex-1">
          <p class="font-serif italic text-lg md:text-xl tracking-[-0.01em] leading-snug text-text-primary">
            Spezialist für Prozesse und KI.
          </p>
          <p class="mt-3 text-[14px] md:text-[15px] text-text-secondary leading-relaxed">
            Bei Porsche, Mercedes und Allianz habe ich tiefe Einblicke bekommen, wie Konzerne funktionieren und ihre Prozesse aufgebaut sind. Für mich war das aber zu langsam und ich hatte zu wenig Spielraum für die Themen, die mich wirklich interessieren und echten Impact schaffen. Also habe ich mich entschieden zu gründen.
          </p>
          <a
            href={lucaLinkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="gruender-link group mt-auto pt-4 inline-flex items-center gap-3 text-sm text-accent-text transition-colors self-start"
          >
            <span class="block h-4 w-[2px] shrink-0 rounded-full bg-accent-text/60 transition-colors duration-300 ease-out group-hover:bg-accent-text" aria-hidden="true"></span>
            <span>Finde mich auf LinkedIn</span>
            <ArrowUpRight class="gruender-link-arrow w-4 h-4 transition-transform duration-300 ease-out" aria-hidden="true" />
          </a>
        </div>
      </article>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const section = document.querySelector("[data-gruender]");
  if (section) {
    const cards = section.querySelectorAll("[data-gruender-card]");

    cards.forEach((card, i) => {
      gsap.set(card, { opacity: 0, y: 30 });
      gsap.to(card, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        delay: i * 0.12,
        ease: "power2.out",
        scrollTrigger: {
          trigger: card,
          start: "top 85%",
          once: true,
        },
      });
    });
  }
</script>

<style>
  /* Card: dezenter Border-Glow + Lift beim Hover, analog zu den Bento-Cards auf /leistungen. */
  .gruender-card {
    transition: border-color 0.3s ease, background-color 0.3s ease, transform 0.3s ease;
  }

  .gruender-card:hover {
    border-color: rgba(76, 175, 130, 0.25);
    background-color: rgba(76, 175, 130, 0.03);
    transform: translateY(-3px);
  }

  /* Portrait: subtiler Zoom beim Hover. --base-scale erlaubt Luca-Foto dauerhaft hochzoomen. */
  .gruender-photo-img {
    transform: scale(var(--base-scale, 1));
    transition: transform 0.6s ease-out;
    will-change: transform;
  }

  .gruender-card:hover .gruender-photo-img {
    transform: scale(calc(var(--base-scale, 1) * 1.04));
  }

  /* LinkedIn-Pfeil rutscht nach rechts-oben, wenn der Link gehovered wird. */
  .gruender-link:hover .gruender-link-arrow {
    transform: translate(2px, -2px);
  }
</style>
