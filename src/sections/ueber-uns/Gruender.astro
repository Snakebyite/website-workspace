---
// Gründer-Section — kompakte 2-Card-Ansicht von Kevin und Luca
// Kevin links, Luca rechts (Kevin-first als Erstkontakt im Sales-Call)
import { Image } from "astro:assets";
import { ArrowUpRight } from "@lucide/astro";
import kevinPhoto from "../../assets/kevin-ueber-uns.jpg";
import lucaPhoto from "../../assets/luca-ueber-uns.jpeg";

// TODO: echte LinkedIn-URLs einsetzen
const kevinLinkedIn = "#";
const lucaLinkedIn = "#";
---

<section class="py-10 md:py-14" data-gruender>
  <div class="mx-auto max-w-5xl px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 items-stretch">

      <!-- Kevin -->
      <article class="rounded-2xl overflow-hidden bg-surface flex flex-col" data-gruender-card>
        <div class="relative h-[340px] md:h-[400px] shrink-0 overflow-hidden" data-gruender-photo>
          <Image
            src={kevinPhoto}
            alt="Kevin, Co-Founder von Telos"
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, 40vw"
            class="w-full h-full object-cover object-[center_25%]"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
            <h2 class="font-serif text-2xl md:text-3xl tracking-[-0.02em] text-text-primary">
              Kevin
            </h2>
            <p class="mt-1.5 text-[11px] font-medium tracking-[0.08em] uppercase text-text-secondary">
              Co-Founder
            </p>
          </div>
        </div>

        <div class="p-5 md:p-6 flex flex-col flex-1">
          <p class="font-serif italic text-lg md:text-xl tracking-[-0.01em] leading-snug text-text-primary">
            Spezialist für digitale Marktplätze.
          </p>
          <p class="mt-3 text-[14px] md:text-[15px] text-text-secondary leading-relaxed">
            Seit über sieben Jahren arbeite ich mit digitalen Marktplätzen, vor allem Amazon. In Bachelor- und Masterarbeit habe ich den Algorithmus und die Mechanik hinter organischer Sichtbarkeit erforscht. Dieses Wissen wende ich täglich an, aus tausenden optimierten Listings statt aus Blogposts.
          </p>
          <a
            href={kevinLinkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto pt-4 inline-flex items-center gap-2 text-sm text-accent-text hover:underline underline-offset-4 transition-colors self-start"
          >
            Finde mich auf LinkedIn
            <ArrowUpRight class="w-4 h-4" aria-hidden="true" />
          </a>
        </div>
      </article>

      <!-- Luca -->
      <article class="rounded-2xl overflow-hidden bg-surface flex flex-col" data-gruender-card>
        <div class="relative h-[340px] md:h-[400px] shrink-0 overflow-hidden" data-gruender-photo>
          <Image
            src={lucaPhoto}
            alt="Luca, Co-Founder von Telos"
            widths={[400, 600, 800, 1000]}
            sizes="(max-width: 768px) 100vw, 40vw"
            class="w-full h-full object-cover object-[center_39%] scale-[1.2] origin-top"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/40 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
            <h2 class="font-serif text-2xl md:text-3xl tracking-[-0.02em] text-text-primary">
              Luca
            </h2>
            <p class="mt-1.5 text-[11px] font-medium tracking-[0.08em] uppercase text-text-secondary">
              Co-Founder
            </p>
          </div>
        </div>

        <div class="p-5 md:p-6 flex flex-col flex-1">
          <p class="font-serif italic text-lg md:text-xl tracking-[-0.01em] leading-snug text-text-primary">
            Spezialist für Prozesse und KI.
          </p>
          <p class="mt-3 text-[14px] md:text-[15px] text-text-secondary leading-relaxed">
            Bei Porsche, Mercedes und Allianz habe ich tiefe Einblicke bekommen, wie Konzerne funktionieren und ihre Prozesse aufgebaut sind. Für mich war das aber zu langsam und ich hatte zu wenig Spielraum für die Themen, die mich wirklich interessieren und echten Impact schaffen. Also habe ich mich entschieden zu gründen.
          </p>
          <a
            href={lucaLinkedIn}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto pt-4 inline-flex items-center gap-2 text-sm text-accent-text hover:underline underline-offset-4 transition-colors self-start"
          >
            Finde mich auf LinkedIn
            <ArrowUpRight class="w-4 h-4" aria-hidden="true" />
          </a>
        </div>
      </article>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const section = document.querySelector("[data-gruender]");
  if (section) {
    const cards = section.querySelectorAll("[data-gruender-card]");

    cards.forEach((card, i) => {
      gsap.set(card, { opacity: 0, y: 30 });
      gsap.to(card, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        delay: i * 0.12,
        ease: "power2.out",
        scrollTrigger: {
          trigger: card,
          start: "top 85%",
          once: true,
        },
      });
    });
  }
</script>
