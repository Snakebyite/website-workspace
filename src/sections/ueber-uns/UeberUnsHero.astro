---
// Über-uns Hero — Split layout: Headline left, Duo-Photo right
// Bigger photo (6 cols) for more visual presence
import { Image } from "astro:assets";
import duoPhoto from "../../assets/luca-kevin-ueber-uns.jpg";
---

<section class="pt-32 md:pt-section pb-16 md:pb-20" data-ueber-hero>
  <div class="mx-auto max-w-7xl px-4 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">

      <!-- Left: Headline -->
      <div class="lg:col-span-5">
        <h1 class="text-[2rem] sm:text-[2.75rem] md:text-[3.75rem] lg:text-[4.5rem] tracking-normal" data-ueber-hero-h1>
          Wir haben zu viele Brands gesehen, die bei Agenturen nur eine Kundennummer waren.
        </h1>
      </div>

      <!-- Right: Duo Photo — bigger, asymmetric 5/7 split with accent glow -->
      <div class="lg:col-span-7">
        <div
          class="relative rounded-2xl overflow-hidden"
          data-ueber-hero-photo
          style="box-shadow: 0 0 140px 10px rgba(76, 175, 130, 0.18), 0 30px 70px -20px rgba(0, 0, 0, 0.5);"
        >
          <Image
            src={duoPhoto}
            alt="Luca und Kevin, Gründer von KFL Consulting"
            widths={[400, 600, 900, 1200, 1400]}
            sizes="(max-width: 1024px) 100vw, 58vw"
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-ueber-hero]");
  if (section) {
    const h1 = section.querySelector("[data-ueber-hero-h1]");
    const photo = section.querySelector("[data-ueber-hero-photo]");

    const tl = gsap.timeline({ delay: 0.3 });

    if (h1) {
      const split = new SplitText(h1, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });
      tl.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
      });
    }

    if (photo) {
      gsap.set(photo, { opacity: 0, y: 20 });
      tl.to(photo, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: "power2.out",
      }, "-=0.4");
    }
  }
</script>
