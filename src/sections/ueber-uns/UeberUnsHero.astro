---
// Über-uns Hero — Wide-Photo-Layout, komplett im ersten Viewport.
// Struktur: Headline oben, breites Foto mittig, Lead-Satz, Story 3-spaltig.
import { Image } from "astro:assets";
import heroBild from "../../assets/ueber-uns/gleiches-bild-wie-hero-startseite-4160x2773.jpeg";
---

<section
  class="-mt-36 md:-mt-48 pt-24 md:pt-28 pb-8 md:pb-10 min-h-dvh flex flex-col"
  data-ueber-hero
>
  <div class="mx-auto max-w-7xl px-4 md:px-8 w-full flex-1 flex flex-col">

    <!-- Headline-Block -->
    <div class="max-w-4xl">
      <span class="block text-xs font-medium tracking-[0.08em] uppercase text-accent-text mb-3" data-ueber-hero-overline>
        Über uns
      </span>

      <h1 class="text-4xl sm:text-5xl md:text-[3.25rem] leading-[1.05] tracking-normal" data-ueber-hero-h1>
        Warum es uns gibt.
      </h1>
    </div>

    <!-- Wide Hero-Photo (gesplittet: links Luca, rechts Kevin)
         Justier-Parameter --img-y-luca / --img-y-kevin (0% oben, 100% unten)
         und --split-gap. Werte mobile vs. desktop im <style>-Block unten. -->
    <div
      class="mt-5 md:mt-6"
      data-ueber-hero-image
    >
      <div
        class="relative rounded-2xl"
        style="box-shadow: 0 0 160px 8px rgba(76, 175, 130, 0.10);"
      >
        <div
          class="flex rounded-2xl overflow-hidden h-[28vh] md:h-[44vh] min-h-[200px] md:min-h-[240px] max-h-[520px]"
          data-ueber-hero-image-inner
          style="gap: var(--split-gap);"
        >
          <!-- Linke Hälfte: Luca -->
          <div class="relative flex-1 overflow-hidden">
            <div
              class="absolute inset-y-0 w-[260%] md:w-[200%] h-full"
              style="left: calc(0% - var(--img-x-luca));"
            >
              <Image
                src={heroBild}
                alt="Luca, Mitgründer von Telos"
                widths={[800, 1280, 1600, 2000]}
                sizes="(max-width: 767px) 130vw, (max-width: 1280px) 100vw, 1280px"
                class="w-full h-full object-cover block"
                style="object-position: 0% var(--img-y-luca);"
                loading="eager"
              />
            </div>
          </div>

          <!-- Rechte Hälfte: Kevin -->
          <div class="relative flex-1 overflow-hidden">
            <div
              class="absolute inset-y-0 w-[260%] md:w-[200%] h-full"
              style="right: calc(0% - var(--img-x-kevin));"
            >
              <Image
                src={heroBild}
                alt="Kevin, Mitgründer von Telos"
                widths={[800, 1280, 1600, 2000]}
                sizes="(max-width: 767px) 130vw, (max-width: 1280px) 100vw, 1280px"
                class="w-full h-full object-cover block"
                style="object-position: 100% var(--img-y-kevin);"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lead-Satz -->
    <p
      class="mt-6 md:mt-8 max-w-4xl text-xl md:text-2xl leading-[1.3] tracking-[-0.01em] text-text-primary"
      data-ueber-hero-lead
    >
      Wir haben zu viele Brands gesehen, die bei Agenturen nur eine Kundennummer waren.
    </p>

    <!-- Story-Block: 3 Spalten, Overlines + Bodies jeweils auf gleicher Höhe via subgrid.
         mt-auto drückt den Block an den unteren Viewport-Rand. -->
    <div
      class="mt-auto pt-8 md:pt-12 grid grid-cols-1 md:grid-cols-3 md:grid-rows-[auto_1fr] gap-x-6 md:gap-x-12 gap-y-8 md:gap-y-2"
      data-ueber-hero-story
    >

      <div class="story-col md:row-span-2 md:grid md:grid-rows-subgrid md:gap-y-3" data-ueber-hero-story-col>
        <span class="story-col-overline block text-xs font-medium tracking-[0.08em] uppercase text-accent-text">
          01 · Wie wir uns kennengelernt haben
        </span>
        <p class="text-[15px] md:text-base text-text-secondary leading-relaxed">
          Wir haben uns im Master kennengelernt. Kevin war bereits seit Jahren als Freelancer im E-Commerce unterwegs und hat einen Partner gesucht, um das Ganze zu skalieren. Schnell haben wir gemerkt, wie gut sich unsere Stärken ergänzen.
        </p>
      </div>

      <div class="story-col md:row-span-2 md:grid md:grid-rows-subgrid md:gap-y-3" data-ueber-hero-story-col>
        <span class="story-col-overline block text-xs font-medium tracking-[0.08em] uppercase text-accent-text">
          02 · Warum wir KFL gegründet haben
        </span>
        <p class="text-[15px] md:text-base text-text-secondary leading-relaxed">
          Aus Kevins Erfahrung im Feld wussten wir früh: Die meisten Agenturen und Freelancer arbeiten anders, als wir es für richtig halten. Diese Chance haben wir genutzt und KFL gegründet.
        </p>
      </div>

      <div class="story-col md:row-span-2 md:grid md:grid-rows-subgrid md:gap-y-3" data-ueber-hero-story-col>
        <span class="story-col-overline block text-xs font-medium tracking-[0.08em] uppercase text-accent-text">
          03 · Wo wir heute stehen
        </span>
        <p class="text-[15px] md:text-base text-text-secondary leading-relaxed">
          Seit 2024 sind wir im E-Commerce unterwegs, mit der gleichen Energie wie am ersten Tag. Jede Brand, die wir nehmen, bekommt unsere volle Bandbreite, deshalb arbeiten wir bewusst mit wenigen.
        </p>
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-ueber-hero]");
  if (section) {
    const overline = section.querySelector("[data-ueber-hero-overline]");
    const h1 = section.querySelector("[data-ueber-hero-h1]");
    const image = section.querySelector("[data-ueber-hero-image-inner]");
    const lead = section.querySelector("[data-ueber-hero-lead]");
    const storyCols = section.querySelectorAll("[data-ueber-hero-story-col]");

    // Intro timeline — alles Above-the-fold kommt choreografiert beim Laden rein.
    const introTl = gsap.timeline({ delay: 0.15 });

    if (overline) {
      gsap.set(overline, { opacity: 0, y: 12 });
      introTl.to(overline, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
      });
    }

    if (h1) {
      const split = new SplitText(h1, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });
      introTl.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
      }, "-=0.2");
    }

    if (image) {
      gsap.set(image, { clipPath: "inset(0 100% 0 0)" });
      introTl.to(image, {
        clipPath: "inset(0 0% 0 0)",
        duration: 0.9,
        ease: "power2.inOut",
      }, "-=0.3");
    }

    const belowEls: Element[] = [];
    if (lead) belowEls.push(lead);
    storyCols.forEach((col) => belowEls.push(col));
    if (belowEls.length) {
      gsap.set(belowEls, { opacity: 0, y: 18 });
      introTl.to(belowEls, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.06,
        ease: "power2.out",
      }, "-=0.4");
    }
  }
</script>

<style>
  /* Hero-Bild: vertikale Justierung der beiden Hälften.
     Mobile: Inner-Container ist breiter (w-260%) → vertikaler Crop möglich,
     daher braucht Kevin einen stärkeren Y-Shift, damit die Köpfe gleich hoch
     sitzen. Desktop-Werte unverändert. */
  [data-ueber-hero-image] {
    --img-y-luca: 0%;
    --img-y-kevin: 33%;
    --img-x-luca: 30%;
    --img-x-kevin: 35%;
    --split-gap: 0px;
  }

  @media (min-width: 768px) {
    [data-ueber-hero-image] {
      --img-y-luca: 0%;
      --img-y-kevin: 17%;
      --img-x-luca: 0%;
      --img-x-kevin: 0%;
      --split-gap: 0px;
    }
  }

  /* Story-Spalten: Accent-Bar unter Overline wächst beim Hover der Spalte. */
  .story-col-overline {
    position: relative;
    padding-bottom: 0.625rem;
  }

  .story-col-overline::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 1.5rem;
    border-radius: 9999px;
    background-color: rgba(76, 175, 130, 0.35);
    transition: width 0.4s ease-out, background-color 0.3s ease;
  }

  .story-col:hover .story-col-overline::after {
    width: 3rem;
    background-color: rgba(76, 175, 130, 1);
  }
</style>
