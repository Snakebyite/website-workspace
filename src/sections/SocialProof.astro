---
// Social Proof Section — Homepage
// Job: Konkretes Vertrauen durch echte Ergebnisse. "Proof Stage."
// Komposition: Drei Case Studies untereinander, alternierender Rhythmus (Video L/R).
// Jede Case zeigt Problem + Lösungsansatz + KPIs — nicht nur Zahlen ohne Kontext.
// Ziel: Wiedererkennung. Der Besucher soll sich in mindestens einem Problem wiederfinden.
import { Play, ArrowRight } from '@lucide/astro';

const calendlyUrl =
  "https://calendly.com/kflconsulting/kennenlernen?hide_event_type_details=1&hide_gdpr_banner=1&background_color=0a0a0a&text_color=efefef&primary_color=4caf82";

const caseStudies = [
  {
    id: 'sailfish',
    name: 'Sailfish',
    problem:
      'Der Amazon-Umsatz stagnierte trotz starker Marke. Amazon wurde intern nur als kleiner Nebenkanal betrachtet.',
    solution:
      'Wir haben Amazon als Wachstumsmotor neu aufgesetzt: saubere Listings, profitabel skalierte Ads und ein Webshop, der vom Marketplace-Traffic mitzieht statt übergangen zu werden. Das Ergebnis sind 300 % Umsatzwachstum über alle Marktplätze.',
    heroKpi: { value: '+300%', label: 'Umsatzwachstum auf Amazon' },
    kpis: [
      { value: '>5', label: 'ROAS' },
      { value: '>10%', label: 'Spill-Over auf Webshop' },
    ],
    videoId: 'xkrqYY4dpMI',
    thumbnail: '/case-studies/sailfish-thumbnail.png',
  },
  {
    id: 'vaud',
    name: 'VAUD',
    problem:
      'Aufgrund des starken Wettbewerbs innerhalb der Supplement-Kategorie blieb der Umsatz in Deutschland hinter den Erwartungen.',
    solution:
      'SEO und Listing-Optimierung für den deutschen Markt aufgesetzt. Keywords recherchiert, Content für Ranking und Conversion optimiert. Das Ergebnis sind 50 % mehr Deckungsbeitrag bei gleichzeitig steigender Conversion Rate.',
    heroKpi: { value: '+50%', label: 'Mehr Deckungsbeitrag' },
    kpis: [
      { value: '+9%', label: 'Conversion Rate' },
      { value: '+40%', label: 'Sales' },
    ],
    videoId: 'bzZ02fvN1Co',
    thumbnail: '/case-studies/vaud-thumbnail.png',
  },
  {
    id: 'heaven-paper',
    name: 'Heaven+Paper',
    problem:
      'Die Abhängigkeit von Paid Ads wurde immer größer, während organisch kaum etwas rankte. Gleichzeitig blieb das Potenzial auf weiteren Marktplätzen ungenutzt.',
    solution:
      'Wir haben eine organische SEO Basis auf die Keywordwurzeln der Kategorie aufgesetzt und dabei alle Low Hanging Fruits mitgenommen. Parallel haben wir den Vertrieb auf Otto, Kaufland und eBay erweitert, zentral steuerbar aus dem Shopify Store und einem Dashboard. Das Ergebnis: 100 % mehr Umsatz in acht Wochen und Sichtbarkeit, die sich selbst trägt.',
    heroKpi: { value: '+100%', label: 'Umsatz in 8 Wochen' },
    kpis: [
      { value: '+35%', label: 'Organischer Umsatzanteil' },
      { value: '+68%', label: 'Mehr Deckungsbeitrag' },
    ],
    videoId: '7jrj0cesPrA',
    thumbnail: '/case-studies/heaven-paper-thumbnail.png',
  },
];
---

<section id="referenzen" class="py-20 md:py-32 scroll-mt-24" data-socialproof>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Headline -->
    <h2 class="max-w-3xl">Was passiert, wenn man es richtig angeht.</h2>

    <!-- Cases — gestapelt, alternierend -->
    <div class="mt-16 md:mt-24 flex flex-col gap-20 md:gap-28">
      {caseStudies.map((cs, i) => {
        const videoLeft = i % 2 === 0;
        return (
          <article data-case class="bg-surface border border-white/10 rounded-2xl p-5 md:bg-transparent md:border-0 md:rounded-none md:p-0">
            <!-- Video + Text -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 items-start">
              <!-- Video + KPIs (KPIs folgen der Videoseite) -->
              <div class:list={[
                'lg:col-span-7 flex flex-col gap-7 md:gap-8',
                videoLeft ? 'lg:order-1' : 'lg:order-2',
              ]}>
                <div class="relative rounded-xl overflow-hidden bg-surface aspect-video" data-video-container={cs.id}>
                  <img
                    src={cs.thumbnail}
                    alt={`Case Study: ${cs.name}`}
                    class="absolute inset-0 w-full h-full object-cover"
                    loading="lazy"
                  />
                  <button
                    class="absolute inset-0 w-full h-full flex items-center justify-center group cursor-pointer bg-black/30 hover:bg-black/20 transition-colors duration-200"
                    data-video-trigger={cs.id}
                    aria-label={`Video abspielen: ${cs.name}`}
                  >
                    <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-colors duration-200 backdrop-blur-sm">
                      <Play class="w-6 h-6 text-text-primary ml-0.5" />
                    </div>
                  </button>
                </div>

                <!-- KPIs — zentriert unter Video, gleichmäßiges Spacing -->
                <div class="grid grid-cols-3 text-center">
                  {[cs.heroKpi, ...cs.kpis].map((kpi) => (
                    <div>
                      <span class="font-body block text-2xl md:text-3xl lg:text-4xl font-bold tracking-tight text-text-primary">{kpi.value}</span>
                      <span class="font-body block text-xs md:text-sm text-text-muted mt-1.5 leading-tight">{kpi.label}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Text -->
              <div class:list={[
                'lg:col-span-5 flex flex-col gap-7 md:gap-8',
                videoLeft ? 'lg:order-2' : 'lg:order-1',
              ]}>
                <div>
                  <span class="font-body text-xs font-medium tracking-[0.08em] uppercase text-text-muted">Problem</span>
                  <p class="font-body text-lg md:text-xl text-text-primary mt-3 leading-relaxed">{cs.problem}</p>
                </div>
                <div>
                  <span class="font-body text-xs font-medium tracking-[0.08em] uppercase text-text-muted">Lösungsansatz</span>
                  <p class="font-body text-lg md:text-xl text-text-primary mt-3 leading-relaxed">{cs.solution}</p>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <!-- Section CTA -->
    <div class="mt-20 md:mt-28" data-cta>
      <div class="flex flex-col items-center text-center max-w-2xl mx-auto">
        <p class="text-text-primary text-lg md:text-xl leading-relaxed" data-cta-subline>
          Wenn du einschätzen willst, ob das auch für deine Marke funktioniert, lass uns sprechen.
        </p>
        <div class="relative mt-6" data-cta-button>
          <span class="cta-glow" aria-hidden="true"></span>
          <a
            href={calendlyUrl}
            target="_blank"
            rel="noopener"
            data-calendly-trigger
            class="group relative inline-flex items-center gap-2 text-accent-text font-medium transition-colors duration-200 hover:text-text-primary"
          >
            <span class="border-b border-transparent group-hover:border-current transition-colors duration-200">Kurzes Gespräch vereinbaren</span>
            <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<link
  is:inline
  rel="stylesheet"
  href="https://assets.calendly.com/assets/external/widget.css"
/>
<script
  is:inline
  async
  src="https://assets.calendly.com/assets/external/widget.js"></script>

<style>
  .cta-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 320px;
    height: 320px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle at center,
      rgba(76, 175, 130, 0.22) 0%,
      rgba(76, 175, 130, 0.1) 35%,
      rgba(76, 175, 130, 0) 70%
    );
    filter: blur(40px);
    opacity: 0.8;
    pointer-events: none;
    z-index: 0;
    animation: cta-glow-pulse 6s ease-in-out infinite;
    transition: opacity 400ms ease, transform 400ms ease;
  }

  [data-cta-button]:hover .cta-glow {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.08);
  }

  @keyframes cta-glow-pulse {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 0.95;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
    }
  }
</style>

<script>
  // Calendly Popup — gleicher Mechanismus wie auf /ueber-uns
  interface CalendlyAPI {
    initPopupWidget: (options: { url: string }) => void;
  }
  const w = window as typeof window & { Calendly?: CalendlyAPI };

  const calendlyTrigger = document.querySelector<HTMLAnchorElement>(
    "[data-socialproof] [data-calendly-trigger]",
  );
  if (calendlyTrigger) {
    calendlyTrigger.addEventListener("click", (e) => {
      if (!w.Calendly) return; // Fallback: Link öffnet in neuem Tab
      e.preventDefault();
      w.Calendly.initPopupWidget({ url: calendlyTrigger.href });
    });
  }

  // Video Embed — Klick auf Play lädt YouTube iframe
  function initVideoTriggers() {
    const videoUrls: Record<string, string> = {
      'sailfish': 'https://www.youtube.com/embed/xkrqYY4dpMI?autoplay=1&rel=0',
      'vaud': 'https://www.youtube.com/embed/bzZ02fvN1Co?autoplay=1&rel=0',
      'heaven-paper': 'https://www.youtube.com/embed/7jrj0cesPrA?autoplay=1&rel=0',
    };

    document.querySelectorAll<HTMLButtonElement>('[data-video-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.videoTrigger;
        if (!id) return;
        const url = videoUrls[id];
        if (!url) return;

        const container = document.querySelector<HTMLElement>(`[data-video-container="${id}"]`);
        if (!container) return;

        container.innerHTML = `<iframe src="${url}" class="absolute inset-0 w-full h-full" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
      });
    });
  }

  initVideoTriggers();

  // --- Scroll Animations ---
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-socialproof]");
  if (section) {
    const h2 = section.querySelector("h2");
    const cases = section.querySelectorAll<HTMLElement>("[data-case]");
    const ctaArea = section.querySelector<HTMLElement>("[data-cta]");

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // Case entrances — fade + rise
    cases.forEach((el) => {
      gsap.set(el, { opacity: 0, y: 40 });
      gsap.to(el, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: "power2.out",
        scrollTrigger: {
          trigger: el,
          start: "top 80%",
          once: true,
        },
      });
    });

    // CTA area — subline + link fade
    if (ctaArea) {
      const ctaSubline = ctaArea.querySelector<HTMLElement>("[data-cta-subline]");
      const ctaButton = ctaArea.querySelector<HTMLElement>("[data-cta-button]");

      const fadeItems = [ctaSubline, ctaButton].filter(Boolean) as Element[];
      if (fadeItems.length) {
        gsap.set(fadeItems, { opacity: 0, y: 20 });
        gsap.to(fadeItems, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          stagger: 0.1,
          ease: "power2.out",
          scrollTrigger: { trigger: ctaSubline ?? ctaArea, start: "top 85%", once: true },
        });
      }
    }
  }
</script>
