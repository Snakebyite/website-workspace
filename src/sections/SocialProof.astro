---
// Social Proof Section — Homepage
// Job: Konkretes Vertrauen durch echte Ergebnisse. "Proof Stage."
// Komposition: Browser-Frame mit Tabs im Chrome — alles in einem Viewport.
// Video 16:9 oben als Hauptelement, KPIs darunter als kompakte Zeile.
// Im Frame: nur Satoshi, Hierarchie über Farbe/Größe/Gewicht.
// Background: surface (#141414) — bewusster Tonal Shift.
import { Play } from '@lucide/astro';
const caseStudies = [
  {
    id: 'sailfish',
    name: 'Sailfish',
    heroKpi: { value: '+250%', label: 'Umsatzwachstum auf Amazon' },
    kpis: [
      { value: '>5', label: 'ROAS' },
      { value: '>10%', label: 'Spill-Over auf Webshop' },
    ],
    videoId: 'xkrqYY4dpMI',
    thumbnail: 'https://i.ytimg.com/vi/xkrqYY4dpMI/hqdefault.jpg',
    hasVideo: true,
  },
  {
    id: 'vaud',
    name: 'VAUD',
    heroKpi: { value: '+50%', label: 'Deckungsbeitrag' },
    kpis: [
      { value: '+9%', label: 'Conversion Rate' },
      { value: '+20%', label: 'Sales' },
    ],
    videoId: 'bzZ02fvN1Co',
    thumbnail: 'https://i.ytimg.com/vi/bzZ02fvN1Co/hqdefault.jpg',
    hasVideo: true,
  },
  {
    id: 'heaven-paper',
    name: 'Heaven+Paper',
    heroKpi: { value: '+100%', label: 'Umsatz in 8 Wochen' },
    kpis: [
      { value: '+35%', label: 'Organischer Umsatzanteil' },
      { value: '70%', label: 'Org. Umsatz bei Top-Artikeln' },
    ],
    videoId: '7jrj0cesPrA',
    thumbnail: 'https://i.ytimg.com/vi/7jrj0cesPrA/hqdefault.jpg',
    hasVideo: true,
  },
];
---

<section id="referenzen" class="py-20 md:py-32 scroll-mt-24" data-socialproof>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Headline -->
    <h2 class="max-w-3xl">Was passiert, wenn man es richtig angeht.</h2>

    <!-- Browser Frame -->
    <div class="mt-12 md:mt-16 bg-background rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.3)]">

      <!-- Browser Chrome mit Tabs -->
      <div class="bg-surface-elevated px-5 py-3 flex items-center gap-4">
        <!-- Window Dots -->
        <div class="flex gap-1.5 shrink-0">
          <div class="w-2.5 h-2.5 rounded-full bg-text-muted/40"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-text-muted/40"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-text-muted/40"></div>
        </div>

        <!-- Tabs im Chrome -->
        <div
          class="flex gap-1 overflow-x-auto [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
          role="tablist"
          aria-label="Case Studies"
        >
          {caseStudies.map((cs, i) => (
            <button
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${cs.id}`}
              id={`tab-${cs.id}`}
              data-tab={cs.id}
              tabindex={i === 0 ? 0 : -1}
              class:list={[
                'font-body px-4 md:px-5 py-1.5 text-sm font-medium rounded-md transition-colors duration-200 cursor-pointer shrink-0',
                'hover:text-text-primary',
                'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/50',
                i === 0 ? 'text-text-primary bg-white/5' : 'text-text-muted',
              ]}
            >
              {cs.name}
            </button>
          ))}
        </div>
      </div>

      <!-- Panels -->
      {caseStudies.map((cs, i) => (
        <div
          id={`panel-${cs.id}`}
          role="tabpanel"
          aria-labelledby={`tab-${cs.id}`}
          data-panel={cs.id}
          class:list={[
            'p-5 md:p-10 md:pb-14',
            i !== 0 && 'hidden',
          ]}
        >
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8 items-center">

            <!-- Video links — 16:9, nicht full-width -->
            <div class="lg:col-span-7">
              <div class="relative rounded-xl overflow-hidden bg-surface-elevated aspect-video" data-video-container={cs.id}>
                {cs.hasVideo && cs.thumbnail ? (
                  <Fragment>
                    <img
                      src={cs.thumbnail}
                      alt={`Case Study: ${cs.name}`}
                      class="absolute inset-0 w-full h-full object-cover"
                      loading="lazy"
                    />
                    <button
                      class="absolute inset-0 w-full h-full flex items-center justify-center group cursor-pointer bg-black/30 hover:bg-black/20 transition-colors duration-200"
                      data-video-trigger={cs.id}
                      aria-label={`Video abspielen: ${cs.name}`}
                    >
                      <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-white/20 transition-colors duration-200 backdrop-blur-sm">
                        <Play class="w-6 h-6 text-text-primary ml-0.5" />
                      </div>
                    </button>
                  </Fragment>
                ) : cs.thumbnail ? (
                  <img
                    src={cs.thumbnail}
                    alt={`Case Study: ${cs.name}`}
                    class="absolute inset-0 w-full h-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="font-body text-sm text-text-muted">Case Study</span>
                  </div>
                )}
              </div>
            </div>

            <!-- KPIs rechts — gleiche Gewichtung, vertikal -->
            <div class="lg:col-span-5 flex flex-col gap-7 md:gap-9">
              {[cs.heroKpi, ...cs.kpis].map((kpi) => (
                <div>
                  <span class="font-body block text-2xl md:text-3xl font-bold tracking-tight text-text-primary">{kpi.value}</span>
                  <span class="font-body block text-xs md:text-sm text-text-muted mt-1">{kpi.label}</span>
                </div>
              ))}
            </div>

          </div>
        </div>
      ))}

    </div>

    <!-- Section CTA -->
    <div class="mt-12 md:mt-16 flex flex-col sm:flex-row justify-center items-center gap-6">
      <a
        href="/kontakt"
        class="inline-block bg-accent hover:bg-accent-hover text-background font-medium px-8 py-4 rounded-button tracking-[0.01em] leading-none transition-colors duration-200"
      >
        Termin buchen
      </a>
      <a
        href="/referenzen"
        class="text-accent-text hover:underline font-medium transition-colors duration-200"
      >
        Alle Ergebnisse ansehen &rarr;
      </a>
    </div>

  </div>
</section>

<script>
  function initSocialProofTabs() {
    const tablist = document.querySelector('[aria-label="Case Studies"]');
    if (!tablist) return;

    const tabs = tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]');
    const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"]');

    function activateTab(targetTab: HTMLButtonElement) {
      const targetId = targetTab.dataset.tab;
      if (!targetId) return;

      tabs.forEach((t) => {
        const isActive = t.dataset.tab === targetId;
        t.setAttribute('aria-selected', String(isActive));
        t.setAttribute('tabindex', isActive ? '0' : '-1');
        t.classList.toggle('text-text-primary', isActive);
        t.classList.toggle('text-text-muted', !isActive);
        t.classList.toggle('bg-white/5', isActive);
      });

      panels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.dataset.panel !== targetId);
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateTab(tab));
    });

    tablist.addEventListener('keydown', (e) => {
      const tabArray = Array.from(tabs);
      const currentIndex = tabArray.findIndex(t => t.getAttribute('aria-selected') === 'true');
      let newIndex = currentIndex;

      if (e.key === 'ArrowRight') {
        newIndex = (currentIndex + 1) % tabArray.length;
      } else if (e.key === 'ArrowLeft') {
        newIndex = (currentIndex - 1 + tabArray.length) % tabArray.length;
      } else if (e.key === 'Home') {
        newIndex = 0;
      } else if (e.key === 'End') {
        newIndex = tabArray.length - 1;
      } else {
        return;
      }

      e.preventDefault();
      activateTab(tabArray[newIndex]);
      tabArray[newIndex].focus();
    });
  }

  // Video Embed — Klick auf Play lädt YouTube/Canva iframe
  function initVideoTriggers() {
    const videoUrls: Record<string, string> = {
      'sailfish': 'https://www.youtube.com/embed/xkrqYY4dpMI?autoplay=1&rel=0',
      'vaud': 'https://www.youtube.com/embed/bzZ02fvN1Co?autoplay=1&rel=0',
      'heaven-paper': 'https://www.youtube.com/embed/7jrj0cesPrA?autoplay=1&rel=0',
    };

    document.querySelectorAll<HTMLButtonElement>('[data-video-trigger]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.videoTrigger;
        if (!id) return;
        const url = videoUrls[id];
        if (!url) return;

        const container = document.querySelector<HTMLElement>(`[data-video-container="${id}"]`);
        if (!container) return;

        container.innerHTML = `<iframe src="${url}" class="absolute inset-0 w-full h-full" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
      });
    });
  }

  initSocialProofTabs();
  initVideoTriggers();

  // --- Scroll Animations ---
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-socialproof]");
  if (section) {
    const h2 = section.querySelector("h2");
    const browserFrame = section.querySelector(".bg-background.rounded-2xl");
    const ctaArea = section.querySelector(".flex.justify-center");

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // Browser frame entrance — scale + fade
    if (browserFrame) {
      gsap.set(browserFrame, { opacity: 0, y: 40, scale: 0.97 });

      gsap.to(browserFrame, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: browserFrame,
          start: "top 80%",
          once: true,
        },
      });
    }

    // CTA area fade-in
    if (ctaArea) {
      gsap.set(ctaArea, { opacity: 0, y: 20 });

      gsap.to(ctaArea, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ctaArea,
          start: "top 90%",
          once: true,
        },
      });
    }
  }
</script>
