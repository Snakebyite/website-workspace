---
// Testimonials Section — Homepage
// Job: Bestätigung durch echte Kundenstimmen. Atempause zwischen Trust und CTA.
// Layout: Links ausgerichtete Pyramide — gleicher Startpunkt, abnehmende max-width.
// Alle Quotes in Satoshi (font-body) — matched mit Problem/Lösungsansatz-Copy in SocialProof.
// Density: NIEDRIG — das Zitat ist das Visual.
// Background: default (#0A0A0A)

const testimonials = [
  {
    quote: '„Ihr habt uns wirklich entscheidend nach vorne gebracht. Und das sage ich nicht, weil ich es sagen muss, sondern weil ich es sagen will."',
    name: 'Jan Sibbersen',
    role: 'CEO & Gründer, sailfish',
    photo: '/testimonials/jan-sibbersen.png',
  },
  {
    quote: '„Während mein Umsatz um 14,1% zulegen konnte, hat sich mein Gewinn um 68,4% gesteigert. Dass die Agentur hält, was sie beim Thema organisches Wachstum verspricht, steht außer Frage."',
    name: 'Stefanie Eusemann',
    role: 'CEO & Gründerin, Heaven+Paper',
    photo: '/testimonials/stefanie-eusemann.png',
  },
  {
    quote: '„Absoluter Profi, was Amazon angeht.\n100% Empfehlung."',
    name: 'Marius Klein',
    role: 'CEO & Gründer, Arider',
    photo: '/testimonials/marius-klein.png',
  },
  {
    quote: '„Wir arbeiten mit Kevin und seinem Team nun seit knapp 18 Monaten zusammen und ich kann meine wärmste Empfehlung aussprechen. Durch unsere Zusammenarbeit konnten wir unseren Absatz auf den Marktplätzen verdoppeln und dabei unseren Produkt, Bestellungs und Bestandspflegeprozess halbieren. Was ein grandioser Deal."',
    name: 'Matthias Buchkärt',
    role: 'Co-Gründer, Pack & Smooch',
    photo: '/testimonials/matthias-buchkaert.png',
  },
];
---

<section class="py-20 md:py-32" data-testimonials>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <h2 class="max-w-2xl mb-12 md:mb-16">Echte Kundenstimmen.</h2>

    {testimonials.map((t, i) => (
      <blockquote class:list={["max-w-4xl", i > 0 && "mt-12 md:mt-16"]}>
        <p class="font-body font-normal text-xl md:text-2xl leading-relaxed text-text-primary whitespace-pre-line">
          {t.quote}
        </p>
        <footer class="mt-6 flex items-center gap-3">
          <img
            src={t.photo}
            alt={t.name}
            width="80"
            height="80"
            loading="lazy"
            class="w-11 h-11 md:w-12 md:h-12 rounded-lg object-cover bg-surface shrink-0"
          />
          <div class="leading-tight">
            <span class="font-body text-sm text-text-secondary">{t.name}</span>
            <span class="font-body text-sm text-text-muted"> &middot; {t.role}</span>
          </div>
        </footer>
      </blockquote>
    ))}

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const section = document.querySelector("[data-testimonials]");
  if (section) {
    const quotes = section.querySelectorAll("blockquote");

    quotes.forEach((quote) => {
      const text = quote.querySelector("p");
      const footer = quote.querySelector("footer");

      gsap.set([text, footer].filter(Boolean), { opacity: 0, y: 20 });

      gsap.timeline({
        scrollTrigger: {
          trigger: quote,
          start: "top 80%",
          once: true,
        },
      })
        .to(text, {
          opacity: 1,
          y: 0,
          duration: 0.7,
          ease: "power2.out",
        })
        .to(footer, {
          opacity: 1,
          y: 0,
          duration: 0.4,
          ease: "power2.out",
        }, "-=0.3");
    });
  }
</script>
