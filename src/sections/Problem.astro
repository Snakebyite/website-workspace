---
// Problem Section — Homepage
// Job: Spiegeln — "Wir wissen wie dein Alltag aussieht"
// Layout: Headline oben, darunter Dashboard (links) + Pain Points (rechts) bündig
// Kein CTA — Resonanz erzeugen, nächste Section liefert die Antwort
---

<section class="pt-16 pb-24 md:pt-24 md:pb-32" data-problem>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Headline — above the grid -->
    <div class="mb-14 md:mb-20" data-problem-header>
      <h2>Kommt dir das bekannt vor?</h2>
    </div>

    <!-- Content grid: Dashboard left, Pain Points right — top & bottom aligned -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-stretch">

      <!-- Left: Dashboard Visual -->
      <div class="lg:col-span-5 hidden lg:block" data-problem-visual>
        <div class="relative rounded-2xl border border-white/5 bg-surface p-8 md:p-10 overflow-hidden h-full flex flex-col justify-between">
          <!-- Subtle glow -->
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_40%,rgba(239,68,68,0.04)_0%,transparent_70%)] pointer-events-none"></div>

          <!-- Metric 1: Rising ACoS -->
          <div class="relative" data-pv-metric="1">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[13px] font-medium tracking-wider uppercase text-text-muted">ACoS</span>
              <span class="text-[13px] font-medium text-red-400/70">38,4 %</span>
            </div>
            <div class="h-[56px] w-full">
              <svg class="w-full h-full" viewBox="0 0 320 56" fill="none" preserveAspectRatio="none">
                <path
                  class="pv-area"
                  d="M0 46 C40 44, 60 40, 100 36 C140 30, 170 28, 200 22 C230 16, 260 12, 320 6 L320 56 L0 56 Z"
                  fill="rgba(239,68,68,0.06)"
                  style="opacity:0;"
                />
                <path
                  class="pv-line"
                  d="M0 46 C40 44, 60 40, 100 36 C140 30, 170 28, 200 22 C230 16, 260 12, 320 6"
                  stroke="rgba(239,68,68,0.35)"
                  stroke-width="1.5"
                  fill="none"
                  style="opacity:0;"
                />
                <circle class="pv-dot" cx="320" cy="6" r="3.5" fill="rgba(239,68,68,0.6)" style="opacity:0;" />
              </svg>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px bg-white/5 my-7"></div>

          <!-- Metric 2: Platform friction — blocked accounts, rejected listings, rules -->
          <div class="relative" data-pv-metric="2">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[13px] font-medium tracking-wider uppercase text-text-muted">Plattform-Status</span>
              <span class="text-[13px] font-medium text-red-400/70">Kritisch</span>
            </div>
            <div class="space-y-2.5">
              <div class="pv-alert flex items-center gap-3" style="opacity:0;">
                <svg class="w-3.5 h-3.5 text-red-400/70 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                <span class="text-[12px] text-text-muted flex-1 min-w-0 truncate">Account-Status</span>
                <span class="text-[11px] text-red-400/70 shrink-0">Unter Review</span>
              </div>
              <div class="pv-alert flex items-center gap-3" style="opacity:0;">
                <svg class="w-3.5 h-3.5 text-red-400/70 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                <span class="text-[12px] text-text-muted flex-1 min-w-0 truncate">Flat-File abgelehnt</span>
                <span class="text-[11px] text-red-400/70 shrink-0">47 Fehler</span>
              </div>
              <div class="pv-alert flex items-center gap-3" style="opacity:0;">
                <svg class="w-3.5 h-3.5 text-amber-400/70 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                <span class="text-[12px] text-text-muted flex-1 min-w-0 truncate">Support-Ticket</span>
                <span class="text-[11px] text-amber-400/70 shrink-0">14 Tage offen</span>
              </div>
              <div class="pv-alert flex items-center gap-3" style="opacity:0;">
                <svg class="w-3.5 h-3.5 text-amber-400/70 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                <span class="text-[12px] text-text-muted flex-1 min-w-0 truncate">Richtlinien-Update</span>
                <span class="text-[11px] text-amber-400/70 shrink-0">3 neu/Monat</span>
              </div>
            </div>
          </div>

          <!-- Divider -->
          <div class="h-px bg-white/5 my-7"></div>

          <!-- Metric 3: SEO backlog — internal resources missing -->
          <div class="relative" data-pv-metric="3">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[13px] font-medium tracking-wider uppercase text-text-muted">SEO-Aufgaben</span>
              <span class="text-[13px] font-medium text-amber-400/70">Nicht gestartet</span>
            </div>
            <div class="space-y-2.5">
              <div class="pv-task flex items-center gap-3" style="opacity:0;">
                <span class="w-3.5 h-3.5 rounded-[3px] border border-amber-400/30 bg-amber-400/[0.04] shrink-0"></span>
                <span class="text-[12px] text-text-muted flex-1">Keyword-Recherche</span>
                <span class="text-[11px] text-amber-400/60">offen</span>
              </div>
              <div class="pv-task flex items-center gap-3" style="opacity:0;">
                <span class="w-3.5 h-3.5 rounded-[3px] border border-amber-400/30 bg-amber-400/[0.04] shrink-0"></span>
                <span class="text-[12px] text-text-muted flex-1">Listings</span>
                <span class="text-[11px] text-amber-400/60">offen</span>
              </div>
              <div class="pv-task flex items-center gap-3" style="opacity:0;">
                <span class="w-3.5 h-3.5 rounded-[3px] border border-amber-400/30 bg-amber-400/[0.04] shrink-0"></span>
                <span class="text-[12px] text-text-muted flex-1">Content</span>
                <span class="text-[11px] text-amber-400/60">offen</span>
              </div>
              <div class="pv-task flex items-center gap-3" style="opacity:0;">
                <span class="w-3.5 h-3.5 rounded-[3px] border border-amber-400/30 bg-amber-400/[0.04] shrink-0"></span>
                <span class="text-[12px] text-text-muted flex-1">Monitoring</span>
                <span class="text-[11px] text-amber-400/60">offen</span>
              </div>
            </div>
            <div class="mt-5 flex items-center gap-3">
              <span class="text-[12px] text-text-muted/70 shrink-0">Interne Kapazität</span>
              <div class="h-1.5 flex-1 rounded-full bg-white/5 overflow-hidden">
                <div class="pv-capacity h-full rounded-full bg-red-400/50" style="width:0%;"></div>
              </div>
              <span class="text-[11px] text-red-400/70 shrink-0">14 % frei</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Pain statements -->
      <div class="lg:col-span-6 lg:col-start-7 flex flex-col gap-10 lg:gap-12">
        <div class="flex gap-5">
          <span class="shrink-0 flex items-center justify-center w-12 h-12 rounded-xl border border-accent/20 bg-accent/[0.06] text-accent-text text-base font-semibold tracking-wide mt-1">01</span>
          <p class="text-xl md:text-2xl text-text-secondary leading-relaxed">
            Dein ACoS steigt, die <span class="text-accent-text font-medium">Marge schrumpft.</span> Organisch rankst du kaum, also musst du mehr Geld in PPC stecken, wenn du mehr Umsatz willst.
          </p>
        </div>
        <div class="flex gap-5">
          <span class="shrink-0 flex items-center justify-center w-12 h-12 rounded-xl border border-accent/20 bg-accent/[0.06] text-accent-text text-base font-semibold tracking-wide mt-1">02</span>
          <p class="text-xl md:text-2xl text-text-secondary leading-relaxed">
            Gesperrte Accounts ohne Vorwarnung, ständig neue Regeln, abgelehnte Listings, Support-Tickets ohne Antwort. Amazon legt dir <span class="text-accent-text font-medium">Steine in den Weg</span> und kostet Nerven, aber du weißt: An der Plattform kommst du nicht vorbei.
          </p>
        </div>
        <div class="flex gap-5">
          <span class="shrink-0 flex items-center justify-center w-12 h-12 rounded-xl border border-accent/20 bg-accent/[0.06] text-accent-text text-base font-semibold tracking-wide mt-1">03</span>
          <p class="text-xl md:text-2xl text-text-secondary leading-relaxed">
            SEO auf Amazon ist ein eigenes Handwerk: Keyword-Recherche, Listings, Content, Monitoring. Sich neben dem Tagesgeschäft einzuarbeiten, kostet <span class="text-accent-text font-medium">Ressourcen, die intern selten frei sind.</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  function initProblemSection(): void {
    const section = document.querySelector<HTMLElement>("[data-problem]");
    if (!section) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const header = section.querySelector<HTMLElement>("[data-problem-header]");
    const h2 = header?.querySelector<HTMLElement>("h2");
    const painItems = section.querySelectorAll<HTMLElement>(".lg\\:col-span-6 > div");

    if (reduced) {
      section.querySelectorAll("[style*='opacity:0']").forEach(el => {
        (el as HTMLElement).style.opacity = "1";
      });
      const cap = section.querySelector<HTMLElement>(".pv-capacity");
      if (cap) cap.style.width = "86%";
      return;
    }

    const ctx = gsap.context(() => {
      // H2 entrance
      if (h2) {
        const split = new SplitText(h2, { type: "words" });
        gsap.set(split.words, { opacity: 0, y: 20 });

        gsap.to(split.words, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 75%", once: true },
        });
      }

      // Pain statements fade in individually
      painItems.forEach((item) => {
        gsap.set(item, { opacity: 0, y: 20 });
        gsap.to(item, {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: "power2.out",
          scrollTrigger: { trigger: item, start: "top 80%", once: true },
        });
      });

      // ── Dashboard Visual animation ──
      const visual = section.querySelector<HTMLElement>("[data-problem-visual]");
      if (!visual) return;

      gsap.set(visual, { opacity: 0, y: 20, scale: 0.95 });

      const tl = gsap.timeline({
        defaults: { ease: "power2.out" },
        scrollTrigger: { trigger: visual, start: "top 80%", once: true },
      });

      tl.to(visual, { opacity: 1, y: 0, scale: 1, duration: 0.7, ease: "back.out(1.4)" });

      const line = visual.querySelector(".pv-line");
      const area = visual.querySelector(".pv-area");
      const dot = visual.querySelector(".pv-dot");

      if (line) {
        const lineEl = line as SVGPathElement;
        const length = lineEl.getTotalLength();
        gsap.set(lineEl, { strokeDasharray: length, strokeDashoffset: length, opacity: 1 });
        tl.to(lineEl, { strokeDashoffset: 0, duration: 1.2, ease: "power2.inOut" }, "-=0.2");
      }
      if (area) tl.to(area, { opacity: 1, duration: 0.6 }, "-=0.6");
      if (dot) tl.to(dot, { opacity: 1, duration: 0.3, ease: "back.out(2)" }, "-=0.2");

      const alerts = visual.querySelectorAll<HTMLElement>(".pv-alert");
      gsap.set(alerts, { x: -8 });
      tl.to(alerts, { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: "power2.out" }, "-=0.3");

      const tasks = visual.querySelectorAll<HTMLElement>(".pv-task");
      gsap.set(tasks, { x: -8 });
      tl.to(tasks, { opacity: 1, x: 0, duration: 0.4, stagger: 0.08, ease: "power2.out" }, "-=0.3");

      const capacity = visual.querySelector<HTMLElement>(".pv-capacity");
      if (capacity) {
        tl.to(capacity, { width: "86%", duration: 0.9, ease: "power2.out" }, "-=0.2");
      }

      gsap.to(dot, {
        scale: 1.4,
        opacity: 0.3,
        duration: 1.5,
        yoyo: true,
        repeat: -1,
        ease: "sine.inOut",
        delay: 2.5,
        transformOrigin: "center center",
      });

    }, section);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initProblemSection();
  document.addEventListener("astro:after-swap", initProblemSection);
</script>
