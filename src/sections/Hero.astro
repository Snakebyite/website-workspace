---
// Hero Section — Homepage
// Split layout: H1 left (7col), Dashboard visual right (5col)
// Logo band anchored at bottom of viewport
---

<section class="min-h-[calc(100dvh-4rem)] md:min-h-[calc(100dvh-5rem)] flex flex-col relative overflow-hidden">
  <!-- Radial glow behind headline -->
  <div
    class="absolute top-1/3 left-[30%] -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(76, 175, 130, 0.06) 0%, transparent 70%)"
    aria-hidden="true"
  ></div>

  <!-- Main content — vertically centered -->
  <div class="flex-1 flex items-center">
    <div class="mx-auto max-w-7xl px-4 md:px-8 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div class="lg:col-span-7">
          <h1 class="text-[2.75rem] sm:text-[3.25rem] md:text-[3.75rem] lg:text-[4.5rem] tracking-normal">
            Dein <span class="text-accent-text">Best Interest Advisor</span>
            <br class="hidden sm:block" />
            für digitale Marktplätze.
          </h1>
          <p class="text-text-secondary text-lg md:text-xl leading-relaxed mt-8 max-w-lg">
            Wir machen Marktplatz-Wachstum planbar. Datenbasiert, gründergeführt, hands-on.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mt-8">
            <a
              href="/kontakt"
              class="bg-accent hover:bg-accent-hover text-background font-medium px-8 py-4 rounded-button tracking-[0.01em] leading-none transition-colors duration-200 text-center"
            >
              Lern uns kennen
            </a>
            <a
              href="#leistungen"
              class="border border-white/10 hover:border-white/20 text-text-primary font-medium px-8 py-4 rounded-button tracking-[0.01em] leading-none transition-colors duration-200 text-center"
            >
              So arbeiten wir
            </a>
          </div>
        </div>

        <!-- Right: Dashboard placeholder — replace with real screenshot later -->
        <div class="lg:col-span-5">
          <div class="bg-surface rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.3)]" aria-hidden="true">
            <!-- Browser chrome -->
            <div class="bg-surface-elevated px-5 py-3 flex items-center gap-2">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-text-muted/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-text-muted/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-text-muted/40"></div>
              </div>
              <span class="text-xs text-text-muted ml-2">Seller Central</span>
            </div>
            <!-- KPI cards -->
            <div class="p-5 space-y-4">
              <div class="grid grid-cols-3 gap-3">
                <div class="bg-surface-elevated rounded-lg p-3">
                  <span class="text-[11px] text-text-muted">Umsatz</span>
                  <p class="text-base md:text-lg font-medium mt-1">€47.2k</p>
                  <span class="text-[11px] text-accent-text">+24%</span>
                </div>
                <div class="bg-surface-elevated rounded-lg p-3">
                  <span class="text-[11px] text-text-muted">Sessions</span>
                  <p class="text-base md:text-lg font-medium mt-1">12.4k</p>
                  <span class="text-[11px] text-accent-text">+18%</span>
                </div>
                <div class="bg-surface-elevated rounded-lg p-3">
                  <span class="text-[11px] text-text-muted">CVR</span>
                  <p class="text-base md:text-lg font-medium mt-1">8.3%</p>
                  <span class="text-[11px] text-accent-text">+2.1%</span>
                </div>
              </div>
              <!-- Bar chart -->
              <div class="bg-surface-elevated rounded-lg p-4">
                <div class="flex items-end gap-[6px] h-24">
                  <div class="flex-1 rounded-sm bg-accent/15" style="height: 35%"></div>
                  <div class="flex-1 rounded-sm bg-accent/15" style="height: 50%"></div>
                  <div class="flex-1 rounded-sm bg-accent/20" style="height: 42%"></div>
                  <div class="flex-1 rounded-sm bg-accent/20" style="height: 65%"></div>
                  <div class="flex-1 rounded-sm bg-accent/25" style="height: 55%"></div>
                  <div class="flex-1 rounded-sm bg-accent/30" style="height: 78%"></div>
                  <div class="flex-1 rounded-sm bg-accent/35" style="height: 70%"></div>
                  <div class="flex-1 rounded-sm bg-accent/50" style="height: 88%"></div>
                  <div class="flex-1 rounded-sm bg-accent" style="height: 100%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

</section>
