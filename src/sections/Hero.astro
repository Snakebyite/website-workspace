---
// Hero Section — Homepage
// Split layout: H1 left (7col), Photo + floating data chips right (5col)
import HeroVisual from "../components/HeroVisual.astro";
import LogoBand from "./LogoBand.astro";
import { Image } from "astro:assets";
import heroPhoto from "../assets/kevin-luca-hero.webp";
---

<section class="-mt-12 lg:mt-0 min-h-[calc(100dvh-4rem)] md:min-h-[calc(100dvh-5rem)] flex flex-col relative overflow-hidden" data-hero>
  <!-- Radial glow behind headline -->
  <div
    class="absolute top-1/3 left-[30%] -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] pointer-events-none"
    style="background: radial-gradient(ellipse at center, rgba(76, 175, 130, 0.06) 0%, transparent 70%)"
    aria-hidden="true"
  ></div>
  <!-- Radial glow behind photo -->
  <div
    class="absolute top-[40%] right-[10%] -translate-y-1/2 w-[600px] h-[600px] pointer-events-none hidden lg:block"
    style="background: radial-gradient(ellipse at center, rgba(76, 175, 130, 0.04) 0%, transparent 70%)"
    aria-hidden="true"
  ></div>

  <!-- Main content — vertically centered -->
  <div class="flex-1 flex items-center">
    <div class="mx-auto max-w-7xl px-4 md:px-8 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div class="lg:col-span-7">
          <h1 class="text-[2rem] sm:text-[2.75rem] md:text-[3.75rem] lg:text-[4.5rem] tracking-normal" data-hero-h1>
            Dein <span class="text-accent-text">Best Interest Advisor</span>
            <br class="hidden sm:block" />
            für <span class="text-accent-text">mehr Gewinn</span> auf
            <br class="hidden sm:block" />
            digitalen Marktplätzen.
          </h1>
          <!-- Mobile-only photo: Luca & Kevin (between H1 and subline, hidden on lg+) -->
          <div class="lg:hidden mt-10 mx-auto max-w-[260px]" data-hero-photo-mobile>
            <Image
              src={heroPhoto}
              alt="Luca und Kevin, Gründer von KFL Consulting"
              widths={[400, 600]}
              sizes="(max-width: 1023px) 260px, 0"
              class="hero-photo-mobile w-full h-auto select-none"
              loading="eager"
              decoding="async"
            />
          </div>
          <p class="text-text-secondary text-lg md:text-xl leading-relaxed mt-8 max-w-lg" data-hero-sub>
            Marktplatzwachstum planbar machen. Datenbasiert entscheiden. Organische Sichtbarkeit gezielt ausbauen. Mit den richtigen Prozessen auf 7-stellige Umsätze skalieren.
          </p>
          <div class="mt-8 max-w-[340px] sm:max-w-none sm:w-fit" data-hero-cta-group>
            <!-- Trust Badges -->
            <div class="grid grid-cols-2 gap-4" data-hero-badges>
              <!-- Google 5.0 Badge -->
              <a href="https://www.google.com/search?sca_esv=ca9c119048fe3647&rlz=1C5AJCO_enDE1206DE1206&sxsrf=ANbL-n7IsVAf5P06RwqoueitFQUi6XzBHw:1775942145149&q=kfl+consulting&si=AL3DRZEsmMGCryMMFSHJ3StBhOdZ2-6yYkXd_doETEE1OR-qOZNvtIaICfLfHaYlEovs20SPM-O8fJVtQDVXsdd0RsZ-AHLQqdJszHi7vx7CLfKYwjw6gYk%3D&uds=ALYpb_mM1P_6lpjjfowRxWEKPgkkfj-V__IA0i1mwLAXDlTAC5MZ0BlXfID3RXFrnCKiq3YTe0Grw1hf9WhGu7dTwv0YoO-D9D7NsmTCGFEEZjPd-7CJqW8&sa=X&ved=2ahUKEwjA58-F3OaTAxVXIBAIHQRlFmoQ3PALegQIKBAF&biw=1468&bih=828&dpr=2" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 sm:gap-3 bg-surface rounded-xl px-3.5 py-3 sm:px-5 sm:py-3.5 border border-white/5 transition-colors duration-200 hover:border-white/10">
                <svg viewBox="0 0 24 24" class="w-6 h-6 sm:w-7 sm:h-7 shrink-0" aria-hidden="true">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <div class="flex flex-col">
                  <div class="flex items-center gap-1 sm:gap-1.5">
                    <span class="text-text-primary font-bold text-base sm:text-lg leading-none">5.0</span>
                    <div class="flex gap-0.5" aria-label="5 von 5 Sternen">
                      {Array.from({ length: 5 }).map(() => (
                        <svg viewBox="0 0 20 20" class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-amber-400 fill-current" aria-hidden="true">
                          <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.28l-4.77 2.51.91-5.33L2.27 6.7l5.34-.78L10 1z"/>
                        </svg>
                      ))}
                    </div>
                  </div>
                  <span class="text-text-muted text-xs mt-0.5">Google</span>
                </div>
              </a>
              <!-- ProvenExpert Badge -->
              <a href="https://www.provenexpert.com/de-de/kfl-consulting/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 sm:gap-3 bg-surface rounded-xl px-3.5 py-3 sm:px-5 sm:py-3.5 border border-white/5 transition-colors duration-200 hover:border-white/10">
                <svg viewBox="0 0 40 40" class="w-6 h-6 sm:w-7 sm:h-7 shrink-0" aria-hidden="true">
                  <circle cx="20" cy="20" r="20" fill="#C5A94B"/>
                  <path d="M12 20.5l5.5 5L28 15" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                </svg>
                <div class="flex flex-col">
                  <div class="flex items-center gap-1 sm:gap-1.5">
                    <span class="text-text-primary font-bold text-base sm:text-lg leading-none">5.0</span>
                    <div class="flex gap-0.5" aria-label="5 von 5 Sternen">
                      {Array.from({ length: 5 }).map(() => (
                        <svg viewBox="0 0 20 20" class="w-3 h-3 sm:w-3.5 sm:h-3.5 text-amber-400 fill-current" aria-hidden="true">
                          <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.28l-4.77 2.51.91-5.33L2.27 6.7l5.34-.78L10 1z"/>
                        </svg>
                      ))}
                    </div>
                  </div>
                  <span class="text-text-muted text-xs mt-0.5">ProvenExpert</span>
                </div>
              </a>
            </div>
            <!-- Termin buchen — primary CTA -->
            <div class="grid grid-cols-2 gap-4 mt-6" data-hero-buttons>
              <a
                href="https://calendly.com/kflconsulting/kennenlernen"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center bg-accent hover:bg-accent-hover text-background font-medium px-6 py-4 rounded-button tracking-[0.01em] leading-tight transition-colors duration-200 text-center"
              >
                Termin buchen
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Photo + floating data chips — desktop only -->
        <div class="lg:col-span-5">
          <HeroVisual />
        </div>
      </div>
    </div>
  </div>

  <!-- Logo Band — full width between hero grid and VSL -->
  <LogoBand />

  <!-- VSL Headline + Video -->
  <div class="mx-auto max-w-7xl px-4 md:px-8 w-full pt-12 md:pt-24 pb-20 md:pb-32">
    <div class="max-w-4xl mx-auto text-center" data-hero-vsl>
        <h2 class="font-body font-normal text-xl sm:text-2xl md:text-3xl tracking-normal leading-[1.3] mb-12 md:mb-16" data-hero-vsl-headline>
          <span class="text-accent-text">Du bist eine D2C Brand mit ca. 250k Jahresumsatz?</span> Wir bauen deine organische Sichtbarkeit auf Amazon & Co. systematisch auf. So gibst du weniger für Ads aus und behältst mehr von deinem Umsatz.
        </h2>
        <div class="relative aspect-video rounded-2xl overflow-hidden bg-surface cursor-pointer group" data-vsl-container data-hero-vsl-video>
          <video
            class="w-full h-full object-cover"
            poster="/videos/vsl-poster.jpg"
            preload="metadata"
            playsinline
            data-vsl-video
          >
            <source src="/videos/vsl.mp4" type="video/mp4" />
          </video>
          <!-- Play button — exact center (face is in upper third, center hits chest/hands) -->
          <div class="absolute inset-0 flex items-center justify-center transition-opacity duration-200" data-vsl-overlay>
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-accent/90 flex items-center justify-center transition-transform duration-200 group-hover:scale-105">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-background ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <!-- Video controls — bottom bar, visible only during playback -->
          <div class="absolute bottom-0 left-0 right-0 opacity-0 transition-opacity duration-200 bg-gradient-to-t from-black/60 to-transparent pt-8 pb-3 px-4" data-vsl-controls>
            <!-- Progress bar -->
            <div class="flex items-center gap-3 mb-2">
              <span class="text-white text-xs font-medium tabular-nums min-w-[3ch]" data-vsl-time>0:00</span>
              <div class="flex-1 h-1 bg-white/20 rounded-full cursor-pointer group/bar relative" data-vsl-progress>
                <div class="h-full bg-accent rounded-full relative" data-vsl-progress-fill style="width: 0%">
                  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full opacity-0 group-hover/bar:opacity-100 transition-opacity duration-150"></div>
                </div>
              </div>
              <span class="text-white text-xs font-medium tabular-nums min-w-[3ch]" data-vsl-duration>0:00</span>
            </div>
            <!-- Speed toggle -->
            <div class="flex justify-end">
              <button
                type="button"
                class="px-3 py-1 rounded-lg bg-white/10 text-white text-xs font-medium tracking-wide hover:bg-white/20 transition-colors duration-150"
                data-vsl-speed-btn
              >
                1.1x
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
</section>

<style>
  .hero-photo-mobile {
    mask-image: linear-gradient(to bottom, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 92%, transparent 100%);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const section = document.querySelector("[data-hero]");
  if (section) {
    const h1 = section.querySelector("[data-hero-h1]");
    const sub = section.querySelector("[data-hero-sub]");
    const buttons = section.querySelector("[data-hero-buttons]");

    const tl = gsap.timeline({ delay: 0.3 });

    // SplitText word-by-word reveal on H1
    if (h1) {
      const split = new SplitText(h1, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });
      tl.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
      });
    }

    // Mobile-only photo fade-in (after H1, before subline)
    const photoMobile = section.querySelector("[data-hero-photo-mobile]");
    if (photoMobile) {
      gsap.set(photoMobile, { opacity: 0, y: 20 });
      tl.to(photoMobile, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: "power2.out",
      }, "-=0.3");
    }

    // Subline fade-in
    if (sub) {
      gsap.set(sub, { opacity: 0, y: 20 });
      tl.to(sub, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out",
      }, "-=0.2");
    }

    // Buttons stagger fade-in
    if (buttons) {
      const btns = buttons.querySelectorAll("a");
      gsap.set(btns, { opacity: 0, y: 20 });
      tl.to(btns, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.08,
        ease: "power2.out",
      }, "-=0.3");
    }

    // Trust badges fade-in
    const badges = section.querySelector("[data-hero-badges]");
    if (badges) {
      const items = badges.querySelectorAll(":scope > a");
      gsap.set(items, { opacity: 0, y: 15 });
      tl.to(items, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        stagger: 0.08,
        ease: "power2.out",
      }, "-=0.2");
    }

    // VSL: scroll-triggered reveal — Headline word-by-word, Video fade-up
    const vslHeadline = section.querySelector<HTMLElement>("[data-hero-vsl-headline]");
    const vslVideo = section.querySelector<HTMLElement>("[data-hero-vsl-video]");

    if (vslHeadline) {
      const headlineSplit = new SplitText(vslHeadline, { type: "words" });
      gsap.set(headlineSplit.words, { opacity: 0, y: 24, filter: "blur(8px)" });
      gsap.to(headlineSplit.words, {
        opacity: 1,
        y: 0,
        filter: "blur(0px)",
        duration: 0.6,
        stagger: 0.035,
        ease: "power3.out",
        scrollTrigger: { trigger: vslHeadline, start: "top 80%", once: true },
      });
    }

    if (vslVideo) {
      gsap.set(vslVideo, { opacity: 0, y: 48, scale: 0.96 });
      gsap.to(vslVideo, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 1.1,
        ease: "power3.out",
        scrollTrigger: { trigger: vslVideo, start: "top 80%", once: true },
      });
    }
  }

  // VSL click-to-play
  const container = document.querySelector("[data-vsl-container]");
  const video = document.querySelector<HTMLVideoElement>("[data-vsl-video]");
  const overlay = document.querySelector("[data-vsl-overlay]");

  const controls = document.querySelector("[data-vsl-controls]") as HTMLElement | null;
  const speedBtn = document.querySelector("[data-vsl-speed-btn]") as HTMLButtonElement | null;
  const progressBar = document.querySelector("[data-vsl-progress]") as HTMLElement | null;
  const progressFill = document.querySelector("[data-vsl-progress-fill]") as HTMLElement | null;
  const timeDisplay = document.querySelector("[data-vsl-time]") as HTMLElement | null;
  const durationDisplay = document.querySelector("[data-vsl-duration]") as HTMLElement | null;
  const speeds = [1.1, 1.5];
  let speedIndex = 0;

  function formatTime(seconds: number): string {
    const m = Math.floor(seconds / 60);
    const s = Math.floor(seconds % 60);
    return m + ":" + String(s).padStart(2, "0");
  }

  if (container && video && overlay && controls && speedBtn && progressBar && progressFill && timeDisplay && durationDisplay) {
    // Play/pause toggle
    container.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("[data-vsl-controls]")) return;

      if (video.paused) {
        video.playbackRate = speeds[speedIndex];
        video.play();
        overlay.style.opacity = "0";
        overlay.style.pointerEvents = "none";
        controls.style.opacity = "1";
      } else {
        video.pause();
        overlay.style.opacity = "1";
        overlay.style.pointerEvents = "auto";
        controls.style.opacity = "0";
      }
    });

    // Update progress bar + time
    video.addEventListener("timeupdate", () => {
      if (video.duration) {
        const pct = (video.currentTime / video.duration) * 100;
        progressFill.style.width = pct + "%";
        timeDisplay.textContent = formatTime(video.currentTime);
      }
    });

    // Set duration once loaded
    video.addEventListener("loadedmetadata", () => {
      durationDisplay.textContent = formatTime(video.duration);
    });

    // Seek on progress bar click
    progressBar.addEventListener("click", (e) => {
      e.stopPropagation();
      const rect = progressBar.getBoundingClientRect();
      const pct = (e.clientX - rect.left) / rect.width;
      video.currentTime = pct * video.duration;
    });

    // Speed toggle
    speedBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      speedIndex = (speedIndex + 1) % speeds.length;
      video.playbackRate = speeds[speedIndex];
      speedBtn.textContent = speeds[speedIndex] + "x";
    });

    // Reset on end
    video.addEventListener("ended", () => {
      overlay.style.opacity = "1";
      overlay.style.pointerEvents = "auto";
      controls.style.opacity = "0";
    });
  }
</script>
