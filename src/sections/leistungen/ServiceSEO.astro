---
// ServiceSEO — Organische Sichtbarkeit / Amazon SEO
// Job: Deep dive into core service. Philosophy + approach + deliverables.
// Layout: Full-width row. Text left (7col), card grid right (5col).
---

<section class="py-12 md:py-20" data-service-seo>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Overline + Headline -->
    <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-accent-text mb-4">
      Organische Sichtbarkeit
    </p>
    <h2 class="max-w-3xl">
      Amazon SEO ist kein Einmalprojekt. Es ist die Basis für alles, was danach kommt.
    </h2>

    <!-- Philosophy Text + Deliverable Cards -->
    <div class="mt-6 md:mt-8 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <div class="lg:col-span-7">
        <p class="text-text-secondary text-lg md:text-xl leading-relaxed max-w-[44rem]">
          Jedes Projekt startet bei uns mit einem vollständigen Keyword Mapping. Nicht mit einer Liste aus einem Tool, sondern mit einem <span class="text-text-primary font-medium">Deep Dive nach der Rank Lift Organic Methode</span>. Wir analysieren alle Wortkombinationen innerhalb der Keywordwurzeln, gleichen Suchintention und relevante Stammdaten ab und bauen das Ganze auf deinem Zielgruppenverständnis auf. Jede Lücke in diesem Prozess wird durch KI und menschliche Validierung geschlossen.
        </p>
        <p class="text-text-secondary text-base md:text-lg leading-relaxed mt-6 max-w-[44rem]">
          Parallel dazu schauen wir uns sämtliche Bewertungen an. Deine und die vom Wettbewerb. AI First integriert, weil das Arbeiten sind, die ein Mensch alleine in dieser Tiefe gar nicht mehr umsetzen kann. Wir setzen das in einem Konzept um, das in kurzer Zeit iteriert wird, so dass das komplette Maximum aus den Daten herausgearbeitet wird. So haben wir komplette Klarheit über alle organischen Lücken in der Nische und maximieren das organische Fundament.
        </p>
        <p class="text-text-secondary text-base md:text-lg leading-relaxed mt-6 max-w-[44rem]">
          Was die meisten übersehen: Genauso wie sich Deal Events ändern, gibt es themenbezogene Keywords, die von nahezu 90% der Seller nicht berücksichtigt werden. Saisonale Shifts, veränderte Suchintentionen, neue Wettbewerberstrukturen. Wir monitoren, passen an und reagieren. Bevor du es merkst.
        </p>
      </div>

      <!-- Deliverable Cards -->
      <div class="lg:col-span-5">
        <h3 class="font-body text-lg font-medium text-text-primary mb-6">Was du bekommst</h3>
        <div class="space-y-4" data-seo-cards>
          <div class="seo-card relative bg-surface rounded-2xl p-5 md:p-6 border border-white/5 overflow-hidden transition-all duration-300">
            <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-text-muted mb-2 transition-colors duration-300">Fundament</p>
            <p class="text-text-primary font-medium text-base mb-1.5">Rank Lift Organic Analyse</p>
            <p class="text-text-secondary text-sm leading-relaxed">Alle Wortkombinationen innerhalb der Keywordwurzeln, Suchintentionen und Stammdaten. KI gestützt aufgebaut, manuell validiert.</p>
          </div>

          <div class="seo-card relative bg-surface rounded-2xl p-5 md:p-6 border border-white/5 overflow-hidden transition-all duration-300">
            <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-text-muted mb-2 transition-colors duration-300">Umsetzung</p>
            <p class="text-text-primary font-medium text-base mb-1.5">Listing Optimierung</p>
            <p class="text-text-secondary text-sm leading-relaxed">Titel, Bullet Points, Backend Keywords, A+ Content. Vollständig abgestimmt auf die Analyse und den Wettbewerb.</p>
          </div>

          <div class="seo-card relative bg-surface rounded-2xl p-5 md:p-6 border border-white/5 overflow-hidden transition-all duration-300">
            <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-text-muted mb-2 transition-colors duration-300">Laufend</p>
            <p class="text-text-primary font-medium text-base mb-1.5">Monitoring und Event Keywords</p>
            <p class="text-text-secondary text-sm leading-relaxed">Rankings, Deal Event Shifts, saisonale Suchintentionen. Kontinuierlich angepasst, kein Set and Forget.</p>
          </div>

        </div>
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-service-seo]");
  if (section) {
    const overline = section.querySelector("p:first-child");
    const h2 = section.querySelector("h2");
    const paragraphs = section.querySelectorAll(".lg\\:col-span-7 p");
    const cardHeading = section.querySelector(".lg\\:col-span-5 h3");
    const cards = section.querySelectorAll("[data-seo-cards] > div");

    // H2 SplitText reveal
    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });

      gsap.to(split.words, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.08,
        ease: "power2.out",
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
      });
    }

    // Overline fade-in
    if (overline) {
      gsap.set(overline, { opacity: 0, y: 10 });
      gsap.to(overline, {
        opacity: 1,
        y: 0,
        duration: 0.4,
        ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 78%", once: true },
      });
    }

    // Paragraphs stagger
    if (paragraphs.length) {
      gsap.set(paragraphs, { opacity: 0, y: 20 });
      gsap.to(paragraphs, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.15,
        ease: "power2.out",
        scrollTrigger: { trigger: paragraphs[0], start: "top 85%", once: true },
      });
    }

    // Card heading
    if (cardHeading) {
      gsap.set(cardHeading, { opacity: 0, y: 15 });
      gsap.to(cardHeading, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
        scrollTrigger: { trigger: cardHeading, start: "top 85%", once: true },
      });
    }

    // Cards stagger entrance
    if (cards.length) {
      gsap.set(cards, { opacity: 0, y: 25 });
      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.12,
        ease: "power2.out",
        scrollTrigger: { trigger: cards[0], start: "top 88%", once: true },
      });
    }
  }
</script>

<style>
  .seo-card:hover {
    transform: translateY(-1.5px);
    border-color: rgba(76, 175, 130, 0.25);
    box-shadow: 0 8px 30px rgba(76, 175, 130, 0.08);
  }

  .seo-card:hover p:first-child {
    color: var(--color-accent-text);
  }
</style>
