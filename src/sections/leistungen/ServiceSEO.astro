---
// ServiceSEO — Organische Sichtbarkeit / Rank Lift Organic Methode
// Horizontale Timeline mit Scroll-Pin + Scrub. Stil angelehnt an MarktplatzPhasenVisual
// von der Startseite: segmentierte Linien (nicht durchgehend), Outer-Ring + Node-Bubble,
// wandernder Pulse-Dot der beim Scrubben mit progress mitläuft.
import ListingMockup from "../../components/ListingMockup.astro";

const steps = [
  {
    title: "Portfolio und Wettbewerb",
    teaser: "Dein Portfolio, deine Wettbewerber.",
    body: `Wir analysieren die <strong class="text-text-primary font-medium">relevanten Produkte</strong> aus deinem Portfolio und sammeln die <strong class="text-text-primary font-medium">relevanten Wettbewerber</strong> in deiner Nische. Die Ausgangslage: was du verkaufst, gegen wen du verkaufst.`,
  },
  {
    title: "Positionierung",
    teaser: "Die Strategie, bevor das Listing kommt.",
    body: `Deep Dive in die Kategorien: <strong class="text-text-primary font-medium">USPs</strong>, <strong class="text-text-primary font-medium">Differenzierungsmerkmale</strong>, <strong class="text-text-primary font-medium">Reviews</strong> aus Kunden- und Wettbewerbsperspektive. Daraus leiten wir ab, wie deine Marke und dein Produkt auf Amazon auftreten müssen, damit die echten Stärken sichtbar werden.`,
  },
  {
    title: "Keyword-Architektur",
    teaser: "Jedes Keyword mit Zahlen hinterlegt.",
    body: `Datenbasierter Deep Dive in die Suchwelt deiner Nische. Welche Keywords bringen <strong class="text-text-primary font-medium">Volumen</strong>, welche <strong class="text-text-primary font-medium">Suchintention</strong> steckt dahinter, welche <strong class="text-text-primary font-medium">Kombinationen</strong> deckt bisher niemand sauber ab. Das Ergebnis: die Karte, nach der das Listing gebaut wird.`,
  },
  {
    title: "Listing-Build",
    teaser: "Aus Portfolio, Strategie und Keywords: dein Listing.",
    body: `Wir führen Portfolio, Positionierung und Keyword-Architektur zusammen. <strong class="text-text-primary font-medium">Titel</strong>, <strong class="text-text-primary font-medium">Bullets</strong>, <strong class="text-text-primary font-medium">Backend</strong>, <strong class="text-text-primary font-medium">A+ Content</strong>. Jedes Element so gebaut, dass es organisch rankt und gleichzeitig dein Produkt überzeugend darstellt.`,
  },
];
---

<section id="organische-sichtbarkeit" class="scroll-mt-24 pt-32 md:pt-48 pb-20 md:pb-32" data-service-seo>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Pin-Wrapper: Header + Desktop Timeline werden gemeinsam gepinnt -->
    <div data-seo-pin>

      <!-- Header -->
      <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-accent-text mb-4" data-seo-overline>
        Organische Sichtbarkeit
      </p>
      <h2 class="max-w-4xl">
        Organische Käufe haben die höchste Marge. Alles, was du organisch liegen lässt, zahlst du in PPC nach.
      </h2>
      <p class="mt-6 md:mt-8 max-w-3xl text-text-secondary text-lg leading-relaxed" data-seo-lead>
        Wer organisch nicht sichtbar ist, zahlt bei Amazon doppelt. Einmal für jeden PPC-Klick und ein zweites Mal, wenn Besucher auf einem Listing landen, das sie nicht überzeugt. Mit der <span class="text-accent-text font-medium">Rank Lift Organic</span> Methode bauen wir in vier Schritten das Listing, das beides kann: ranken und verkaufen.
      </p>

      <!-- ─────────────────── DESKTOP: Timeline ─────────────────── -->
      <div class="hidden md:block mt-14 lg:mt-20" data-seo-desktop>

        <!-- Timeline -->
        <div class="relative" data-seo-timeline>
          <!-- Background segments (inactive) — positioned via JS between bubbles -->
          <div class="seo-seg-bg" data-seo-seg-bg="0" aria-hidden="true"></div>
          <div class="seo-seg-bg" data-seo-seg-bg="1" aria-hidden="true"></div>
          <div class="seo-seg-bg" data-seo-seg-bg="2" aria-hidden="true"></div>

          <!-- Active fill segments — grow via scaleX on scroll -->
          <div class="seo-seg-fill" data-seo-seg="0" aria-hidden="true"></div>
          <div class="seo-seg-fill" data-seo-seg="1" aria-hidden="true"></div>
          <div class="seo-seg-fill" data-seo-seg="2" aria-hidden="true"></div>

          <!-- Pulse-dot — travels along segments during transitions -->
          <div class="seo-pulse" data-seo-pulse aria-hidden="true">
            <div class="seo-pulse-core"></div>
          </div>

          <!-- 4 Columns with bubbles + titles -->
          <div class="grid grid-cols-4 gap-x-6 lg:gap-x-10">
            {steps.map((step, i) => (
              <div class="flex flex-col items-center text-center">
                <!-- Outer ring (glow when active) -->
                <div class="seo-node relative" data-seo-bubble data-step-index={i}>
                  <span class="seo-bubble-ring" aria-hidden="true"></span>
                  <span
                    class="font-body font-medium text-[1rem] tracking-[0.02em] tabular-nums seo-bubble-num"
                    data-seo-bubble-number
                  >
                    {String(i + 1).padStart(2, "0")}
                  </span>
                </div>
                <h4
                  class="mt-6 font-body font-medium text-[1rem] lg:text-[1.0625rem] uppercase tracking-[0.08em] leading-[1.3] max-w-[20ch]"
                  data-seo-step-title
                  data-step-index={i}
                >
                  {step.title}
                </h4>
              </div>
            ))}
          </div>
        </div>

        <!-- Central text area -->
        <div
          class="relative mt-12 lg:mt-14 min-h-[220px] max-w-3xl mx-auto px-4"
          data-seo-text-area
        >
          {steps.map((step, i) => (
            <div
              class="absolute inset-0 px-4 text-center"
              data-seo-text
              data-step-index={i}
              style={`opacity: ${i === 0 ? 1 : 0};`}
            >
              <p class="font-body text-xl md:text-2xl font-medium text-text-primary leading-[1.35] tracking-[-0.01em]">
                {step.teaser}
              </p>
              <p
                class="mt-5 text-text-secondary text-[1.0625rem] lg:text-lg leading-[1.65]"
                set:html={step.body}
              />
            </div>
          ))}
        </div>

        <!-- Before/After listing comparison — static, shows final result -->
        <div class="mt-8 lg:mt-10 max-w-[1040px] mx-auto" data-seo-mockups>
          <div class="grid grid-cols-[1fr_auto_1fr] gap-x-5 lg:gap-x-7 gap-y-3 items-stretch">
            <!-- Labels row -->
            <p class="text-[0.6875rem] font-medium uppercase tracking-[0.14em] text-text-muted text-center self-end">
              Vorher
            </p>
            <div></div>
            <p class="text-[0.6875rem] font-medium uppercase tracking-[0.14em] text-accent-text text-center self-end">
              Nachher
            </p>
            <!-- Cards row — items-stretch makes both cards equal height -->
            <ListingMockup variant="before" />
            <div class="self-center flex items-center justify-center text-accent-text">
              <svg class="w-5 h-5 lg:w-6 lg:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
            <ListingMockup variant="after" />
          </div>
        </div>

      </div>
    </div>

    <!-- ─────────────────── MOBILE: Vertikaler Flow ─────────────────── -->
    <div class="md:hidden mt-12" data-seo-mobile>
      <div class="relative" data-seo-mobile-steps>
        <div
          class="absolute top-6 bottom-6 w-px bg-gradient-to-b from-accent-text/50 via-white/15 to-white/5 left-6"
          aria-hidden="true"
        ></div>

        {steps.map((step, i) => (
          <div class="relative flex gap-5 pb-10 last:pb-0" data-seo-mobile-step>
            <div class="relative z-10 shrink-0 flex items-center justify-center w-12 h-12 rounded-full border border-accent-text/40 bg-surface">
              <span class="font-body font-medium text-[0.875rem] tracking-[0.02em] tabular-nums text-accent-text">
                {String(i + 1).padStart(2, "0")}
              </span>
            </div>
            <div class="pt-1.5 max-w-2xl">
              <h4 class="font-body font-medium text-[0.9375rem] uppercase tracking-[0.08em] leading-[1.3]">
                {step.title}
              </h4>
              <p class="mt-2 text-text-primary font-medium text-base leading-[1.4]">
                {step.teaser}
              </p>
              <p
                class="mt-2.5 text-text-secondary text-[0.9375rem] leading-[1.6]"
                set:html={step.body}
              />
            </div>
          </div>
        ))}
      </div>

      <!-- Before/After listing comparison (mobile) -->
      <div class="mt-14 space-y-8">
        <div>
          <p class="text-[0.6875rem] font-medium uppercase tracking-[0.14em] text-text-muted mb-2.5 text-center">
            Vorher
          </p>
          <ListingMockup variant="before" />
        </div>
        <div class="flex items-center justify-center text-accent-text">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <polyline points="5 12 12 19 19 12"></polyline>
          </svg>
        </div>
        <div>
          <p class="text-[0.6875rem] font-medium uppercase tracking-[0.14em] text-accent-text mb-2.5 text-center">
            Nachher
          </p>
          <ListingMockup variant="after" />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ─── Timeline Segments ─── */
  .seo-seg-bg,
  .seo-seg-fill {
    position: absolute;
    top: 31px; /* node center: 32px - half of 1px line */
    height: 1px;
    pointer-events: none;
  }

  .seo-seg-bg {
    background: rgba(255, 255, 255, 0.08);
  }

  .seo-seg-fill {
    background: rgba(107, 175, 150, 0.85);
    box-shadow: 0 0 8px rgba(107, 175, 150, 0.45);
    transform-origin: left center;
    transform: scaleX(0);
  }

  /* ─── Node (bubble + outer ring) ─── */
  .seo-node {
    z-index: 10;
    width: 64px;
    height: 64px;
    border-radius: 9999px;
    background: #0a0a0a; /* solid page bg so segments can't bleed through */
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.4s ease, border-color 0.4s ease;
  }

  /* Outer glow ring — only visible when active */
  .seo-bubble-ring {
    position: absolute;
    inset: -6px;
    border-radius: 9999px;
    border: 1px solid rgba(76, 175, 130, 0);
    box-shadow: 0 0 0 rgba(76, 175, 130, 0);
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
    pointer-events: none;
  }

  .seo-bubble-num {
    color: rgba(153, 153, 153, 1);
    position: relative;
    z-index: 1;
    transition: color 0.4s ease;
  }

  /* ─── Pulse-Dot ─── */
  .seo-pulse {
    position: absolute;
    top: 31px;
    left: 0;
    width: 14px;
    height: 14px;
    margin-left: -7px;
    margin-top: -6.5px;
    border-radius: 9999px;
    background: rgba(107, 175, 150, 0.55);
    filter: blur(4px);
    pointer-events: none;
    opacity: 0;
    will-change: transform, opacity;
  }

  .seo-pulse-core {
    position: absolute;
    inset: 4px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.95);
    filter: none;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const INACTIVE_BORDER = "rgba(255,255,255,0.15)";
  const INACTIVE_BG = "rgba(10,10,10,1)";
  const INACTIVE_NUMBER = "rgba(153,153,153,1)";
  const INACTIVE_TITLE = "rgba(153,153,153,1)";
  const INACTIVE_RING_BORDER = "rgba(76,175,130,0)";
  const INACTIVE_RING_SHADOW = "0 0 0 rgba(76,175,130,0)";

  const ACTIVE_BORDER = "rgba(107,175,150,0.7)";
  const ACTIVE_BG = "rgba(76,175,130,0.12)";
  const ACTIVE_NUMBER = "rgba(107,175,150,1)";
  const ACTIVE_TITLE = "rgba(239,239,239,1)";
  const ACTIVE_RING_BORDER = "rgba(76,175,130,0.25)";
  const ACTIVE_RING_SHADOW = "0 0 20px rgba(76,175,130,0.35)";

  const section = document.querySelector("[data-service-seo]");
  if (section) {
    const overline = section.querySelector("[data-seo-overline]");
    const h2 = section.querySelector("h2");
    const lead = section.querySelector("[data-seo-lead]");

    // Header entrance animations (always on)
    if (overline) {
      gsap.set(overline, { opacity: 0, y: 10 });
      gsap.to(overline, {
        opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 78%", once: true },
      });
    }

    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });
      gsap.to(split.words, {
        opacity: 1, y: 0, duration: 0.6, stagger: 0.06, ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 75%", once: true },
      });
    }

    if (lead) {
      gsap.set(lead, { opacity: 0, y: 15 });
      gsap.to(lead, {
        opacity: 1, y: 0, duration: 0.5, ease: "power2.out",
        scrollTrigger: { trigger: lead, start: "top 85%", once: true },
      });
    }

    // Desktop: pinned scroll-scrubbed timeline
    const isDesktop = window.matchMedia("(min-width: 768px)").matches;

    if (isDesktop) {
      const pin = section.querySelector<HTMLElement>("[data-seo-pin]");
      const timelineEl = section.querySelector<HTMLElement>("[data-seo-timeline]");
      const bubbles = section.querySelectorAll<HTMLElement>("[data-seo-bubble]");
      const bubbleNumbers = section.querySelectorAll<HTMLElement>("[data-seo-bubble-number]");
      const bubbleRings = section.querySelectorAll<HTMLElement>(".seo-bubble-ring");
      const stepTitles = section.querySelectorAll<HTMLElement>("[data-seo-step-title]");
      const segFills = section.querySelectorAll<HTMLElement>("[data-seo-seg]");
      const segBgs = section.querySelectorAll<HTMLElement>("[data-seo-seg-bg]");
      const pulse = section.querySelector<HTMLElement>("[data-seo-pulse]");
      const texts = section.querySelectorAll<HTMLElement>("[data-seo-text]");

      if (pin && timelineEl && bubbles.length === 4 && texts.length === 4 && pulse) {
        // ── Position segments + measure bubble centers (responsive) ──
        const bubbleCenters: number[] = [0, 0, 0, 0];

        const layoutSegments = () => {
          const timelineRect = timelineEl.getBoundingClientRect();
          const bubbleRects = Array.from(bubbles).map((b) => b.getBoundingClientRect());

          // Cache bubble-center x offsets (relative to timeline) for pulse positioning
          bubbleRects.forEach((r, i) => {
            bubbleCenters[i] = r.left + r.width / 2 - timelineRect.left;
          });

          for (let i = 0; i < 3; i++) {
            const left = bubbleRects[i].right - timelineRect.left;
            const width = Math.max(0, bubbleRects[i + 1].left - bubbleRects[i].right);
            [segFills[i], segBgs[i]].forEach((seg) => {
              if (!seg) return;
              seg.style.left = `${left}px`;
              seg.style.width = `${width}px`;
            });
          }
        };

        layoutSegments();
        window.addEventListener("resize", layoutSegments);

        // ── Initial state: Step 1 active, rest muted ──
        bubbles.forEach((b, i) => {
          gsap.set(b, {
            borderColor: i === 0 ? ACTIVE_BORDER : INACTIVE_BORDER,
            backgroundColor: i === 0 ? ACTIVE_BG : INACTIVE_BG,
          });
        });
        bubbleRings.forEach((r, i) => {
          gsap.set(r, {
            borderColor: i === 0 ? ACTIVE_RING_BORDER : INACTIVE_RING_BORDER,
            boxShadow: i === 0 ? ACTIVE_RING_SHADOW : INACTIVE_RING_SHADOW,
          });
        });
        bubbleNumbers.forEach((n, i) => {
          gsap.set(n, { color: i === 0 ? ACTIVE_NUMBER : INACTIVE_NUMBER });
        });
        stepTitles.forEach((t, i) => {
          gsap.set(t, { color: i === 0 ? ACTIVE_TITLE : INACTIVE_TITLE });
        });
        texts.forEach((t, i) => {
          gsap.set(t, { opacity: i === 0 ? 1 : 0, y: i === 0 ? 0 : 14 });
        });
        gsap.set(pulse, { x: bubbleCenters[0], opacity: 0 });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: pin,
            start: "top top+=120",
            end: "+=2000",
            pin: true,
            scrub: 0.6,
            invalidateOnRefresh: true,
            onRefresh: layoutSegments,
          },
        });

        // Transitions at progress 0.25, 0.5, 0.75
        for (let i = 1; i < 4; i++) {
          const pos = i / 4;
          const D = 0.08;

          // Pulse travels from previous bubble-center to current bubble-center
          tl.to(pulse, { opacity: 1, duration: D * 0.3, ease: "power2.out" }, pos - D);
          tl.to(pulse, {
            x: () => bubbleCenters[i],
            duration: D * 1.5,
            ease: "power2.inOut",
          }, pos - D);
          tl.to(pulse, { opacity: 0, duration: D * 0.4, ease: "power2.in" }, pos + D * 0.5);

          // Segment fill
          tl.to(segFills[i - 1], {
            scaleX: 1,
            duration: D * 1.5,
            ease: "power1.inOut",
          }, pos - D);

          // Previous text out
          tl.to(texts[i - 1], { opacity: 0, y: -14, duration: D, ease: "power2.inOut" }, pos - D);

          // Next text in
          tl.fromTo(texts[i],
            { opacity: 0, y: 14 },
            { opacity: 1, y: 0, duration: D, ease: "power2.inOut" },
            pos + D * 0.2
          );

          // Deactivate previous bubble
          tl.to(bubbles[i - 1], {
            borderColor: INACTIVE_BORDER,
            backgroundColor: INACTIVE_BG,
            duration: D,
            ease: "power2.inOut",
          }, pos - D * 0.5);
          tl.to(bubbleRings[i - 1], {
            borderColor: INACTIVE_RING_BORDER,
            boxShadow: INACTIVE_RING_SHADOW,
            duration: D,
            ease: "power2.inOut",
          }, pos - D * 0.5);
          tl.to(bubbleNumbers[i - 1], { color: INACTIVE_NUMBER, duration: D, ease: "power2.inOut" }, pos - D * 0.5);
          tl.to(stepTitles[i - 1], { color: INACTIVE_TITLE, duration: D, ease: "power2.inOut" }, pos - D * 0.5);

          // Activate current bubble
          tl.to(bubbles[i], {
            borderColor: ACTIVE_BORDER,
            backgroundColor: ACTIVE_BG,
            duration: D,
            ease: "power2.inOut",
          }, pos - D * 0.5);
          tl.to(bubbleRings[i], {
            borderColor: ACTIVE_RING_BORDER,
            boxShadow: ACTIVE_RING_SHADOW,
            duration: D,
            ease: "power2.inOut",
          }, pos - D * 0.5);
          tl.to(bubbleNumbers[i], { color: ACTIVE_NUMBER, duration: D, ease: "power2.inOut" }, pos - D * 0.5);
          tl.to(stepTitles[i], { color: ACTIVE_TITLE, duration: D, ease: "power2.inOut" }, pos - D * 0.5);
        }
      }
    } else {
      // Mobile: simple staggered reveal
      const mobileSteps = section.querySelectorAll<HTMLElement>("[data-seo-mobile-step]");
      if (mobileSteps.length) {
        gsap.set(mobileSteps, { opacity: 0, y: 20 });
        gsap.to(mobileSteps, {
          opacity: 1, y: 0, duration: 0.5, stagger: 0.12, ease: "power2.out",
          scrollTrigger: {
            trigger: section.querySelector("[data-seo-mobile-steps]"),
            start: "top 80%",
            once: true,
          },
        });
      }
    }
  }
</script>
