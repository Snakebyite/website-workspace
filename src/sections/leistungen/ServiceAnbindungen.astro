---
// ServiceAnbindungen — Marktplatz-Anbindungen
// Struktur: Overline + H2 + Subline → Key Visual (Hub) → 3-Spalter (Ohne | Mit | Methode).
// Dichte: MITTEL. Typografie und Visual tragen, kein Karten-Overload.
import MarktplatzHub from "../../components/MarktplatzHub.astro";
import { X, Check } from "@lucide/astro";

const probleme = [
  "CSV-Chaos und Feed-Fehler",
  "Ausverkäufe, Stornos, Buy-Box-Verluste",
  "Ranking-Einbrüche durch Datenlücken",
];

const benefits = [
  "Eine zentrale Datenquelle, alle Kanäle synchron",
  "Echtzeit-Updates für Preise und Bestände",
  "KI-gestützte Listing-Qualität je Marktplatz",
];

const methode = [
  "Stammdaten-Audit und Mapping",
  "API-Anbindung und Plattform-Setup",
  "Go-Live, Monitoring, Skalierung",
];
---

<section id="marktplatz-anbindungen" class="scroll-mt-24 py-20 md:py-32" data-service-anbindungen>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    {/* Overline + Headline + Subline */}
    <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-accent-text mb-4">
      Marktplatz-Anbindungen
    </p>
    <h2 class="max-w-4xl">
      Dein Shop spricht mit jedem Marktplatz, <span class="text-accent-text">automatisch.</span>
    </h2>
    <p class="text-text-secondary text-lg md:text-xl leading-relaxed mt-6 max-w-2xl">
      Eine zentrale Datenquelle, alle Kanäle synchron. Stammdaten einmal sauber pflegen, Änderungen fließen in Sekunden durch, ohne Excel oder manuelle Uploads. Neue Marktplätze sauber anbinden, Multichannel endlich richtig skalieren.
    </p>

    {/* Key Visual */}
    <div class="mt-14 md:mt-20" data-hub-wrapper>
      <MarktplatzHub />
    </div>

    {/* Kompakte 3-Spalten: Problem | Lösung | Methode */}
    <div class="mt-16 md:mt-24 grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12" data-triptych>

      <div data-col>
        <p class="font-body text-xs font-medium uppercase tracking-[0.08em] text-text-muted mb-5">
          Ohne zentrale Anbindung
        </p>
        <ul class="space-y-4">
          {probleme.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex items-center justify-center w-5 h-5 shrink-0 rounded-full bg-red-500/10">
                <X class="w-3 h-3 text-red-400" />
              </span>
              <span class="text-text-secondary leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div data-col>
        <p class="font-body text-xs font-medium uppercase tracking-[0.08em] text-accent-text mb-5">
          Mit zentraler Anbindung
        </p>
        <ul class="space-y-4">
          {benefits.map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex items-center justify-center w-5 h-5 shrink-0 rounded-full bg-accent/15">
                <Check class="w-3 h-3 text-accent-text" />
              </span>
              <span class="text-text-primary leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div data-col>
        <p class="font-body text-xs font-medium uppercase tracking-[0.08em] text-text-muted mb-5">
          So gehen wir vor
        </p>
        <ol class="space-y-4">
          {methode.map((item, i) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex items-center justify-center w-5 h-5 shrink-0 font-body text-xs font-medium text-accent-text tabular-nums">
                0{i + 1}
              </span>
              <span class="text-text-primary leading-relaxed">{item}</span>
            </li>
          ))}
        </ol>
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  function initAnbindungen(): void {
    const section = document.querySelector<HTMLElement>("[data-service-anbindungen]");
    if (!section) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) return;

    const overline = section.querySelector<HTMLElement>("p:first-child");
    const h2 = section.querySelector<HTMLElement>("h2");
    const introP = section.querySelector<HTMLElement>("h2 + p");
    const cols = section.querySelectorAll<HTMLElement>("[data-triptych] [data-col]");

    const ctx = gsap.context(() => {
      if (overline) {
        gsap.set(overline, { opacity: 0, y: 10 });
        gsap.to(overline, {
          opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 78%", once: true },
        });
      }

      if (h2) {
        const split = new SplitText(h2, { type: "words" });
        gsap.set(split.words, { opacity: 0, y: 20 });
        gsap.to(split.words, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 75%", once: true },
        });
      }

      if (introP) {
        gsap.set(introP, { opacity: 0, y: 20 });
        gsap.to(introP, {
          opacity: 1, y: 0, duration: 0.6, ease: "power2.out",
          scrollTrigger: { trigger: introP, start: "top 88%", once: true },
        });
      }

      if (cols.length) {
        gsap.set(cols, { opacity: 0, y: 24 });
        gsap.to(cols, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.12, ease: "power2.out",
          scrollTrigger: { trigger: cols[0], start: "top 85%", once: true },
        });
      }
    }, section);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initAnbindungen();
  document.addEventListener("astro:after-swap", initAnbindungen);
</script>
