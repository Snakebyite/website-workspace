---
// ServiceStrategie — Marktplatz Strategie
// Desktop: Split-Layout wird gepinnt, beim Scrollen wechseln Steps links
// (aktiv/seen) und Visuals rechts (crossfade). 3 Steps ≈ 3 gleich große
// Scroll-Segmente innerhalb der Pin-Strecke.
// Mobile: Kein Pin, Visuals untereinander gestapelt, jedes Visual triggert sich selbst.
import StrategieAnalyseVisual from "../../components/StrategieAnalyseVisual.astro";
import StrategieRoadmapVisual from "../../components/StrategieRoadmapVisual.astro";
import StrategieSparringVisual from "../../components/StrategieSparringVisual.astro";
import { ArrowRight } from "@lucide/astro";

const calendlyUrl =
  "https://calendly.com/kflconsulting/kennenlernen?hide_event_type_details=1&hide_gdpr_banner=1&background_color=0a0a0a&text_color=efefef&primary_color=4caf82";
---

<section id="marktplatz-strategie" class="scroll-mt-24 py-20 md:py-32" data-service-strategie>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    {/* Overline + Headline */}
    <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-accent-text mb-4" data-strategie-overline>
      Marktplatz Strategie
    </p>
    <h2 class="max-w-3xl">
      Erst die Strategie, dann die Skalierung. Nicht umgekehrt.
    </h2>

    <p class="mt-8 md:mt-10 max-w-4xl text-text-secondary text-lg leading-relaxed" data-strategie-lead>
      Viele Unternehmen starten auf Marktplätzen, ohne klares Ziel und ohne Blick für die echten Engpässe. Am Ende verbrennen <span class="text-text-primary font-medium">Budget und Zeit</span>. Das alles alleine zu steuern, zwischen Tagesgeschäft, Teams und zehn gleichzeitigen Baustellen, ist kaum zu schaffen. Genau da setzen wir an: mit <span class="text-text-primary font-medium">Außenperspektive</span> und der <span class="text-text-primary font-medium">Erfahrung aus mehr als 100 Projekten</span>.
    </p>

    {/* Pin-Wrapper: Desktop-Pin greift hier, Mobile-Layout funktioniert ohne Pin */}
    <div class="mt-14 md:mt-20" data-strategie-pin>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">

        {/* Steps links */}
        <div class="lg:col-span-5 flex flex-col gap-8 md:gap-10" data-strategie-steps>
          <div class="step flex gap-5 md:gap-6 is-active" data-step data-step-index="0">
            <span class="font-body text-sm font-medium tabular-nums text-text-muted leading-none pt-1 shrink-0">01</span>
            <div>
              <p class="font-body text-xs font-medium uppercase tracking-[0.1em] text-accent-text leading-none">
                Analyse
              </p>
              <p class="mt-3 text-text-primary text-base md:text-[1.0625rem] leading-relaxed">
                Ehrlicher Blick auf Kanäle, KPIs und Engpässe. Daraus wird sichtbar, wo Budget wirklich liegen bleibt und wo der größte Hebel steckt.
              </p>
            </div>
          </div>
          <div class="step flex gap-5 md:gap-6" data-step data-step-index="1">
            <span class="font-body text-sm font-medium tabular-nums text-text-muted leading-none pt-1 shrink-0">02</span>
            <div>
              <p class="font-body text-xs font-medium uppercase tracking-[0.1em] text-accent-text leading-none">
                Roadmap
              </p>
              <p class="mt-3 text-text-primary text-base md:text-[1.0625rem] leading-relaxed">
                Aus der Analyse wird eine klare, fahrbare Roadmap: die Themen, die für euer Setup den größten Hebel haben, in der richtigen Reihenfolge.
              </p>
            </div>
          </div>
          <div class="step flex gap-5 md:gap-6" data-step data-step-index="2">
            <span class="font-body text-sm font-medium tabular-nums text-text-muted leading-none pt-1 shrink-0">03</span>
            <div>
              <p class="font-body text-xs font-medium uppercase tracking-[0.1em] text-accent-text leading-none">
                Sparring
              </p>
              <p class="mt-3 text-text-primary text-base md:text-[1.0625rem] leading-relaxed">
                Ihr habt uns als Advisor und Sparringspartner im Rücken: Entscheidungen gegenchecken bevor Budget fließt, Prioritäten neu sortieren wenn sich Markt oder KPIs drehen, neue Chancen früher auf dem Radar.
              </p>
            </div>
          </div>
        </div>

        {/* Visual-Stack rechts: Desktop überlagernd, Mobile gestapelt */}
        <div class="lg:col-span-7" data-strategie-visual-stack>
          <div class="visual-slot is-active" data-visual-slot data-visual-index="0">
            <StrategieAnalyseVisual pinControlled={true} />
          </div>
          <div class="visual-slot" data-visual-slot data-visual-index="1">
            <StrategieRoadmapVisual pinControlled={true} />
          </div>
          <div class="visual-slot" data-visual-slot data-visual-index="2">
            <StrategieSparringVisual pinControlled={true} />
          </div>
        </div>

      </div>
    </div>

    <div class="mt-14 md:mt-20 flex justify-center" data-strategie-cta>
      <div class="relative inline-flex" data-strategie-cta-button>
        <span class="cta-glow" aria-hidden="true"></span>
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener"
          data-calendly-trigger
          class="group relative inline-flex items-center gap-2 text-accent-text font-medium transition-colors duration-200 hover:text-text-primary"
        >
          <span class="border-b border-transparent group-hover:border-current transition-colors duration-200">
            Deine Marktplatzstrategie erarbeiten
          </span>
          <ArrowRight class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" />
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  /* ─── Steps: inactive wirkt gedimmt, active voll ─── */
  [data-strategie-steps] .step {
    opacity: 0.45;
    transition: opacity 0.5s ease;
  }
  [data-strategie-steps] .step.is-active {
    opacity: 1;
  }

  /* ─── Visual-Stack: Mobile gestapelt, Desktop überlagernd ─── */
  [data-strategie-visual-stack] {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Auf Mobile alle drei Visuals (Analyse, Roadmap, Sparring) komplett
     ausblenden. Die Step-Texte links erzählen die Story allein, ohne
     Animations-Risiken auf Phones. Desktop bleibt unberührt. */
  @media (max-width: 1023px) {
    [data-strategie-visual-stack] {
      display: none;
    }
    /* Auf Mobile gibt es kein "aktiver Step / inaktiver Step"-Konzept
       (kein Pin, kein Visual-Wechsel) — alle Steps gleich hell anzeigen. */
    [data-strategie-steps] .step {
      opacity: 1;
    }
  }

  @media (min-width: 1024px) {
    [data-strategie-visual-stack] {
      position: relative;
      display: block;
      gap: 0;
      height: 520px;
    }
    [data-strategie-visual-stack] .visual-slot {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s ease;
    }
    [data-strategie-visual-stack] .visual-slot.is-active {
      opacity: 1;
      pointer-events: auto;
    }
  }

  /* ─── Reduced motion: alles sofort sichtbar, kein Pin ─── */
  @media (prefers-reduced-motion: reduce) {
    [data-strategie-steps] .step { opacity: 1; }
    @media (min-width: 1024px) {
      [data-strategie-visual-stack] {
        position: static;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        height: auto;
      }
      [data-strategie-visual-stack] .visual-slot {
        position: static;
        opacity: 1;
        pointer-events: auto;
      }
    }
  }

  /* ─── CTA Glow ─── */
  .cta-glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 420px;
    height: 420px;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle at center,
      rgba(76, 175, 130, 0.28) 0%,
      rgba(76, 175, 130, 0.12) 35%,
      rgba(76, 175, 130, 0) 70%
    );
    filter: blur(40px);
    opacity: 0.85;
    pointer-events: none;
    z-index: 0;
    animation: cta-glow-pulse 6s ease-in-out infinite;
    transition: opacity 400ms ease, transform 400ms ease;
  }

  [data-strategie-cta-button]:hover .cta-glow {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.08);
  }

  @keyframes cta-glow-pulse {
    0%,
    100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(ScrollTrigger, SplitText);

  function initStrategie(): void {
    const section = document.querySelector<HTMLElement>("[data-service-strategie]");
    if (!section) return;

    const ctaTrigger = section.querySelector<HTMLAnchorElement>("[data-strategie-cta] [data-calendly-trigger]");
    if (ctaTrigger) {
      ctaTrigger.addEventListener("click", (e) => {
        const w = window as typeof window & { Calendly?: { initPopupWidget: (o: { url: string }) => void } };
        if (!w.Calendly) return;
        e.preventDefault();
        w.Calendly.initPopupWidget({ url: ctaTrigger.href });
      });
    }

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const ctx = gsap.context(() => {
      const overline = section.querySelector<HTMLElement>("[data-strategie-overline]");
      const h2 = section.querySelector<HTMLElement>("h2");
      const lead = section.querySelector<HTMLElement>("[data-strategie-lead]");
      const steps = Array.from(section.querySelectorAll<HTMLElement>("[data-strategie-steps] [data-step]"));
      const pin = section.querySelector<HTMLElement>("[data-strategie-pin]");
      const visualStack = section.querySelector<HTMLElement>("[data-strategie-visual-stack]");
      const slots = Array.from(section.querySelectorAll<HTMLElement>("[data-visual-slot]"));
      const visualWraps = slots.map((slot) =>
        slot.querySelector<HTMLElement>("[data-analyse-wrap], [data-roadmap-wrap], [data-sparring-wrap]"),
      );

      if (reduced) {
        [overline, h2, lead, visualStack].forEach((el) => {
          if (el) gsap.set(el, { opacity: 1, y: 0 });
        });
        steps.forEach((el) => {
          gsap.set(el, { opacity: 1, y: 0 });
          el.classList.add("is-active");
        });
        slots.forEach((s) => s.classList.add("is-active"));
        // reduced: einfach alle Visuals aktivieren (stacked dargestellt)
        visualWraps.forEach((w) => w?.dispatchEvent(new CustomEvent("activate-visual")));
        return;
      }

      // ─── Entrance Animations (für Header-Block, immer) ───
      if (overline) {
        gsap.set(overline, { opacity: 0, y: 10 });
        gsap.to(overline, {
          opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 78%", once: true },
        });
      }
      if (h2) {
        const split = new SplitText(h2, { type: "words" });
        gsap.set(split.words, { opacity: 0, y: 20 });
        gsap.to(split.words, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 75%", once: true },
        });
      }
      if (lead) {
        gsap.set(lead, { opacity: 0, y: 15 });
        gsap.to(lead, {
          opacity: 1, y: 0, duration: 0.6, ease: "power2.out",
          scrollTrigger: { trigger: lead, start: "top 85%", once: true },
        });
      }

      const ctaWrap = section.querySelector<HTMLElement>("[data-strategie-cta]");
      if (ctaWrap) {
        gsap.set(ctaWrap, { opacity: 0, y: 15 });
        gsap.to(ctaWrap, {
          opacity: 1, y: 0, duration: 0.5, ease: "power2.out",
          scrollTrigger: { trigger: ctaWrap, start: "top 90%", once: true },
        });
      }

      // ─── Active-Step-Handling (Desktop mit Pin + Mobile per Scroll) ───
      let currentIndex = -1;
      function setActive(next: number): void {
        if (next === currentIndex) return;
        const prev = currentIndex;
        currentIndex = next;

        steps.forEach((s, i) => s.classList.toggle("is-active", i === next));
        slots.forEach((s, i) => s.classList.toggle("is-active", i === next));

        // Deaktivieren des vorherigen Visuals (vor allem Pong-Loop pausieren)
        if (prev >= 0 && visualWraps[prev]) {
          visualWraps[prev]!.dispatchEvent(new CustomEvent("deactivate-visual"));
        }
        // Aktivieren des neuen Visuals
        if (visualWraps[next]) {
          visualWraps[next]!.dispatchEvent(new CustomEvent("activate-visual"));
        }
      }

      const isDesktop = window.matchMedia("(min-width: 1024px)").matches;

      if (isDesktop && pin && slots.length === 3) {
        // Desktop: Pin + progress-basierter Step-Wechsel
        ScrollTrigger.create({
          trigger: pin,
          start: "center center",
          end: "+=2100",
          pin: true,
          scrub: 0.6,
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            const p = self.progress;
            // 0 - 0.34 : Step 0, 0.34 - 0.67 : Step 1, 0.67 - 1.0 : Step 2
            const next = p < 0.34 ? 0 : p < 0.67 ? 1 : 2;
            setActive(next);
          },
        });

        // Initialzustand setzen (Step 0 aktiv, erstes Visual aktivieren)
        setActive(0);
      } else {
        // Mobile/Fallback: je Visual ein ScrollTrigger, der das entsprechende Event dispatcht
        slots.forEach((slot, i) => {
          ScrollTrigger.create({
            trigger: slot,
            start: "top 80%",
            once: false,
            onEnter: () => {
              if (visualWraps[i]) {
                visualWraps[i]!.dispatchEvent(new CustomEvent("activate-visual"));
              }
            },
            onLeave: () => {
              // Für Pong: pausieren wenn außer Sicht
              if (visualWraps[i]) {
                visualWraps[i]!.dispatchEvent(new CustomEvent("deactivate-visual"));
              }
            },
            onEnterBack: () => {
              if (visualWraps[i]) {
                visualWraps[i]!.dispatchEvent(new CustomEvent("activate-visual"));
              }
            },
            onLeaveBack: () => {
              if (visualWraps[i]) {
                visualWraps[i]!.dispatchEvent(new CustomEvent("deactivate-visual"));
              }
            },
          });
        });
        // Steps auf Mobile alle aktiv darstellen
        steps.forEach((s) => s.classList.add("is-active"));
      }
    }, section);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initStrategie();
  document.addEventListener("astro:after-swap", initStrategie);
</script>
