---
// ServiceStrategie — Marktplatz-Strategie
// Job: Position Telos as strategic partner, not executor.
// Layout: Mirrored — Visual left (5col), text right (7col) for rhythm.
// Dichte: MITTEL — text-focused, no visual component yet.
---

<section class="py-20 md:py-32" data-service-strategie>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    <!-- Overline + Headline -->
    <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-accent-text mb-4">
      Marktplatz-Strategie
    </p>
    <h2 class="max-w-3xl">
      Erst die Strategie, dann die Skalierung. Nicht umgekehrt.
    </h2>

    <div class="mt-10 md:mt-14 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <!-- Left: Visual weight — Key principles as compact blocks -->
      <div class="lg:col-span-5 flex flex-col gap-6">
        <div class="border border-white/5 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:border-white/15 hover:bg-white/[0.02]">
          <p class="font-body text-base font-semibold uppercase tracking-[0.08em] text-accent-text mb-3">Analyse</p>
          <p class="text-text-primary font-medium text-lg">Deep Research Analysis</p>
          <p class="text-text-secondary text-sm mt-2">Wie groß ist dein Markt wirklich? Wer sind die relevanten Player? Wo liegen die Lücken, die andere nicht sehen?</p>
        </div>
        <div class="border border-white/5 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:border-white/15 hover:bg-white/[0.02]">
          <p class="font-body text-base font-semibold uppercase tracking-[0.08em] text-accent-text mb-3">Kontext</p>
          <p class="text-text-primary font-medium text-lg">Markt, Wettbewerb & Produktportfolio</p>
          <p class="text-text-secondary text-sm mt-2">Wir verstehen dein Geschäftsmodell, dein Sortiment und deine Wettbewerber — bevor wir eine einzige Optimierung starten.</p>
        </div>
        <div class="border border-white/5 rounded-2xl p-6 md:p-8 transition-all duration-300 hover:border-white/15 hover:bg-white/[0.02]">
          <p class="font-body text-base font-semibold uppercase tracking-[0.08em] text-accent-text mb-3">Planung</p>
          <p class="text-text-primary font-medium text-lg">Go-to-Market & Rollout</p>
          <p class="text-text-secondary text-sm mt-2">Welche Marktplätze zuerst? Welche Produkte haben den größten Hebel? Was ist die richtige Reihenfolge?</p>
        </div>
      </div>

      <!-- Right: Text -->
      <div class="lg:col-span-7">
        <p class="text-text-secondary text-lg md:text-xl leading-relaxed">
          Viele Brands starten auf Marktplätzen, indem sie Produkte listen und hoffen, dass es läuft. Wenn es nicht läuft, wird mehr Geld in Ads gesteckt. Wenn es dann immer noch nicht läuft, wird der Kanal als "nicht profitabel" abgestempelt.
        </p>
        <p class="text-text-secondary text-base md:text-lg leading-relaxed mt-6">
          Das Problem ist selten der Kanal. Das Problem ist, dass es keinen Plan gab. Keine Marktanalyse, keine Priorisierung, keine klare Reihenfolge. Wir setzen genau da an: Bevor eine einzige Optimierung startet, verstehen wir deinen Markt, deine Wettbewerber und dein Produktportfolio in der Tiefe.
        </p>
        <p class="text-text-secondary text-base md:text-lg leading-relaxed mt-6">
          Daraus entsteht ein Plan. Kein 80-Seiten-Dokument, sondern eine klare Roadmap: Welche Marktplätze, welche Produkte, welche Hebel. Datenbasiert priorisiert, nicht nach Bauchgefühl. Und dann setzen wir gemeinsam um. Schritt für Schritt, messbar, mit klaren Verantwortlichkeiten.
        </p>
        <p class="text-text-secondary text-base md:text-lg leading-relaxed mt-6">
          Wir denken dabei nicht in isolierten Kanälen, sondern <span class="text-text-primary font-medium">holistisch</span>: Wie spielen organische Sichtbarkeit, Advertising und Produktdaten zusammen? Wo ist der Engpass, der das Wachstum blockiert? Genau dort setzen wir den Hebel an.
        </p>
      </div>

    </div>

    <!-- Checklist -->
    <div class="mt-16 md:mt-20" data-strategie-checklist>
      <h3 class="text-[2rem] sm:text-[2.5rem] md:text-[3rem] leading-tight text-center mb-12" data-pakete-h3>
        Unsere Betreuung enthält folgende Pakete
      </h3>
      <div class="divide-y divide-white/5 border-t border-white/5">

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">Produktdatenoptimierung</p>
            <p class="text-text-secondary text-sm mt-1.5">Optimierung deiner Produktdaten für maximale Sichtbarkeit und Conversion auf allen relevanten Marktplätzen.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">SEO-Optimierung</p>
            <p class="text-text-secondary text-sm mt-1.5">Datenbasierte Keyword-Recherche und Implementierung für maximale organische Sichtbarkeit und bessere Indexierung.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">Strategische Beratung</p>
            <p class="text-text-secondary text-sm mt-1.5">Phasenbasierte Wachstumspläne mit klaren Meilensteinen und messbaren KPIs für nachhaltigen Marktplatzerfolg.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">Margenoptimierung</p>
            <p class="text-text-secondary text-sm mt-1.5">Kontinuierliche Analyse und Verbesserung deiner Gewinnmargen durch strategische Preis- und Kostenoptimierung.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">PPC-Management</p>
            <p class="text-text-secondary text-sm mt-1.5">Effizientes Kampagnen-Management für Sponsored Products, Brands und Display. Datengetrieben, mit klarem Fokus auf ROAS und Profitabilität.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">API-First-Strategien</p>
            <p class="text-text-secondary text-sm mt-1.5">Direkte Anbindung an Marktplatz-APIs für automatisierte Prozesse, Echtzeit-Daten und skalierbare Workflows ohne manuelle Zwischenschritte.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">Produktbilder-Optimierung</p>
            <p class="text-text-secondary text-sm mt-1.5">Analyse und Optimierung deiner Produktbilder für höhere Klickraten und Conversion — abgestimmt auf Marktplatz-Anforderungen und Wettbewerb.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">A+ Content-Optimierung</p>
            <p class="text-text-secondary text-sm mt-1.5">Erstellung und Optimierung von A+ Content für stärkere Markenpräsenz, höhere Conversion und bessere organische Sichtbarkeit.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">Internationalisierung</p>
            <p class="text-text-secondary text-sm mt-1.5">Expansion auf internationale Marktplätze mit lokalisiertem Content, länderspezifischer Keyword-Strategie und angepasster Marktplatz-Architektur.</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

        <div class="flex items-start justify-between gap-6 py-6 md:py-8">
          <div>
            <p class="text-text-primary font-medium text-lg">Operations</p>
            <p class="text-text-secondary text-sm mt-1.5">Automatisierung wiederkehrender Prozesse — Listing-Erstellung · KPI-Dashboards & Alerting · Workflow-Automatisierung · Bestandsmanagement</p>
          </div>
          <span class="shrink-0 rounded-lg bg-[rgba(76,175,130,0.12)] px-3 py-1 text-sm font-medium text-accent-text">Enthalten</span>
        </div>

      </div>
    </div>

    <!-- CTA — unter Checklist -->
    <div class="mt-20 md:mt-28 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center" data-strategie-cta>
      <div class="lg:col-span-7">
        <h3 class="text-2xl md:text-[2rem] tracking-[-0.02em] leading-[1.2]">Lass uns über deine Strategie sprechen.</h3>
        <p class="text-text-secondary text-base md:text-lg leading-relaxed mt-4 max-w-lg">
          Marktplatz Strategie, organische Sichtbarkeit, Anbindungen, Automatisierung. Wir haben die Bausteine. Jetzt kommt es darauf an, welche Kombination für dein Setup den größten Hebel hat.
        </p>
      </div>
      <div class="lg:col-span-5 flex flex-col items-start lg:items-end gap-4 md:gap-5">
        <a
          href="/kontakt"
          class="inline-block bg-accent hover:bg-accent-hover text-background font-medium px-8 py-4 rounded-button tracking-[0.01em] leading-none transition-colors duration-200"
        >
          Kostenloses Erstgespräch
        </a>
        <span class="text-sm text-text-muted">Unverbindlich, 30 Minuten</span>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  const section = document.querySelector("[data-service-strategie]");
  if (section) {
    const overline = section.querySelector("p:first-child");
    const h2 = section.querySelector("h2");
    const cards = section.querySelectorAll(".lg\\:col-span-5 > div");
    const paragraphs = section.querySelectorAll(".lg\\:col-span-7 p");

    if (overline) {
      gsap.set(overline, { opacity: 0, y: 10 });
      gsap.to(overline, {
        opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 78%", once: true },
      });
    }

    if (h2) {
      const split = new SplitText(h2, { type: "words" });
      gsap.set(split.words, { opacity: 0, y: 20 });
      gsap.to(split.words, {
        opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: "power2.out",
        scrollTrigger: { trigger: section, start: "top 75%", once: true },
      });
    }

    if (cards.length) {
      gsap.set(cards, { opacity: 0, y: 25 });
      gsap.to(cards, {
        opacity: 1, y: 0, duration: 0.6, stagger: 0.12, ease: "power2.out",
        scrollTrigger: { trigger: cards[0], start: "top 85%", once: true },
      });
    }

    if (paragraphs.length) {
      gsap.set(paragraphs, { opacity: 0, y: 20 });
      gsap.to(paragraphs, {
        opacity: 1, y: 0, duration: 0.6, stagger: 0.15, ease: "power2.out",
        scrollTrigger: { trigger: paragraphs[0], start: "top 85%", once: true },
      });
    }

    const paketeH3 = section.querySelector("[data-pakete-h3]");
    if (paketeH3) {
      const paketeSplit = new SplitText(paketeH3, { type: "words" });
      gsap.set(paketeSplit.words, { opacity: 0, y: 20 });
      gsap.to(paketeSplit.words, {
        opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: "power2.out",
        scrollTrigger: { trigger: paketeH3, start: "top 80%", once: true },
      });
    }

    const checklist = section.querySelector("[data-strategie-checklist]");
    if (checklist) {
      const rows = checklist.querySelectorAll(".divide-y > div");
      gsap.set(rows, { opacity: 0, y: 20 });
      gsap.to(rows, {
        opacity: 1, y: 0, duration: 0.5, stagger: 0.1, ease: "power2.out",
        scrollTrigger: { trigger: checklist, start: "top 85%", once: true },
      });
    }

    const cta = section.querySelector("[data-strategie-cta]");
    if (cta) {
      const ctaH3 = cta.querySelector("h3");
      const ctaP = cta.querySelector("p");
      const ctaAction = cta.querySelector(".lg\\:col-span-5");

      if (ctaH3) {
        const ctaSplit = new SplitText(ctaH3, { type: "words" });
        gsap.set(ctaSplit.words, { opacity: 0, y: 20 });
        gsap.to(ctaSplit.words, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: "power2.out",
          scrollTrigger: { trigger: cta, start: "top 80%", once: true },
        });
      }

      if (ctaP) {
        gsap.set(ctaP, { opacity: 0, y: 15 });
        gsap.to(ctaP, {
          opacity: 1, y: 0, duration: 0.5, ease: "power2.out",
          scrollTrigger: { trigger: cta, start: "top 80%", once: true },
        });
      }

      if (ctaAction) {
        gsap.set(ctaAction.children, { opacity: 0, y: 15 });
        gsap.to(ctaAction.children, {
          opacity: 1, y: 0, duration: 0.5, stagger: 0.1, ease: "power2.out",
          scrollTrigger: { trigger: ctaAction, start: "top 85%", once: true },
        });
      }
    }
  }
</script>
