---
// ServiceStrategie — Marktplatz Strategie
// Narrativ: Chaos → Klarheit. Aus vielen Baustellen werden drei priorisierte Hebel.
// Key Visual: StrategieClarityVisual Loop-Animation trägt die Sektion.
// Sehr zurückhaltender Text, Visual soll sprechen.
import StrategieClarityVisual from "../../components/StrategieClarityVisual.astro";
---

<section id="marktplatz-strategie" class="scroll-mt-24 py-20 md:py-32" data-service-strategie>
  <div class="mx-auto max-w-7xl px-4 md:px-8">

    {/* Overline + Headline */}
    <p class="font-body text-sm font-medium uppercase tracking-[0.08em] text-accent-text mb-4" data-strategie-overline>
      Marktplatz Strategie
    </p>
    <h2 class="max-w-3xl">
      Erst die Strategie, dann die Skalierung. Nicht umgekehrt.
    </h2>

    {/* Intro — Problem + Lösung in einem Block, Kern-Phrasen hervorgehoben */}
    <p class="mt-8 md:mt-10 max-w-4xl text-text-secondary text-lg leading-relaxed" data-strategie-lead>
      Viele Unternehmen starten auf Marktplätzen, ohne eine klare Antwort darauf, wo sie eigentlich hin wollen und wo die Engpässe liegen. Die Folge: planloses Springen zwischen Themen, jedes Shiny Object fühlt sich wichtig an, Budget und Zeit verbrennen. Das Problem ist selten die Taktik, es ist der <span class="text-text-primary font-medium">fehlende Überblick</span>. Den allein zu behalten ist schwer, zwischen Tagesgeschäft, Teams und zehn gleichzeitigen Baustellen. Genau da setzen wir an: mit <span class="text-text-primary font-medium">Außenperspektive</span> und den <span class="text-text-primary font-medium">Mustern aus vielen Brands</span>, die wir schon begleitet haben.
    </p>

    {/* Editorial-Split: Steps vertikal links, Grafik rechts im Hochformat */}
    <div class="mt-14 md:mt-20 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <div class="lg:col-span-5 flex flex-col gap-10 md:gap-12" data-strategie-steps>
        <div class="step flex gap-5 md:gap-6" data-step>
          <span class="font-body text-sm font-medium tabular-nums text-text-muted leading-none pt-1 shrink-0">01</span>
          <div>
            <p class="font-body text-xs font-medium uppercase tracking-[0.1em] text-accent-text leading-none">
              Analyse
            </p>
            <p class="mt-3 text-text-primary text-base md:text-[1.0625rem] leading-relaxed">
              Ehrlicher Blick auf Kanäle, KPIs, Portfolio, Stärken und Schwächen. Daraus wird sichtbar, wo Budget wirklich liegen bleibt.
            </p>
          </div>
        </div>
        <div class="step flex gap-5 md:gap-6" data-step>
          <span class="font-body text-sm font-medium tabular-nums text-text-muted leading-none pt-1 shrink-0">02</span>
          <div>
            <p class="font-body text-xs font-medium uppercase tracking-[0.1em] text-accent-text leading-none">
              Priorisierte Hebel
            </p>
            <p class="mt-3 text-text-primary text-base md:text-[1.0625rem] leading-relaxed">
              Aus der Analyse leiten wir eine klare, fahrbare Roadmap ab, die für euer Setup den größten Hebel hat. Kein Katalog, eine Priorisierung.
            </p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7" data-strategie-visual>
        <StrategieClarityVisual />
      </div>

    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { SplitText } from "gsap/SplitText";

  gsap.registerPlugin(ScrollTrigger, SplitText);

  function initStrategie(): void {
    const section = document.querySelector<HTMLElement>("[data-service-strategie]");
    if (!section) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const ctx = gsap.context(() => {
      const overline = section.querySelector<HTMLElement>("[data-strategie-overline]");
      const h2 = section.querySelector<HTMLElement>("h2");
      const lead = section.querySelector<HTMLElement>("[data-strategie-lead]");
      const steps = section.querySelectorAll<HTMLElement>("[data-strategie-steps] [data-step]");
      const visual = section.querySelector<HTMLElement>("[data-strategie-visual]");

      if (reduced) {
        [overline, h2, lead, visual].forEach((el) => {
          if (el) gsap.set(el, { opacity: 1, y: 0 });
        });
        steps.forEach((el) => gsap.set(el, { opacity: 1, y: 0 }));
        return;
      }

      if (overline) {
        gsap.set(overline, { opacity: 0, y: 10 });
        gsap.to(overline, {
          opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 78%", once: true },
        });
      }

      if (h2) {
        const split = new SplitText(h2, { type: "words" });
        gsap.set(split.words, { opacity: 0, y: 20 });
        gsap.to(split.words, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: "power2.out",
          scrollTrigger: { trigger: section, start: "top 75%", once: true },
        });
      }

      if (lead) {
        gsap.set(lead, { opacity: 0, y: 15 });
        gsap.to(lead, {
          opacity: 1, y: 0, duration: 0.6, ease: "power2.out",
          scrollTrigger: { trigger: lead, start: "top 85%", once: true },
        });
      }

      if (steps.length) {
        gsap.set(steps, { opacity: 0, y: 18 });
        gsap.to(steps, {
          opacity: 1, y: 0, duration: 0.55, stagger: 0.12, ease: "power2.out",
          scrollTrigger: { trigger: steps[0], start: "top 85%", once: true },
        });
      }

      if (visual) {
        gsap.set(visual, { opacity: 0, y: 24 });
        gsap.to(visual, {
          opacity: 1, y: 0, duration: 0.8, ease: "power2.out",
          scrollTrigger: { trigger: visual, start: "top 85%", once: true },
        });
      }
    }, section);

    document.addEventListener("astro:before-swap", () => ctx.revert(), { once: true });
  }

  initStrategie();
  document.addEventListener("astro:after-swap", initStrategie);
</script>
