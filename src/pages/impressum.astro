---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Impressum" description="Impressum von KFL Consulting – Kevin Flurschütz, Würzburg.">
  <section class="mx-auto max-w-3xl px-4 md:px-8 py-24 md:py-32">
    <h1 class="text-3xl md:text-4xl mb-12">Impressum</h1>

    <div class="space-y-10 text-text-secondary text-base leading-relaxed">
      <div>
        <h2 class="text-lg font-body font-medium text-text-primary mb-3">Angaben gemäß § 5 DDG</h2>
        <p>
          KFL Consulting<br />
          Kevin Flurschütz<br />
          Behrstraße 6<br />
          97074 Würzburg
        </p>
      </div>

      <div>
        <h2 class="text-lg font-body font-medium text-text-primary mb-3">Kontakt</h2>
        <p>
          E-Mail: <a href="mailto:info@kfl-consulting.com" class="text-accent-text hover:text-accent transition-colors duration-200">info@kfl-consulting.com</a>
        </p>
      </div>

      <div>
        <h2 class="text-lg font-body font-medium text-text-primary mb-3">Umsatzsteuer-Identifikationsnummer</h2>
        <p>
          gemäß § 27a Umsatzsteuergesetz:<br />
          DE353948338
        </p>
      </div>

      <div>
        <h2 class="text-lg font-body font-medium text-text-primary mb-3">Redaktionell verantwortlich</h2>
        <p>
          Kevin Flurschütz<br />
          Behrstraße 6<br />
          97074 Würzburg
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
